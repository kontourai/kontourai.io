{
  "name": "kontourai-io",
  "type": "module",
  "version": "0.1.0",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "validate": "node scripts/check-content-boundary.cjs && node scripts/check-theme-tokens.mjs && node scripts/check-security-hardening.mjs && node scripts/check-receipts.mjs && node scripts/check-playwright-pin.mjs && node scripts/validate.mjs && node scripts/check-sitemap.mjs",
    "test:rendered": "npm run build && playwright test",
    "refresh:product-status": "node scripts/refresh-product-status.mjs",
    "check:product-status": "node scripts/refresh-product-status.mjs --dry-run",
    "check:pin-drift": "node scripts/detect-pin-drift.mjs",
    "check:content-boundary": "node scripts/check-content-boundary.cjs",
    "check:sitemap": "node scripts/check-sitemap.mjs",
    "check:playwright-pin": "node scripts/check-playwright-pin.mjs",
    "check:receipts": "node scripts/check-receipts.mjs",
    "check:theme-tokens": "node scripts/check-theme-tokens.mjs",
    "check:security-hardening": "node scripts/check-security-hardening.mjs",
    "sync-versions": "node scripts/sync-versions.mjs",
    "sync-versions:check": "node scripts/sync-versions.mjs --check",
    "workflow:sidecar": "flow-agents-workflow-sidecar",
    "workflow:validate-artifacts": "flow-agents-validate-artifacts"
  },
  "trust-reconcile-manifest": [
    { "id": "site-verify", "command": "npm run build && npm run validate" }
  ],
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^6.4.4",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@kontourai/flow-agents": "^3.1.0",
    "@kontourai/surface": "^2.1.2",
    "@kontourai/ui": "^1.11.0",
    "@playwright/test": "^1.61.1",
    "vite": "^7.3.3",
    "wrangler": "4.107.0"
  }
}
