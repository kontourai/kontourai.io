# Umami Analytics
# Kontour AI production website ID. Override this only if the Umami site changes.
PUBLIC_UMAMI_WEBSITE_ID=6a6ee693-2480-4bd2-a371-6af4e5f82e7d

# Defaults to https://cloud.umami.is/script.js when omitted.
PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js

# Comma-separated production hostnames. Keeps staging/local previews from
# sending analytics if this build is reused somewhere else.
PUBLIC_UMAMI_DOMAINS=kontourai.io,www.kontourai.io

# Cloudflare Web Analytics
# Optional second analytics source. Prefer enabling Web Analytics in the
# Cloudflare Pages settings, or paste the site token here if injecting in code.
PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN=

# Defaults to https://static.cloudflareinsights.com/beacon.min.js when omitted.
PUBLIC_CLOUDFLARE_WEB_ANALYTICS_URL=https://static.cloudflareinsights.com/beacon.min.js
