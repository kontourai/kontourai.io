---
/**
 * Two-column text + visual layout (hero and feature rows). Collapses to a
 * single stacked column on narrow screens via `.stack-mobile`.
 */
interface Props {
  ratio?: "1-1" | "1-1.15" | "1-1.2" | "1.15-1";
  gap?: "md" | "lg";
  align?: "start" | "center";
  class?: string;
  [key: string]: unknown;
}

const { ratio = "1-1", gap = "md", align = "start", class: className, ...rest } = Astro.props;
---

<div
  {...rest}
  class:list={["split", "stack-mobile", className]}
  data-ratio={ratio}
  data-gap={gap}
  data-align={align}
>
  <slot />
</div>

<style>
  .split {
    display: grid;
    min-width: 0;
  }
  .split > :global(*) {
    min-width: 0;
  }
  .split[data-gap="md"] {
    gap: 4rem;
  }
  .split[data-gap="lg"] {
    gap: 5rem;
  }
  .split[data-align="start"] {
    align-items: start;
  }
  .split[data-align="center"] {
    align-items: center;
  }
  .split[data-ratio="1-1"] {
    grid-template-columns: 1fr 1fr;
  }
  .split[data-ratio="1-1.15"] {
    grid-template-columns: 1fr 1.15fr;
  }
  .split[data-ratio="1-1.2"] {
    grid-template-columns: 1fr 1.2fr;
  }
  .split[data-ratio="1.15-1"] {
    grid-template-columns: 1.15fr 1fr;
  }
</style>
