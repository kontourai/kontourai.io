---
import { products, type ProductKey } from '@/lib/products';

interface Props {
  active?: 'home' | 'developers' | ProductKey;
  /** Hide product links regardless of active page (teaser pages like home/early access). */
  teaser?: boolean;
}

const { active, teaser } = Astro.props;
const teaserNav = teaser || active === 'home';

const github = { href: 'https://github.com/kontourai', label: 'GitHub', external: true, event: 'footer-github' };
const links = teaserNav
  ? [
      github,
      { href: '/early-access/', label: 'Early access', event: 'footer-contact' },
    ]
  : [
      { href: '/developers/', label: 'Developers', event: 'footer-developers' },
      ...products.map(({ href, label, key }) => ({ href, label, event: `footer-${key}` })),
      github,
    ];
---

<footer class="footer">
  <div class="container footer__grid">
    <div>
      <a href="/" class="footer__brand" aria-label="Kontour AI home">
        <span class="footer__wordmark">Kontour<span class="footer__dot">.</span></span>
      </a>
      <p class="footer__tagline">Evidence-backed confidence. Not certainty theater.</p>
      <p class="footer__legal">Apache 2.0 &nbsp;·&nbsp; Open source &nbsp;·&nbsp; © 2026 Kontour AI</p>
    </div>

    <nav class="footer__nav">
      {links.map(({ href, label, external, event }) => (
        <a
          href={href}
          target={external ? '_blank' : undefined}
          rel={external ? 'noopener' : undefined}
          data-umami-event={event}
          class="footer__link"
        >{label}</a>
      ))}
    </nav>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-edge);
    margin-top: 8rem;
    padding: 3rem var(--spacing-page);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: start;
  }

  .footer__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    margin-bottom: 0.75rem;
  }

  .footer__wordmark {
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--color-chalk-2);
    letter-spacing: 0;
  }

  .footer__dot {
    color: var(--color-gold);
  }

  .footer__tagline {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-chalk-3);
    line-height: 1.6;
    max-width: 340px;
    letter-spacing: 0;
  }

  .footer__legal {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-chalk-3);
    margin-top: 1.5rem;
    opacity: 0.6;
  }

  .footer__nav {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    align-items: flex-end;
  }

  .footer__link {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-chalk-3);
    text-decoration: none;
    letter-spacing: 0;
    transition: color 0.15s;
  }

  .footer__link:hover {
    color: var(--color-chalk-2);
  }
</style>
