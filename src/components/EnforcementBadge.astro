---
/**
 * Enforcement-level badge (#110): honesty as a UI primitive. Every capability
 * claim that varies by runtime states its real enforcement level through one
 * component, so the levels and their visual grammar can't drift apart page by
 * page.
 *
 * Levels map to the shared `.trust-badge` variants:
 *  - blocking   -> verified (green): the runtime hands the gate real exit
 *                  codes and the turn cannot end on unproven work.
 *  - advisory   -> stale (gold): evidence is computed and surfaced, but the
 *                  stop decision stays with the human on that runtime.
 *  - spec-only  -> unknown (neutral): the open format runs; no runtime hook.
 *
 * `label` overrides the default text when a row needs nuance (e.g.
 * "Advisory / partial"); the level still controls the variant so the color
 * can never contradict the stated level.
 */
import type { EnforcementLevel } from "@/lib/runtime-enforcement";

interface Props {
  level: EnforcementLevel;
  label?: string;
  class?: string;
  [key: string]: unknown;
}

const VARIANTS: Record<EnforcementLevel, { variant: string; label: string }> = {
  blocking: { variant: "verified", label: "Blocking" },
  advisory: { variant: "stale", label: "Advisory" },
  "spec-only": { variant: "unknown", label: "Spec-only" },
};

const { level, label, class: className, ...rest } = Astro.props;
const mapped = VARIANTS[level];
if (!mapped) throw new Error(`EnforcementBadge: unknown level "${level}"`);
// A label may qualify its level ("Advisory / partial") but never rename it —
// the visible text must lead with the canonical level word so the badge can't
// visually claim one level while data-enforcement says another.
if (label && !label.startsWith(mapped.label)) {
  throw new Error(
    `EnforcementBadge: label "${label}" must start with the canonical level label "${mapped.label}"`,
  );
}
---

<span
  {...rest}
  class:list={["trust-badge", `trust-badge--${mapped.variant}`, className]}
  data-enforcement={level}
>{label ?? mapped.label}</span>
