---
/**
 * Per-runtime enforcement table (#110): renders the shared
 * runtime-enforcement data through EnforcementBadge so /trust and
 * /flow-agents show the same rows, badges, and meanings. Styles moved here
 * from trust.astro so the table's visual grammar can't fork either.
 */
import EnforcementBadge from "@/components/EnforcementBadge.astro";
import { runtimeEnforcement } from "@/lib/runtime-enforcement";
---

<div class="table-scroll">
  <table class="enforcement-table">
    <thead>
      <tr>
        <th scope="col">Runtime</th>
        <th scope="col">Enforcement</th>
        <th scope="col">What it means</th>
      </tr>
    </thead>
    <tbody>
      {runtimeEnforcement.map(({ runtime, level, label, meaning }) => (
        <tr>
          <td class="enforcement-table__runtime">{runtime}</td>
          <td>
            <EnforcementBadge level={level} label={label} />
          </td>
          <td class="enforcement-table__meaning">{meaning}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .table-scroll {
    overflow-x: auto;
    border: 1px solid var(--color-edge);
    border-radius: 8px;
    margin-bottom: 1.75rem;
  }
  .enforcement-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }
  .enforcement-table th {
    text-align: left;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.62rem;
    color: var(--color-chalk-2);
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-edge);
    background: var(--color-ink-2);
    white-space: nowrap;
  }
  .enforcement-table td {
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--color-edge);
    vertical-align: top;
    color: var(--color-chalk-2);
  }
  .enforcement-table tr:last-child td {
    border-bottom: none;
  }
  .enforcement-table__runtime {
    color: var(--color-chalk);
    white-space: nowrap;
  }
  .enforcement-table__meaning {
    color: var(--color-chalk-2);
  }
</style>
