---
interface Props {
  active?: 'home' | 'veritas' | 'surface';
}
const { active } = Astro.props;
---

<header style="position: fixed; top: 0; left: 0; right: 0; z-index: 100; border-bottom: 1px solid var(--color-edge);">
  <div style="
    background: rgba(7, 9, 14, 0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  ">
    <nav style="
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 var(--spacing-page);
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    ">
      <!-- Logo -->
      <a href="/" style="display: flex; align-items: center; gap: 0.6rem; text-decoration: none;" aria-label="Kontour AI home">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <!-- Topographic K mark -->
          <path
            d="M4 4 L4 20 M4 12 L14 4 M4 12 L14 20"
            stroke="var(--color-gold)"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <ellipse cx="12" cy="12" rx="8" ry="8" stroke="rgba(201,163,90,0.2)" stroke-width="1" fill="none"/>
          <ellipse cx="12" cy="12" rx="5" ry="5" stroke="rgba(201,163,90,0.12)" stroke-width="1" fill="none"/>
        </svg>
        <span style="
          font-family: var(--font-display);
          font-size: 1.1rem;
          font-weight: 400;
          color: var(--color-chalk);
          letter-spacing: -0.01em;
        ">Kontour<span style="color: var(--color-gold);">.</span></span>
      </a>

      <!-- Nav links -->
      <div style="display: flex; align-items: center; gap: 0.25rem;">
        <a
          href="/veritas"
          aria-current={active === 'veritas' ? 'page' : undefined}
          style={`
            padding: 0.4rem 0.85rem;
            border-radius: 4px;
            font-family: var(--font-mono);
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            text-decoration: none;
            color: ${active === 'veritas' ? 'var(--color-chalk)' : 'var(--color-chalk-3)'};
            background: ${active === 'veritas' ? 'var(--color-ink-3)' : 'transparent'};
            transition: color 0.15s, background 0.15s;
          `}
        >veritas</a>

        <a
          href="/surface"
          aria-current={active === 'surface' ? 'page' : undefined}
          style={`
            padding: 0.4rem 0.85rem;
            border-radius: 4px;
            font-family: var(--font-mono);
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            text-decoration: none;
            color: ${active === 'surface' ? 'var(--color-chalk)' : 'var(--color-chalk-3)'};
            background: ${active === 'surface' ? 'var(--color-ink-3)' : 'transparent'};
            transition: color 0.15s, background 0.15s;
          `}
        >surface</a>

        <div style="width: 1px; height: 18px; background: var(--color-edge); margin: 0 0.5rem;"></div>

        <a
          href="https://github.com/kontourai"
          target="_blank"
          rel="noopener"
          style="
            padding: 0.4rem 0.85rem;
            border-radius: 4px;
            font-family: var(--font-mono);
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            text-decoration: none;
            color: var(--color-chalk-3);
            display: flex;
            align-items: center;
            gap: 0.4rem;
            transition: color 0.15s;
          "
        >
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          github
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  a[style*="color: var(--color-chalk-3)"]:hover {
    color: var(--color-chalk) !important;
  }
</style>
