---
import type { Accent } from '@/lib/theme';

type NavKey = 'home' | 'preview' | 'veritas' | 'surface' | 'survey' | 'flow' | 'flow-agents' | 'console';

interface Props {
  active?: NavKey;
}
const { active } = Astro.props;

// Product nav links, in display order, each with its accent when active.
const links: { href: string; label: string; key: NavKey; accent: Accent }[] = [
  { href: '/veritas', label: 'veritas', key: 'veritas', accent: 'green' },
  { href: '/flow', label: 'flow', key: 'flow', accent: 'cobalt-2' },
  { href: '/flow-agents', label: 'Flow Agents', key: 'flow-agents', accent: 'chalk-2' },
  { href: '/surface', label: 'surface', key: 'surface', accent: 'gold' },
  { href: '/survey', label: 'survey', key: 'survey', accent: 'gold-2' },
  { href: '/console', label: 'console', key: 'console', accent: 'cobalt' },
];
---

<header class="nav">
  <div class="nav__bar">
    <nav class="nav__inner">
      <!-- Logo -->
      <a href="/" class="nav__logo" aria-label="Kontour AI home">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <!-- Topographic K mark -->
          <path
            d="M4 4 L4 20 M4 12 L14 4 M4 12 L14 20"
            stroke="var(--color-gold)"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <ellipse cx="12" cy="12" rx="8" ry="8" stroke="rgba(201,163,90,0.2)" stroke-width="1" fill="none"/>
          <ellipse cx="12" cy="12" rx="5" ry="5" stroke="rgba(201,163,90,0.12)" stroke-width="1" fill="none"/>
        </svg>
        <span class="nav__wordmark">Kontour<span class="nav__dot">.</span></span>
      </a>

      <!-- Nav links -->
      <div class="nav-links nav__links">
        {active !== 'home' && (
          <>
            {links.map(({ href, label, key, accent }) => (
              <a
                href={href}
                class="nav-link"
                aria-current={active === key ? 'page' : undefined}
                data-accent={active === key ? accent : undefined}
                data-umami-event={`nav-${key}`}
              >{label}</a>
            ))}

            <div class="nav__divider"></div>
          </>
        )}

        <a
          href="https://github.com/kontourai"
          target="_blank"
          rel="noopener"
          data-umami-event="nav-github"
          class="nav-link nav__github"
        >
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          github
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    border-bottom: 1px solid var(--color-edge);
  }

  .nav__bar {
    background: rgba(7, 9, 14, 0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--spacing-page);
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
  }

  .nav__wordmark {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--color-chalk);
    letter-spacing: 0;
  }

  .nav__dot {
    color: var(--color-gold);
  }

  /* Keep the bar one line tall; let links scroll on narrow screens instead of
     wrapping (which would break the fixed header height). */
  .nav__links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    min-width: 0;
    overflow-x: auto;
  }
  .nav__links {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .nav__links::-webkit-scrollbar {
    display: none;
  }

  .nav__divider {
    width: 1px;
    height: 18px;
    background: var(--color-edge);
    margin: 0 0.5rem;
  }

  .nav__github {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  /* Active link accent (the `.nav-link[aria-current]` background lives in
     global.css; this adds the per-product color). */
  .nav-link[aria-current="page"][data-accent] {
    color: var(--accent);
  }
</style>
