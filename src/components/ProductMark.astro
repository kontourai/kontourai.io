---
/**
 * ProductMark — the canonical per-product glyph.
 *
 * One source of truth for the Kontour product marks so the Nav, the homepage
 * product grid, and each product hero all reference identical SVG rather than
 * copy-pasting paths. Each mark is a 24×24 stroke icon drawn with
 * `currentColor`, so it inherits whatever color the surrounding context sets
 * (e.g. a product page's accent or the default text color).
 *
 * Marks are sourced at build time from @kontourai/ui via Vite `?raw` SVG
 * imports — a single source of truth shared with the design system. Only the
 * static .svg files are imported, so no React or token CSS enters the bundle.
 */
import consoleSvg from "@kontourai/ui/icons/console.svg?raw";
import flowAgentsSvg from "@kontourai/ui/icons/flow-agents.svg?raw";
import flowSvg from "@kontourai/ui/icons/flow.svg?raw";
import surfaceSvg from "@kontourai/ui/icons/surface.svg?raw";
import surveySvg from "@kontourai/ui/icons/survey.svg?raw";
import veritasSvg from "@kontourai/ui/icons/veritas.svg?raw";

export type ProductMarkSlug =
  "surface" | "flow" | "veritas" | "survey" | "console" | "flow-agents";

type Props = {
  /** Product slug selecting which glyph to render. */
  product: ProductMarkSlug;
  /** Pixel size of the square mark. Defaults to 24 (the native viewBox size). */
  size?: number;
  /** Extra class names forwarded to the <svg>. */
  class?: string;
} & Record<string, unknown>;

const { product, size = 24, class: className, ...rest } = Astro.props as Props;

/**
 * Inner SVG markup for each product, sourced from @kontourai/ui at build time.
 * `extractInner` strips the package's <svg> wrapper (including its fixed
 * width/height) so the shared <svg> below — and the `size` prop — control
 * rendering. The inner paths match the design-system marks exactly.
 */
function extractInner(rawSvg: string): string {
  return rawSvg
    .replace(/^<svg[^>]*>/, "")
    .replace(/<\/svg>\s*$/, "")
    .trim();
}

const inner: Record<ProductMarkSlug, string> = {
  surface: extractInner(surfaceSvg),
  flow: extractInner(flowSvg),
  veritas: extractInner(veritasSvg),
  survey: extractInner(surveySvg),
  console: extractInner(consoleSvg),
  "flow-agents": extractInner(flowAgentsSvg),
};

const classAttr = className ? `product-mark ${className}` : "product-mark";
---

<svg
  class={classAttr}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.75"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  {...rest}
  set:html={inner[product]}
/>
