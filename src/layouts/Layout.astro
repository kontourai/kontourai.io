---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  og?: {
    title?: string;
    description?: string;
    image?: string;
    imageAlt?: string;
  };
}

const {
  title,
  description = 'Show the work behind AI. Kontour makes AI-assisted work inspectable — what was claimed, what supports it, which gates it passed, and what is still uncertain.',
  noindex = false,
  og,
} = Astro.props;

const ogTitle = og?.title ?? title;
const ogDescription = og?.description ?? description;
const site = Astro.site ?? new URL('https://kontourai.io');
const canonicalUrl = new URL(Astro.url.pathname, site);
const ogImage = new URL(og?.image ?? '/og/kontour-share.png', site);
const ogImageAlt = og?.imageAlt ?? 'Kontour AI share card showing inspectability infrastructure for AI-assisted work.';
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID ?? '6a6ee693-2480-4bd2-a371-6af4e5f82e7d';
const umamiScriptUrl = import.meta.env.PUBLIC_UMAMI_SCRIPT_URL ?? 'https://cloud.umami.is/script.js';
const umamiDomains = import.meta.env.PUBLIC_UMAMI_DOMAINS ?? 'kontourai.io,www.kontourai.io';
const cloudflareAnalyticsToken = import.meta.env.PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN;
const cloudflareAnalyticsUrl = import.meta.env.PUBLIC_CLOUDFLARE_WEB_ANALYTICS_URL ?? 'https://static.cloudflareinsights.com/beacon.min.js';
const shouldLoadUmami = Boolean(umamiWebsiteId) && import.meta.env.PROD;
const shouldLoadCloudflareAnalytics = Boolean(cloudflareAnalyticsToken) && import.meta.env.PROD;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex ? (
      <meta name="robots" content="noindex, follow" />
    ) : (
      <link rel="canonical" href={canonicalUrl.href} />
    )}

    <!-- OG -->
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Kontour AI" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage.href} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <title>{title}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,200;0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,200;1,9..144,300;1,9..144,400&family=JetBrains+Mono:wght@400;500&family=Syne:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    {
      shouldLoadUmami && (
        <script
          defer
          src={umamiScriptUrl}
          data-website-id={umamiWebsiteId}
          data-domains={umamiDomains}
          data-do-not-track="true"
          data-exclude-search="true"
        />
      )
    }
    {
      shouldLoadCloudflareAnalytics && (
        <script
          defer
          src={cloudflareAnalyticsUrl}
          data-cf-beacon={`{"token":"${cloudflareAnalyticsToken}"}`}
        />
      )
    }
  </head>
  <body>
    <slot />
  </body>
</html>
