---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
---

<Layout
  title="Kontour AI Preview — Internal review"
  description="Internal review page for the Kontour AI product line."
>
  <Nav active="preview" />

  <section class="contour-bg" style="padding: 8rem var(--spacing-page) 4rem; border-bottom: 1px solid var(--color-edge);">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 1rem; color: var(--color-gold);">INTERNAL REVIEW — UNLINKED</div>
      <h1 class="display-lg" style="color: var(--color-chalk); margin-bottom: 1rem;">Kontour AI shows the work behind AI.</h1>
      <p style="color: var(--color-chalk-2); font-size: 1rem; line-height: 1.75; max-width: 760px; margin-bottom: 2rem;">
        This page is for design partners and reviewers. It's not linked from
        the public site. Content here may include unshipped features and
        timeline estimates that aren't yet public.
      </p>
      <p style="color: var(--color-chalk-3); font-size: 0.95rem; line-height: 1.7; max-width: 760px;">
        Kontour AI shows the work behind AI. Agents now write code, run
        processes, and make claims faster than people can review them. Our
        products give humans and other agents a shared way to see what was
        claimed, what supports it, which gates the work passed, and what's
        still uncertain — so anyone can decide whether the work deserves
        trust before acting on it. The same shape works for any product that
        needs to show its work, not just AI ones.
      </p>
    </div>
  </section>

  <section style="padding: 5rem var(--spacing-page);">
    <div style="max-width: 1280px; margin: 0 auto; display: flex; flex-direction: column; gap: 3rem;">
      {[
        {
          name: 'Surface',
          badge: 'v0.5.0',
          color: 'var(--color-gold)',
          one: "The shared foundation under Kontour's products. One shape for claims, evidence, freshness, and gaps so the same trust state can be read by a person, an agent, or another system.",
          now: 'Current package: @kontourai/surface v0.5.0.',
          coming: 'Support for external integrations; expanded Producer Extension API.',
          demo: `$ npx surface report --format summary

Kontour Surface trust snapshot surface-1777090239260
Source: kontour-surface-validation-fixtures

Claims: 4 (unknown: 1, verified: 2, stale: 1)
High-impact unsupported: none
Transparency gaps: 3`,
        },
        {
          name: 'Flow',
          badge: 'v0.1.0',
          color: 'var(--color-cobalt-2)',
          one: 'Process transparency for any required-path work. Flow shows why a process was allowed to move forward — gate by gate, with the evidence behind each transition.',
          now: 'Current package: @kontourai/flow v0.1.0.',
          coming: 'v0.1 CLI; evidence adapters for command/file/CI/Veritas/human/trace.',
          demo: `$ flow status run.dev-1847 --format summary

flow run: agent-dev-flow / feature-search-filters
current step: verify

PASS  plan gate: acceptance criteria linked
PASS  implementation gate: scoped files changed
BLOCK verify gate: browser evidence missing
      expected: tests, lint, screenshot, Veritas readiness

next action: run browser check before publish
continuation: resume from verify, not chat memory
report: .flow/runs/run.dev-1847/report.md`,
        },
        {
          name: 'Veritas',
          badge: 'v0.4.0',
          color: 'var(--color-green)',
          one: "Merge autonomy for AI-authored code. Veritas turns your repo's standards into evidence-backed readiness reports agents and reviewers can rely on.",
          now: 'Current package: @kontourai/veritas v0.4.0.',
          coming: 'Repo Conformance public docs; Standards Recommendations workflow.',
          demo: `$ npx veritas readiness --working-tree --format feedback

veritas 0.4.0 — readiness
repo standards: loaded
repo map: loaded

PASS  protected-standards: no unauthorized edits
PASS  evidence-check: npm run verify
PASS  change-boundaries: no unreviewed boundary crossing
PASS  merge-readiness: ready

readiness coverage:
  satisfied: 12
  advisory: 1
  stale: 0
  missing: 0

report: .veritas/evidence/readiness-local.json`,
        },
        {
          name: 'Flow Agents',
          badge: 'coming soon',
          color: 'var(--color-chalk-2)',
          one: 'Keep your coding agent on the required path across Claude Code, Codex, Kiro, and GitHub Actions. Flow Agents brings Flow-backed workflows and Kontour evidence into the agent tools you already use.',
          now: 'In active development; public alpha expected soon.',
          coming: 'Public alpha bundles for Claude Code, Codex, Kiro; work-mode library (Build / Understand / Capture / Prepare / Follow Up).',
          demo: `$ flow-agents status

distribution: upcoming public alpha
runtimes: Claude Code, Codex, Kiro, GitHub Actions
workflow state: Flow-backed
code evidence: Veritas readiness
repo: https://github.com/kontourai/flow-agents`,
        },
      ].map(({ name, badge, color, one, now, coming, demo }) => (
        <article class="card" style="padding: 2rem; position: relative; overflow: hidden;">
          <div style={`
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, ${color}, transparent);
          `}></div>
          <div style="display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 2rem;">
            <div>
              <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
                <span class="trust-badge trust-badge--proposed">{badge}</span>
                <span class="label-sm" style={`color: ${color};`}>{name}</span>
              </div>
              <h2 class="display-md" style="color: var(--color-chalk); margin-bottom: 1rem;">{name}</h2>
              <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.7;">{one}</p>
              <div style="margin-top: 1.5rem; padding: 1rem; background: var(--color-ink-1); border: 1px solid var(--color-edge); border-radius: 4px;">
                <div class="label-sm" style="margin-bottom: 0.7rem;">What's shipping now / what's coming</div>
                <p style="color: var(--color-chalk-3); font-size: 0.82rem; line-height: 1.6; margin: 0 0 0.6rem;">{now}</p>
                <p style="color: var(--color-chalk-3); font-size: 0.82rem; line-height: 1.6; margin: 0;">Coming: {coming}</p>
              </div>
            </div>
            <div class="terminal">
              <div class="terminal-bar">
                <div class="terminal-dot"></div>
                <div class="terminal-dot"></div>
                <div class="terminal-dot"></div>
                <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--color-chalk-3); margin-left: 0.5rem;">{name.toLowerCase()} demo</span>
              </div>
              <div class="terminal-body">
                <pre style="margin: 0; white-space: pre-wrap; font-family: var(--font-mono); font-size: 0.75rem; line-height: 1.6; color: var(--color-chalk-2);">{demo}</pre>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <Footer active="preview" />
</Layout>

<style>
  @media (max-width: 900px) {
    article > div[style*="grid-template-columns"] {
      display: flex !important;
      flex-direction: column !important;
    }
  }
</style>
