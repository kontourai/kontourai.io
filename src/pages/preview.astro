---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import Terminal from '@/components/Terminal.astro';
import Section from '@/components/Section.astro';
import Card from '@/components/Card.astro';
import type { Accent } from '@/lib/theme';

const items: { name: string; badge: string; accent: Accent; one: string; now: string; coming: string; demo: string }[] = [
  {
    name: 'Surface',
    badge: 'v0.5.1',
    accent: 'gold',
    one: "Surface makes claims inspectable. One shape for claims, evidence, policies, freshness, and gaps so the same trust state can be read by a person, an agent, or another system.",
    now: 'Current package: @kontourai/surface v0.5.1.',
    coming: 'Support for external integrations; expanded Producer Extension API.',
    demo: `$ npx surface report --format summary

Kontour Surface trust snapshot surface-1777090239260
Source: kontour-surface-validation-fixtures

Claims: 4 (unknown: 1, verified: 2, stale: 1)
High-impact unsupported: none
Transparency gaps: 3`,
  },
  {
    name: 'Survey',
    badge: 'v0.4.6',
    accent: 'gold-2',
    one: 'Survey makes the producer side of claims inspectable before Surface. Sources, extractions, candidates, and reviews become Surface-ready claims with provenance attached — without absorbing producer domain policy.',
    now: 'Current package: @kontourai/survey v0.4.6. Proof-stage library, not an ingestion platform.',
    coming: 'Resource-shaped ClaimReviewRecord exports; structured derivation edges; first vertical adapters.',
    demo: `import { buildSurveyTrustInput, SurveyInputBuilder } from "@kontourai/survey";
import { buildTrustReport } from "@kontourai/surface";

const input = new SurveyInputBuilder({ source: "crawler:run-1" })
  .addObservation(observation)
  .build();

const report = buildTrustReport(buildSurveyTrustInput(input));

// source -> extraction -> candidate -> review -> claim
// projected into a Surface TrustInput`,
  },
  {
    name: 'Flow',
    badge: 'v0.1.0',
    accent: 'cobalt-2',
    one: 'Flow makes required process paths inspectable. It shows why a process was allowed to move forward — gate by gate, with the evidence behind each transition.',
    now: 'Current package: @kontourai/flow v0.1.0. Local CLI plus a loopback Flow Console.',
    coming: 'Evidence adapters for command/file/CI/Veritas/human/trace; richer console views.',
    demo: `$ flow status run.dev-1847 --format summary

flow run: agent-dev-flow / feature-search-filters
current step: verify

PASS  plan gate: acceptance criteria linked
PASS  implementation gate: scoped files changed
BLOCK verify gate: browser evidence missing
      expected: tests, lint, screenshot, Veritas readiness

next action: run browser check before publish
continuation: resume from verify, not chat memory
report: .flow/runs/run.dev-1847/report.md`,
  },
  {
    name: 'Veritas',
    badge: 'v0.4.0',
    accent: 'green',
    one: "Veritas makes code and change readiness inspectable. It turns your repo's standards into evidence-backed readiness reports agents and reviewers can rely on.",
    now: 'Current package: @kontourai/veritas v0.4.0.',
    coming: 'Repo Conformance public docs; Standards Recommendations workflow.',
    demo: `$ npx veritas readiness --working-tree --format feedback

veritas 0.4.0 — readiness
repo standards: loaded
repo map: loaded

PASS  protected-standards: no unauthorized edits
PASS  evidence-check: npm run verify
PASS  change-boundaries: no unreviewed boundary crossing
PASS  merge-readiness: ready

readiness coverage:
  satisfied: 12
  advisory: 1
  stale: 0
  missing: 0

report: .veritas/evidence/readiness-local.json`,
  },
  {
    name: 'Flow Agents',
    badge: 'early access',
    accent: 'chalk-2',
    one: 'Flow Agents applies Flow and Veritas discipline inside Claude Code, Codex, Kiro, and GitHub Actions. It keeps coding work on the required path without becoming an agent runtime.',
    now: 'Installable today from GitHub via install.sh; pre-1.0, GitHub-only (not yet on npm).',
    coming: 'npm distribution; broader work-mode library (Build / Understand / Capture / Prepare / Follow Up); framework adapters.',
    demo: `$ bash install.sh ~/dev/my-project

distribution: GitHub (install.sh), pre-1.0
runtimes: Claude Code, Codex, Kiro, GitHub Actions
workflow state: Flow-backed sidecars
code evidence: optional Veritas readiness
repo: https://github.com/kontourai/flow-agents`,
  },
  {
    name: 'Console',
    badge: 'early preview',
    accent: 'cobalt',
    one: 'Console makes the suite operable. It brings claim status, process state, proof, queues, decisions, freshness, and next actions across Kontour products into one place — without owning their semantics.',
    now: 'Early preview. Portable contracts, a local read-only fixture inspector, and a local UI over a loopback SSE hub — not a hosted service. Primitives work without it.',
    coming: 'Shared console shell after Surface / Flow / Survey consoles converge; unified work queue and suite-level action routing.',
    demo: `$ npm run inspect:fixtures

Kontour Console fixture inspection
Event streams: 3   Projection snapshots: 2

claim   claim-provider-directory  verified  fresh
process run-provider-118-review  completed
gate    gate-provider-evidence    passed
review  review-provider-118       approved

Validation: errors=0
actions shown as inert descriptors only`,
  },
];
---

<Layout
  title="Kontour AI Preview — Internal review"
  description="Internal review page for the Kontour AI product line."
>
  <Nav active="preview" />

  <section class="contour-bg preview-hero">
    <div class="container">
      <p class="label-sm preview-hero__kicker">INTERNAL REVIEW — UNLINKED</p>
      <h1 class="display-lg preview-hero__title">Kontour AI shows the work behind AI.</h1>
      <p class="preview-hero__lede">
        This page is for design partners and reviewers. It's not linked from
        the public site. Content here may include unshipped features and
        timeline estimates that aren't yet public.
      </p>
      <p class="preview-hero__body">
        Kontour AI builds inspectability infrastructure for AI-assisted work.
        Agents now write code, run processes, and make claims faster than people
        can manually inspect. Our products give humans and other agents a shared
        way to see what was claimed, what supports it, which gates the work
        passed, and what's still uncertain — so anyone can decide what deserves
        trust before acting on it. The same shape works for any product that
        needs to show its work, not just AI ones.
      </p>
    </div>
  </section>

  <Section>
    <div class="container preview-list">
      {items.map(({ name, badge, accent, one, now, coming, demo }) => (
        <Card accent={accent} bar="top" pad="lg">
          <div class="preview-split stack-mobile">
            <div>
              <div class="preview-card__head">
                <span class="trust-badge trust-badge--proposed">{badge}</span>
                <span class="label-sm pname">{name}</span>
              </div>
              <h2 class="display-md preview-card__title">{name}</h2>
              <p class="body">{one}</p>
              <div class="preview-meta">
                <p class="label-sm preview-meta__label">What's shipping now / what's coming</p>
                <p class="preview-meta__text">{now}</p>
                <p class="preview-meta__text preview-meta__text--last">Coming: {coming}</p>
              </div>
            </div>
            <Terminal title={`${name.toLowerCase()} demo`}>
              <pre class="pv-demo">{demo}</pre>
            </Terminal>
          </div>
        </Card>
      ))}
    </div>
  </Section>

  <Footer active="preview" />
</Layout>

<style>
  .preview-hero {
    padding: 8rem var(--spacing-page) 4rem;
    border-bottom: 1px solid var(--color-edge);
    position: relative;
    overflow: hidden;
  }
  .preview-hero__kicker {
    color: var(--color-gold);
    margin: 0 0 1rem;
  }
  .preview-hero__title {
    margin-bottom: 1rem;
  }
  .preview-hero__lede {
    color: var(--color-chalk-2);
    font-size: 1rem;
    line-height: 1.75;
    max-width: 760px;
    margin-bottom: 2rem;
  }
  .preview-hero__body {
    color: var(--color-chalk-3);
    font-size: 0.95rem;
    line-height: 1.7;
    max-width: 760px;
  }

  .preview-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  .preview-split {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 2rem;
  }
  .preview-card__head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .pname {
    color: var(--accent);
  }
  .preview-card__title {
    margin-bottom: 1rem;
  }
  .preview-meta {
    margin-top: 1.5rem;
    padding: 1rem;
    background: var(--color-ink-1);
    border: 1px solid var(--color-edge);
    border-radius: 4px;
  }
  .preview-meta__label {
    margin-bottom: 0.7rem;
  }
  .preview-meta__text {
    color: var(--color-chalk-3);
    font-size: 0.82rem;
    line-height: 1.6;
    margin: 0 0 0.6rem;
  }
  .preview-meta__text--last {
    margin-bottom: 0;
  }
  .pv-demo {
    margin: 0;
    white-space: pre-wrap;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.6;
    color: var(--color-chalk-2);
  }
</style>
