---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
---

<Layout
  title="Veritas — Merge autonomy for AI-authored code · Kontour AI"
  description="Veritas helps teams trust AI-authored code by turning repo standards into evidence-backed readiness reports, guidance, and merge gates."
>
  <Nav active="veritas" />

  <!-- ──────────────────────────────────────────────────────
       Hero
  ────────────────────────────────────────────────────────── -->
  <section class="contour-bg" style="
    padding: 10rem var(--spacing-page) 6rem;
    border-bottom: 1px solid var(--color-edge);
    position: relative;
    overflow: hidden;
  ">
    <!-- Green accent glow -->
    <div style="
      position: absolute;
      top: 0;
      right: 0;
      width: 600px;
      height: 400px;
      background: radial-gradient(ellipse at top right, rgba(82,196,126,0.05) 0%, transparent 70%);
      pointer-events: none;
    "></div>

    <div style="max-width: 1280px; margin: 0 auto; position: relative; z-index: 1;">
      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
        align-items: center;
      ">
        <!-- Left -->
        <div>
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 2rem;">
            <span class="trust-badge trust-badge--verified">v0.4.0</span>
            <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--color-chalk-3);">npm install -D @kontourai/veritas</span>
          </div>

          <h1 class="animate-fade-up" style="
            font-family: var(--font-display);
            font-optical-sizing: auto;
            font-size: clamp(3.5rem, 6vw, 5.5rem);
            font-weight: 400;
            line-height: 0.95;
            letter-spacing: -0.03em;
            color: var(--color-chalk);
            margin-bottom: 0.5rem;
          ">Veritas</h1>

          <p class="animate-fade-up delay-100" style="
            font-family: var(--font-mono);
            font-size: 0.75rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--color-green);
            margin-bottom: 2rem;
          ">Merge autonomy for AI-authored code · Built with Surface</p>

          <p class="animate-fade-up delay-200" style="
            font-size: 1.05rem;
            color: var(--color-chalk-2);
            line-height: 1.7;
            max-width: 460px;
            margin-bottom: 2.5rem;
          ">
            Veritas turns your repo standards into evidence-backed checks, guidance,
            and readiness reports so routine AI-authored changes can move without
            making humans re-review every implementation detail.
          </p>

          <div class="animate-fade-up delay-300" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
            <a href="https://github.com/kontourai/veritas" target="_blank" rel="noopener" class="btn-primary" data-umami-event="veritas-hero-github">
              View on GitHub →
            </a>
            <a href="https://www.npmjs.com/package/@kontourai/veritas" target="_blank" rel="noopener" class="btn-ghost" data-umami-event="veritas-hero-npm">
              npm package
            </a>
          </div>
        </div>

        <!-- Right: run output -->
        <div class="animate-fade-in delay-300">
          <div class="terminal">
            <div class="terminal-bar">
              <div class="terminal-dot"></div>
              <div class="terminal-dot"></div>
              <div class="terminal-dot"></div>
              <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--color-chalk-3); margin-left: 0.5rem;">veritas readiness</span>
            </div>
            <div class="terminal-body">
              <p><span class="prompt">$ </span><span class="cmd">npx veritas readiness --working-tree</span></p>
              <br />
              <p class="info">  veritas 0.4.0 — readiness</p>
              <p class="muted">  repo map:      loaded</p>
              <p class="muted">  repo standards: loaded</p>
              <br />
              <p class="pass">  PASS  evidence-check: npm run verify</p>
              <p class="pass">  PASS  repo-standards-present</p>
              <p class="pass">  PASS  ai-instruction-files-synced</p>
              <p class="pass">  PASS  merge-readiness: ready</p>
              <br />
              <p class="warn">  INFO  evidence-freshness: current</p>
              <p style="color: var(--color-chalk-3); padding-left: 2rem; font-size: 0.72rem;">
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;→ checked against this diff and standards version
              </p>
              <p style="color: var(--color-chalk-3); padding-left: 2rem; font-size: 0.72rem;">
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;→ boundary crossing: none
              </p>
              <br />
              <p style="color: var(--color-chalk-3);">  ───────────────────────────────</p>
              <p style="color: var(--color-chalk-2);">  0 failures &nbsp; 0 warnings</p>
              <p class="muted">  evidence → .veritas/evidence/&lt;run-id&gt;.json</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Product promise
  ────────────────────────────────────────────────────────── -->
  <section style="padding: 6rem var(--spacing-page);">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 3rem;">What Veritas makes possible</div>

      <div style="
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
      ">
        {[
          {
            num: '01',
            title: 'Define what good looks like',
            color: 'var(--color-green)',
            summary: 'Repo Standards',
            body: 'Capture the repo expectations reviewers keep in their heads: required tests, protected files, shared contracts, release checks, security scans, boundaries, and authority rules.',
            tags: ['requirements', 'evidence-checks', 'authorities', 'guidance'],
          },
          {
            num: '02',
            title: 'Guide work at the moment of change',
            color: 'var(--color-cobalt-2)',
            summary: 'Change Guidance',
            body: 'When an agent or developer touches a risky work area, Veritas supplies the relevant standards before context drift turns into a bad merge.',
            tags: ['work-areas', 'boundaries', 'hooks', 'recheck'],
          },
          {
            num: '03',
            title: 'Earn merge readiness',
            color: 'var(--color-gold)',
            summary: 'Readiness Reports',
            body: 'Every change gets a clear answer: what passed, what failed, what evidence is stale, what needs recheck, and why this change can or cannot merge with reduced human review.',
            tags: ['merge-readiness', 'freshness', 'exceptions', 'coverage'],
          },
        ].map(({ num, title, color, summary, body, tags }) => (
          <div key={num} class="card" style="padding: 2rem;">
            <div style="
              font-family: var(--font-mono);
              font-size: 0.65rem;
              color: var(--color-chalk-3);
              margin-bottom: 1rem;
            ">{num}</div>

            <div style={`
              width: 28px;
              height: 2px;
              background: ${color};
              margin-bottom: 1.25rem;
              border-radius: 1px;
            `}></div>

            <h3 style="
              font-family: var(--font-display);
              font-size: 1.5rem;
              font-weight: 400;
              color: var(--color-chalk);
              margin-bottom: 0.35rem;
              letter-spacing: -0.01em;
            ">{title}</h3>

            <p style={`
              font-family: var(--font-mono);
              font-size: 0.7rem;
              color: ${color};
              margin-bottom: 1rem;
              letter-spacing: 0.03em;
            `}>{summary}</p>

            <p style="
              color: var(--color-chalk-2);
              font-size: 0.875rem;
              line-height: 1.7;
              margin-bottom: 1.5rem;
            ">{body}</p>

            <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
              {tags.map(tag => (
                <span key={tag} style="
                  font-family: var(--font-mono);
                  font-size: 0.58rem;
                  padding: 0.12rem 0.45rem;
                  border: 1px solid var(--color-edge-2);
                  border-radius: 2px;
                  color: var(--color-chalk-3);
                  letter-spacing: 0.06em;
                ">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Change boundaries
  ────────────────────────────────────────────────────────── -->
  <section style="
    padding: 5rem var(--spacing-page);
    border-top: 1px solid var(--color-edge);
    border-bottom: 1px solid var(--color-edge);
    background: var(--color-ink-1);
  ">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
      ">
        <div>
          <div class="label-sm" style="margin-bottom: 1.5rem; color: var(--color-cobalt-2);">Change boundaries</div>
          <h2 class="display-md" style="color: var(--color-chalk); margin-bottom: 1.25rem;">
            Shared code without<br />
            shared confusion.
          </h2>
          <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.75; margin-bottom: 1.5rem;">
            Fast AI development breaks down when several agents and developers touch
            the same repo without knowing which work areas are independent, protected,
            or coupled. Veritas makes those boundaries explicit.
          </p>
          <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.75; margin-bottom: 1.5rem;">
            A change that stays inside its work area can move quickly. A boundary crossing
            asks for the right evidence, owner context, or coordination before it becomes
            another surprise in review.
          </p>
          <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.75; margin-bottom: 0;">
            This is how teams keep code DRY without turning every shared package,
            contract, or generated artifact into a manual-review bottleneck.
          </p>
        </div>

        <!-- Activation targets grid -->
        <div style="
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 1rem;
        ">
          {[
            { label: 'Work Area', detail: 'Where the change belongs', color: 'var(--color-gold)' },
            { label: 'Change Boundary', detail: 'Where extra coordination begins', color: 'var(--color-cobalt-2)' },
            { label: 'Protected Area', detail: 'Where stronger authority is required', color: 'var(--color-green)' },
            { label: 'Boundary Crossing', detail: 'When readiness needs more evidence', color: 'var(--color-chalk-2)' },
          ].map(({ label, detail, color }) => (
            <div key={label} style="
              background: var(--color-ink-2);
              border: 1px solid var(--color-edge);
              border-radius: 6px;
              padding: 1.25rem;
            ">
              <div style={`
                font-family: var(--font-mono);
                font-size: 0.7rem;
                color: ${color};
                margin-bottom: 0.35rem;
              `}>{label}</div>
              <div style="
                font-family: var(--font-mono);
                font-size: 0.65rem;
                color: var(--color-chalk-3);
                letter-spacing: 0.04em;
              ">{detail}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Built with Surface
  ────────────────────────────────────────────────────────── -->
  <section style="padding: 5rem var(--spacing-page); border-top: 1px solid var(--color-edge);">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
      ">
        <div>
          <div class="label-sm" style="margin-bottom: 1.5rem; color: var(--color-gold);">Built with Surface</div>
          <h2 class="display-md" style="color: var(--color-chalk); margin-bottom: 1.25rem;">
            One run, two views.
          </h2>
          <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.75; margin-bottom: 1.5rem;">
            Veritas users should not need to learn Surface vocabulary or configure
            Surface files. Veritas produces repo-native readiness reports, then
            projects the underlying trust state into Surface for portability,
            inspection, and downstream consoles.
          </p>
          <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.75; margin-bottom: 1.5rem;">
            That means the same run can guide an agent, inform a reviewer, and later
            be re-inspected by another system without turning Veritas into generic
            transparency tooling.
          </p>
          <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.75;">
            Public message: Built with Surface. Product experience: Veritas.
          </p>
          <div style="margin-top: 2rem;">
            <a href="/surface" class="btn-ghost" data-umami-event="veritas-surface-link">Explore Surface →</a>
          </div>
        </div>

        <div class="terminal">
          <div class="terminal-bar">
            <div class="terminal-dot"></div>
            <div class="terminal-dot"></div>
            <div class="terminal-dot"></div>
            <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--color-chalk-3); margin-left: 0.5rem;">trust snapshot ← veritas evidence</span>
          </div>
          <div class="terminal-body">
            <p><span class="prompt">$ </span><span class="cmd">node examples/surface-handoff.mjs</span></p>
            <br />
            <p class="info">  Kontour Surface trust snapshot surface-1778389390389</p>
            <p class="muted">  Source: veritas:readiness-run</p>
            <br />
            <p>  Requirements: <span class="pass">11</span> &nbsp;(satisfied: 8, advisory: 2, disputed: 1)</p>
            <p class="muted">  Coverage: evidence checks, requirement results, boundary crossings, freshness</p>
            <br />
            <p>  Merge readiness: <span class="pass">ready with advisory follow-up</span></p>
            <p>  Recheck available: <span class="pass">npm run verify</span></p>
            <p>  Freshness: <span class="pass">current for this diff</span></p>
            <p>  Surface projection: <span class="warn">portable trust state</span></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       CLI reference strip
  ────────────────────────────────────────────────────────── -->
  <section style="padding: 5rem var(--spacing-page);">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 2.5rem;">Current CLI</div>

      <div style="
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 0.75rem;
      ">
        {[
          { cmd: 'veritas init', desc: 'Bootstrap Repo Standards, Repo Map, and guidance' },
          { cmd: 'veritas readiness --working-tree', desc: 'Generate a readiness report for the current change' },
          { cmd: 'veritas explain --file <path>', desc: 'Show just-in-time guidance for a work area' },
          { cmd: 'veritas attest bootstrap', desc: 'Record authority evidence for protected standards' },
          { cmd: 'veritas eval summary', desc: 'Review standards feedback from prior runs' },
          { cmd: 'veritas recommendation list', desc: 'Review standards recommendations' },
          { cmd: 'veritas integrations claude-code install', desc: 'Wire agent hooks where supported' },
          { cmd: 'veritas apply stop-hook', desc: 'Send readiness feedback back to supported agents' },
        ].map(({ cmd, desc }) => (
          <div key={cmd} style="
            display: flex;
            flex-direction: column;
            gap: 0.35rem;
            padding: 1rem 1.25rem;
            background: var(--color-ink-1);
            border: 1px solid var(--color-edge);
            border-radius: 4px;
          ">
            <code style="
              font-family: var(--font-mono);
              font-size: 0.78rem;
              color: var(--color-green);
            ">{cmd}</code>
            <span style="
              font-size: 0.78rem;
              color: var(--color-chalk-3);
              line-height: 1.4;
            ">{desc}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer active="veritas" />
</Layout>

<style>
  @media (max-width: 900px) {
    section > div > div[style*="grid-template-columns: 1fr 1fr"] {
      display: flex !important;
      flex-direction: column !important;
    }
    section > div > div[style*="grid-template-columns: repeat(3, 1fr)"] {
      display: flex !important;
      flex-direction: column !important;
    }
  }
</style>
