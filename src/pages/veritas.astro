---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
---

<Layout
  title="Veritas — Bespoke lint for AI agents · Kontour AI"
  description="Repo-local governance that tells AI agents exactly what changed violated your rules before they finish work. Runs through tracked instructions, hooks, and CI."
>
  <Nav active="veritas" />

  <!-- ──────────────────────────────────────────────────────
       Hero
  ────────────────────────────────────────────────────────── -->
  <section class="contour-bg" style="
    padding: 10rem var(--spacing-page) 6rem;
    border-bottom: 1px solid var(--color-edge);
    position: relative;
    overflow: hidden;
  ">
    <!-- Green accent glow -->
    <div style="
      position: absolute;
      top: 0;
      right: 0;
      width: 600px;
      height: 400px;
      background: radial-gradient(ellipse at top right, rgba(82,196,126,0.05) 0%, transparent 70%);
      pointer-events: none;
    "></div>

    <div style="max-width: 1280px; margin: 0 auto; position: relative; z-index: 1;">
      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
        align-items: center;
      ">
        <!-- Left -->
        <div>
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 2rem;">
            <span class="trust-badge trust-badge--verified">v0.3.0</span>
            <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--color-chalk-3);">npm install -D @kontourai/veritas</span>
          </div>

          <h1 class="animate-fade-up" style="
            font-family: var(--font-display);
            font-optical-sizing: auto;
            font-size: clamp(3.5rem, 6vw, 5.5rem);
            font-weight: 400;
            line-height: 0.95;
            letter-spacing: -0.03em;
            color: var(--color-chalk);
            margin-bottom: 0.5rem;
          ">Veritas</h1>

          <p class="animate-fade-up delay-100" style="
            font-family: var(--font-mono);
            font-size: 0.75rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--color-green);
            margin-bottom: 2rem;
          ">Repo lint for AI agents · Built on Surface</p>

          <p class="animate-fade-up delay-200" style="
            font-size: 1.05rem;
            color: var(--color-chalk-2);
            line-height: 1.7;
            max-width: 460px;
            margin-bottom: 2.5rem;
          ">
            You define what your repo considers mandatory.
            Veritas runs your rules and tells any AI agent exactly which changes
            violated them — before it declares done.
          </p>

          <div class="animate-fade-up delay-300" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
            <a href="https://github.com/kontourai/veritas" target="_blank" rel="noopener" class="btn-primary" data-umami-event="veritas-hero-github">
              View on GitHub →
            </a>
            <a href="https://www.npmjs.com/package/@kontourai/veritas" target="_blank" rel="noopener" class="btn-ghost" data-umami-event="veritas-hero-npm">
              npm package
            </a>
          </div>
        </div>

        <!-- Right: run output -->
        <div class="animate-fade-in delay-300">
          <div class="terminal">
            <div class="terminal-bar">
              <div class="terminal-dot"></div>
              <div class="terminal-dot"></div>
              <div class="terminal-dot"></div>
              <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--color-chalk-3); margin-left: 0.5rem;">veritas run</span>
            </div>
            <div class="terminal-body">
              <p><span class="prompt">$ </span><span class="cmd">npx veritas run --working-tree</span></p>
              <br />
              <p class="info">  veritas 0.3.0 — run</p>
              <p class="muted">  adapter: .veritas/repo.adapter.json</p>
              <p class="muted">  policy:  .veritas/policy-packs/default.policy-pack.json</p>
              <br />
              <p class="pass">  PASS  proof-command: npm run verify</p>
              <p class="pass">  PASS  required-governance-artifacts</p>
              <p class="pass">  PASS  ai-instruction-files-synced</p>
              <p class="pass">  PASS  proof-family:repo-governance</p>
              <br />
              <p class="warn">  INFO  proof-family:runtime-contracts</p>
              <p style="color: var(--color-chalk-3); padding-left: 2rem; font-size: 0.72rem;">
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;→ move-to-test / advisory
              </p>
              <p style="color: var(--color-chalk-3); padding-left: 2rem; font-size: 0.72rem;">
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;→ evidence: connected-agent replacement tests
              </p>
              <br />
              <p style="color: var(--color-chalk-3);">  ───────────────────────────────</p>
              <p style="color: var(--color-chalk-2);">  0 failures &nbsp; 0 warnings</p>
              <p class="muted">  evidence → .veritas/evidence/&lt;run-id&gt;.json</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Three jobs
  ────────────────────────────────────────────────────────── -->
  <section style="padding: 6rem var(--spacing-page);">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 3rem;">Three jobs</div>

      <div style="
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
      ">
        {[
          {
            num: '01',
            title: 'Enforce boundaries',
            color: 'var(--color-green)',
            summary: 'Strict surface ownership',
            body: 'Required files, governance blocks, companion test requirements, cross-surface-write rules. Stops parallel workstreams from colliding before changes land.',
            tags: ['artifacts', 'governance-block', 'cross-surface-write', 'if-changed'],
          },
          {
            num: '02',
            title: 'Deliver JIT context',
            color: 'var(--color-cobalt-2)',
            summary: '`veritas explain` + PreToolUse hook',
            body: 'Long agent sessions drift toward high-level goals and forget repo-specific constraints. Veritas pushes the right rules into the agent\'s context at the moment of edit.',
            tags: ['explain', 'pre-tool-use', 'per-file', 'per-rule'],
          },
          {
            num: '03',
            title: 'Self-correct via lint',
            color: 'var(--color-gold)',
            summary: '`veritas run --working-tree` → PASS / FAIL',
            body: 'Terse lint-style output directly into the agent\'s context window. Exit codes 0/1/2 are hook-friendly. The agent reads it the way it reads a failing test.',
            tags: ['shadow-run', 'exit-codes', 'feedback-format', 'eval-history'],
          },
        ].map(({ num, title, color, summary, body, tags }) => (
          <div key={num} class="card" style="padding: 2rem;">
            <div style="
              font-family: var(--font-mono);
              font-size: 0.65rem;
              color: var(--color-chalk-3);
              margin-bottom: 1rem;
            ">{num}</div>

            <div style={`
              width: 28px;
              height: 2px;
              background: ${color};
              margin-bottom: 1.25rem;
              border-radius: 1px;
            `}></div>

            <h3 style="
              font-family: var(--font-display);
              font-size: 1.5rem;
              font-weight: 400;
              color: var(--color-chalk);
              margin-bottom: 0.35rem;
              letter-spacing: -0.01em;
            ">{title}</h3>

            <p style={`
              font-family: var(--font-mono);
              font-size: 0.7rem;
              color: ${color};
              margin-bottom: 1rem;
              letter-spacing: 0.03em;
            `}>{summary}</p>

            <p style="
              color: var(--color-chalk-2);
              font-size: 0.875rem;
              line-height: 1.7;
              margin-bottom: 1.5rem;
            ">{body}</p>

            <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
              {tags.map(tag => (
                <span key={tag} style="
                  font-family: var(--font-mono);
                  font-size: 0.58rem;
                  padding: 0.12rem 0.45rem;
                  border: 1px solid var(--color-edge-2);
                  border-radius: 2px;
                  color: var(--color-chalk-3);
                  letter-spacing: 0.06em;
                ">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Agent activation
  ────────────────────────────────────────────────────────── -->
  <section style="
    padding: 5rem var(--spacing-page);
    border-top: 1px solid var(--color-edge);
    border-bottom: 1px solid var(--color-edge);
    background: var(--color-ink-1);
  ">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
      ">
        <div>
          <div class="label-sm" style="margin-bottom: 1.5rem; color: var(--color-cobalt-2);">Agent activation</div>
          <h2 class="display-md" style="color: var(--color-chalk); margin-bottom: 1.25rem;">
            Works with any agent<br />
            that reads your repo.
          </h2>
          <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.75; margin-bottom: 1.5rem;">
            Veritas injects a governance block into every AI instruction file in your repo.
            Agents that read repo instructions — Claude Code, Cursor, Codex, Copilot — see
            the same rules and proof requirements through tracked files.
          </p>
          <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.75; margin-bottom: 1.5rem;">
            Stop-hook integration wires <code style="font-family: var(--font-mono); font-size: 0.85rem; color: var(--color-green); background: rgba(82,196,126,0.08); padding: 0.1rem 0.35rem; border-radius: 2px;">veritas run</code> to fire
            at session end for Claude Code, Cursor, and Codex. Copilot stays covered
            through instructions and CI.
          </p>
          <p style="color: var(--color-chalk-3); font-size: 0.82rem; line-height: 1.7; font-style: italic;">
            Codex and Claude Code can feed transcript-backed eval drafts; Cursor and
            Copilot use the generic governance-block + stop-hook contract.
          </p>
          <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.75; margin-bottom: 0;">
            Human attestations keep policy packs, adapters, and team profiles from being
            silently rewritten by agents. Eval history can draft proposals, but a human
            accept or reject decision closes the loop.
          </p>
        </div>

        <!-- Activation targets grid -->
        <div style="
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 1rem;
        ">
          {[
            { file: 'CLAUDE.md', agent: 'Claude Code', color: 'var(--color-gold)' },
            { file: 'AGENTS.md', agent: 'Codex', color: 'var(--color-cobalt-2)' },
            { file: '.cursorrules', agent: 'Cursor', color: 'var(--color-green)' },
            { file: 'copilot-instructions.md', agent: 'GitHub Copilot', color: 'var(--color-chalk-2)' },
          ].map(({ file, agent, color }) => (
            <div key={file} style="
              background: var(--color-ink-2);
              border: 1px solid var(--color-edge);
              border-radius: 6px;
              padding: 1.25rem;
            ">
              <div style={`
                font-family: var(--font-mono);
                font-size: 0.7rem;
                color: ${color};
                margin-bottom: 0.35rem;
              `}>{file}</div>
              <div style="
                font-family: var(--font-mono);
                font-size: 0.65rem;
                color: var(--color-chalk-3);
                letter-spacing: 0.04em;
              ">{agent}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Built on Surface
  ────────────────────────────────────────────────────────── -->
  <section style="padding: 5rem var(--spacing-page); border-top: 1px solid var(--color-edge);">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
      ">
        <div>
          <div class="label-sm" style="margin-bottom: 1.5rem; color: var(--color-gold);">Built on Surface</div>
          <h2 class="display-md" style="color: var(--color-chalk); margin-bottom: 1.25rem;">
            One run, two consumers.
          </h2>
          <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.75; margin-bottom: 1.5rem;">
            Each Veritas evidence artifact projects into <code style="font-family: var(--font-mono); font-size: 0.85rem; color: var(--color-gold); background: rgba(201,163,90,0.08); padding: 0.1rem 0.35rem; border-radius: 2px;">surface.input</code> —
            a portable shape Surface can turn into a trust report a human, a PR
            comment, or a downstream system can read. Policy packs become Surface
            collections, so the same run supports both agent feedback and
            control-level review. Integrity metadata anchors each verified claim
            to the source ref, changed files, and governance configuration that
            produced the evidence.
          </p>
          <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.75; margin-bottom: 1.5rem;">
            Run a <code style="font-family: var(--font-mono); font-size: 0.85rem; color: var(--color-green); background: rgba(82,196,126,0.08); padding: 0.1rem 0.35rem; border-radius: 2px;">veritas eval record</code> and the outcome, confidence, and
            reviewer notes are written directly into the run snapshot at <code style="font-family: var(--font-mono); font-size: 0.82rem; color: var(--color-chalk-3);">.surface/runs/</code>.
            The Surface dashboard picks it up without any extra steps.
          </p>
          <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.75;">
            You can use Veritas without Surface (the feedback loop is independent),
            and you can build on Surface without Veritas.
            Together, what the agent acted on becomes what the auditor reads.
          </p>
          <div style="margin-top: 2rem;">
            <a href="/surface" class="btn-ghost" data-umami-event="veritas-surface-link">Explore Surface →</a>
          </div>
        </div>

        <div class="terminal">
          <div class="terminal-bar">
            <div class="terminal-dot"></div>
            <div class="terminal-dot"></div>
            <div class="terminal-dot"></div>
            <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--color-chalk-3); margin-left: 0.5rem;">surface report ← veritas evidence</span>
          </div>
          <div class="terminal-body">
            <p><span class="prompt">$ </span><span class="cmd">node examples/surface-handoff.mjs</span></p>
            <br />
            <p class="info">  Kontour Surface report surface-1778389390389</p>
            <p class="muted">  Source: veritas:check-in-local</p>
            <br />
            <p>  Claims: <span class="pass">11</span> &nbsp;(proposed: 2, verified: 8, disputed: 1)</p>
            <p class="muted">  Surfaces: veritas.proof-lanes: 2, veritas.policy-results: 7,</p>
            <p class="muted">  &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; veritas.external-tool-results: 1, veritas.verification-budget: 1</p>
            <br />
            <p>  Collections: <span class="pass">1</span> &nbsp;(policy pack controls)</p>
            <p>  High-impact unsupported: <span class="warn">2</span></p>
            <p>  Disputed: <span class="warn">veritas.check-in-local.external-tool.fallow-fallow-advisory</span></p>
            <p>  Fault lines: <span class="warn">2</span></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       CLI reference strip
  ────────────────────────────────────────────────────────── -->
  <section style="padding: 5rem var(--spacing-page);">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 2.5rem;">CLI surface</div>

      <div style="
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 0.75rem;
      ">
        {[
          { cmd: 'veritas init', desc: 'Bootstrap adapter, policy pack, governance blocks' },
          { cmd: 'veritas run --working-tree', desc: 'Agent-facing lint path with feedback output' },
          { cmd: 'veritas report', desc: 'Evidence artifact with JSON or feedback output' },
          { cmd: 'veritas runtime status', desc: 'Check hook wiring and activation state' },
          { cmd: 'veritas eval draft', desc: 'Record agent evidence for a run' },
          { cmd: 'veritas eval record', desc: 'Accept or reject agent output manually' },
          { cmd: 'veritas eval summary', desc: 'Aggregate improvement metrics over time' },
          { cmd: 'veritas apply stop-hook', desc: 'Wire Claude Code / Cursor stop hooks' },
        ].map(({ cmd, desc }) => (
          <div key={cmd} style="
            display: flex;
            flex-direction: column;
            gap: 0.35rem;
            padding: 1rem 1.25rem;
            background: var(--color-ink-1);
            border: 1px solid var(--color-edge);
            border-radius: 4px;
          ">
            <code style="
              font-family: var(--font-mono);
              font-size: 0.78rem;
              color: var(--color-green);
            ">{cmd}</code>
            <span style="
              font-size: 0.78rem;
              color: var(--color-chalk-3);
              line-height: 1.4;
            ">{desc}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  @media (max-width: 900px) {
    section > div > div[style*="grid-template-columns: 1fr 1fr"] {
      display: flex !important;
      flex-direction: column !important;
    }
    section > div > div[style*="grid-template-columns: repeat(3, 1fr)"] {
      display: flex !important;
      flex-direction: column !important;
    }
  }
</style>
