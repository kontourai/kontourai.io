---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import Terminal from '@/components/Terminal.astro';
import Section from '@/components/Section.astro';
import Glow from '@/components/Glow.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Card from '@/components/Card.astro';
import Grid from '@/components/Grid.astro';
import Split from '@/components/Split.astro';
import { getProductStatus, productBadge } from '@/lib/product-status';
import type { Accent } from '@/lib/theme';

const veritasStatus = getProductStatus('veritas');

const boundaries: { label: string; detail: string; accent: Accent }[] = [
  { label: 'Work Area', detail: 'Where the change belongs', accent: 'gold' },
  { label: 'Change Boundary', detail: 'Where extra coordination begins', accent: 'cobalt-2' },
  { label: 'Protected Area', detail: 'Where stronger authority is required', accent: 'green' },
  { label: 'Boundary Crossing', detail: 'When readiness needs more evidence', accent: 'chalk-2' },
];

const promises: { num: string; title: string; accent: Accent; summary: string; body: string; tags: string[] }[] = [
  { num: '01', title: 'Define what good looks like', accent: 'green', summary: 'Repo Standards', body: 'Capture the repo expectations reviewers keep in their heads: required tests, protected files, shared contracts, release checks, security scans, boundaries, and authority rules.', tags: ['requirements', 'evidence-checks', 'authorities', 'guidance'] },
  { num: '02', title: 'Guide work at the moment of change', accent: 'cobalt-2', summary: 'Change Guidance', body: 'When an agent or developer touches a risky work area, Veritas supplies the relevant standards before context drift turns into a bad merge.', tags: ['work-areas', 'boundaries', 'hooks', 'recheck'] },
  { num: '03', title: 'Earn merge readiness', accent: 'gold', summary: 'Readiness Reports', body: 'Every change gets a clear answer: what passed, what failed, what evidence is stale, what needs recheck, and why this change can or cannot merge with reduced human review.', tags: ['merge-readiness', 'freshness', 'exceptions', 'coverage'] },
];

const beyond: { title: string; body: string; accent: Accent }[] = [
  { title: 'Standards feedback', accent: 'green', body: 'Longitudinal tracking of whether each standard helped, got in the way, or needs adjustment — built from real run evidence.' },
  { title: 'Recommendations', accent: 'cobalt-2', body: 'Data-driven suggestions for tightening, relaxing, or retiring standards, accepted or rejected with authority backing.' },
  { title: 'Marker benchmarking', accent: 'gold', body: 'Deterministic scoring of whether Veritas guidance actually improves agent outcomes, not just whether checks pass.' },
  { title: 'Claim authoring', accent: 'chalk-2', body: 'Author and manage Surface claims directly from the repo, so readiness state is portable to people, agents, and other systems.' },
];

const cli = [
  { cmd: 'veritas init', desc: 'Bootstrap Repo Standards, Repo Map, and guidance' },
  { cmd: 'veritas readiness --working-tree', desc: 'Generate a readiness report for the current change' },
  { cmd: 'veritas explain --file <path>', desc: 'Show just-in-time guidance for a work area' },
  { cmd: 'veritas attest bootstrap', desc: 'Record authority evidence for protected standards' },
  { cmd: 'veritas claim list', desc: 'Author and inspect Surface claims for the repo' },
  { cmd: 'veritas feedback summary', desc: 'Review whether standards are helping across prior runs' },
  { cmd: 'veritas recommendation list', desc: 'Review data-driven standards recommendations' },
  { cmd: 'veritas integrations claude-code install', desc: 'Wire agent hooks where supported' },
];
---

<Layout
  title="Veritas — Inspectable code readiness for AI-authored changes · Kontour AI"
  description="Veritas makes code and change readiness inspectable by turning repo standards into evidence-backed guidance and readiness reports."
>
  <Nav active="veritas" />

  <!-- Hero -->
  <Section contour size="hero" borderBottom>
    <Glow accent="green" position="top-right" />
    <div class="container">
      <Split ratio="1-1" gap="lg" align="center">
        <div>
          <div class="hero-badges">
            <span class="trust-badge trust-badge--verified">{productBadge(veritasStatus)}</span>
            <span class="install-hint">npm install -D @kontourai/veritas</span>
          </div>

          <h1 class="product-title animate-fade-up">Veritas</h1>
          <p class="product-tagline animate-fade-up delay-100" data-accent="green">code and change readiness made inspectable</p>

          <p class="hero-copy animate-fade-up delay-200">
            Define what good looks like for your repo. Veritas checks each
            change against those standards, gives the agent just-in-time
            guidance while it works, and produces a readiness report that says
            what passed, what failed, what evidence is stale, and whether the
            change has enough fresh evidence to merge with reduced human review.
            It is not a code-review bot; the repo owns the standards and people
            keep authority over merge risk.
          </p>

          <div class="hero-actions animate-fade-up delay-300">
            <a href="https://github.com/kontourai/veritas" target="_blank" rel="noopener" class="btn-primary" data-umami-event="veritas-hero-github">View on GitHub →</a>
            <a href="https://www.npmjs.com/package/@kontourai/veritas" target="_blank" rel="noopener" class="btn-ghost" data-umami-event="veritas-hero-npm">npm package</a>
          </div>
        </div>

        <Terminal class="animate-fade-in delay-300" title="veritas readiness">
          <p><span class="prompt">$ </span><span class="cmd">npx veritas readiness --working-tree</span></p>
          <br />
          <p class="info">  veritas {veritasStatus.version} — readiness</p>
          <p class="muted">  repo map:      loaded</p>
          <p class="muted">  repo standards: loaded</p>
          <br />
          <p class="pass">  PASS  evidence-check: npm run verify</p>
          <p class="pass">  PASS  repo-standards-present</p>
          <p class="pass">  PASS  ai-instruction-files-synced</p>
          <p class="pass">  PASS  merge-readiness: ready</p>
          <br />
          <p class="warn">  INFO  evidence-freshness: current</p>
          <p class="sub">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;→ checked against this diff and standards version</p>
          <p class="sub">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;→ boundary crossing: none</p>
          <br />
          <p class="rule">  ───────────────────────────────</p>
          <p class="cmd">  0 failures &nbsp; 0 warnings</p>
          <p class="muted">  evidence → .veritas/evidence/&lt;run-id&gt;.json</p>
        </Terminal>
      </Split>
    </div>
  </Section>

  <!-- Change boundaries -->
  <Section tone="alt" borderTop borderBottom>
    <div class="container">
      <Split ratio="1-1" gap="md" align="center">
        <div>
          <Eyebrow accent="cobalt-2">Change boundaries</Eyebrow>
          <h2 class="display-md cb__title">Shared code without<br />shared confusion.</h2>
          <p class="body cb__copy">
            Fast AI development breaks down when several agents and developers touch
            the same repo without knowing which work areas are independent, protected,
            or coupled. Veritas makes those boundaries explicit.
          </p>
          <p class="body cb__copy">
            A change that stays inside its work area can move quickly. A boundary crossing
            asks for the right evidence, owner context, or coordination before it becomes
            another surprise in review.
          </p>
          <p class="body cb__copy cb__copy--last">
            This is how teams keep code DRY without turning every shared package,
            contract, or generated artifact into a manual-review bottleneck.
          </p>
        </div>

        <Grid cols={2} gap="md">
          {boundaries.map(({ label, detail, accent }) => (
            <div class="minicard" data-accent={accent}>
              <div class="minicard__label">{label}</div>
              <div class="minicard__detail">{detail}</div>
            </div>
          ))}
        </Grid>
      </Split>
    </div>
  </Section>

  <!-- Product promise -->
  <Section size="lg">
    <div class="container">
      <Eyebrow gap="lg">What Veritas makes possible</Eyebrow>
      <Grid cols={3} gap="lg">
        {promises.map(({ num, title, accent, summary, body, tags }) => (
          <Card pad="lg" accent={accent}>
            <div class="promise__num">{num}</div>
            <div class="promise__rule"></div>
            <h3 class="promise__title">{title}</h3>
            <p class="promise__summary">{summary}</p>
            <p class="promise__body">{body}</p>
            <div class="promise__tags">
              {tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          </Card>
        ))}
      </Grid>
    </div>
  </Section>

  <!-- Example use case -->
  <Section tone="alt" borderTop>
    <div class="container">
      <Split ratio="1-1" gap="md" align="center">
        <div>
          <Eyebrow accent="green">Example use case</Eyebrow>
          <h2 class="display-md ip__title">The catch you'd<br />otherwise miss.</h2>
          <p class="body ip__copy">
            An agent rewrites an API handler but skips the test that covers it.
            Instead of surfacing days later in review, Veritas flags the missing
            evidence at the moment of change — and tells the agent exactly what
            it needs before the work is submitted.
          </p>
          <p class="body ip__copy ip__copy--last">
            Reviewers spend their attention inspecting evidence, not
            rediscovering the standard from a diff.
          </p>
        </div>

        <Terminal title="veritas readiness — blocked">
          <p><span class="prompt">$ </span><span class="cmd">npx veritas readiness --working-tree</span></p>
          <br />
          <p class="info">  veritas {veritasStatus.version} — readiness</p>
          <p class="muted">  repo standards: loaded</p>
          <br />
          <p class="pass">  PASS  change-boundaries: within work area</p>
          <p class="warn">  BLOCK evidence-check: api handler changed, test missing</p>
          <p class="sub">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;→ expected: test covering src/api/handler.ts</p>
          <br />
          <p>  merge-readiness: <span class="warn">blocked — 1 requirement unmet</span></p>
          <p class="muted">  next action: add the missing test, then re-run</p>
        </Terminal>
      </Split>
    </div>
  </Section>

  <!-- Standards that learn -->
  <Section borderTop size="lg">
    <div class="container">
      <Eyebrow accent="green">Beyond the gate</Eyebrow>
      <h2 class="display-md measure-lg beyond-heading">Standards that get sharper the more you ship.</h2>
      <p class="fine measure beyond-note">
        A readiness verdict is the start. Veritas also tracks whether your
        standards are actually helping, recommends adjustments from real run
        history, and projects every claim into Surface so the evidence is
        inspectable downstream.
      </p>

      <Grid cols={4} gap="md">
        {beyond.map(({ title, body, accent }) => (
          <Card accent={accent} bar="top" pad="sm">
            <h3 class="beyond__title">{title}</h3>
            <p class="beyond__body">{body}</p>
          </Card>
        ))}
      </Grid>
    </div>
  </Section>

  <!-- CLI reference strip -->
  <Section borderTop>
    <div class="container">
      <Eyebrow gap="lg">Current CLI</Eyebrow>
      <Grid min="280" gap="sm">
        {cli.map(({ cmd, desc }) => (
          <div class="cli">
            <code class="cli__cmd">{cmd}</code>
            <span class="cli__desc">{desc}</span>
          </div>
        ))}
      </Grid>
    </div>
  </Section>

  <Section size="note" borderTop>
    <div class="container">
      <p class="closing-note">Veritas is built with Surface. Users don't need to configure Surface — it's the shared shape under the readiness state.</p>
    </div>
  </Section>

  <Footer active="veritas" />
</Layout>

<style>
  .cb__title,
  .ip__title {
    margin-bottom: 1.25rem;
  }
  .cb__copy,
  .ip__copy {
    margin-bottom: 1.5rem;
  }
  .cb__copy--last,
  .ip__copy--last {
    margin-bottom: 0;
  }

  .promise__num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-chalk-3);
    margin-bottom: 1rem;
  }
  .promise__rule {
    width: 28px;
    height: 2px;
    background: var(--accent);
    margin-bottom: 1.25rem;
    border-radius: 1px;
  }
  .promise__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-chalk);
    margin-bottom: 0.35rem;
    letter-spacing: 0;
  }
  .promise__summary {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent);
    margin-bottom: 1rem;
    letter-spacing: 0;
  }
  .promise__body {
    color: var(--color-chalk-2);
    font-size: 0.875rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  .promise__tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    padding: 0.12rem 0.45rem;
    border: 1px solid var(--color-edge-2);
    border-radius: 2px;
    color: var(--color-chalk-3);
    letter-spacing: 0;
  }

  .beyond-heading {
    margin-bottom: 1rem;
  }
  .beyond-note {
    margin-bottom: 2.5rem;
  }
  .beyond__title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--color-chalk);
    margin-bottom: 0.6rem;
    letter-spacing: 0;
  }
  .beyond__body {
    font-size: 0.8rem;
    color: var(--color-chalk-3);
    line-height: 1.6;
  }

  .cli {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.25rem;
    background: var(--color-ink-1);
    border: 1px solid var(--color-edge);
    border-radius: 4px;
  }
  .cli__cmd {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-green);
  }
  .cli__desc {
    font-size: 0.78rem;
    color: var(--color-chalk-3);
    line-height: 1.4;
  }

  .closing-note {
    color: var(--color-chalk-3);
    font-size: 0.95rem;
    line-height: 1.7;
    font-style: italic;
    margin: 0;
  }
</style>
