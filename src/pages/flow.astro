---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import Terminal from '@/components/Terminal.astro';
import Section from '@/components/Section.astro';
import Glow from '@/components/Glow.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Card from '@/components/Card.astro';
import Grid from '@/components/Grid.astro';
import Split from '@/components/Split.astro';
import QuestionGrid from '@/components/QuestionGrid.astro';
import { getProductStatus, productBadge } from '@/lib/product-status';
import type { Accent } from '@/lib/theme';

const flowStatus = getProductStatus('flow');

const answers: { q: string; accent?: Accent }[] = [
  { q: 'What process path was required?' },
  { q: 'Which step is active now?' },
  { q: 'Which gate controls the next transition?', accent: 'cobalt-2' },
  { q: 'What evidence does the gate expect?', accent: 'cobalt-2' },
  { q: 'What evidence was actually collected?', accent: 'green' },
  { q: 'Why was the transition allowed or blocked?', accent: 'gold' },
  { q: 'Was an exception accepted, and by whom?', accent: 'red' },
  { q: 'How should another agent resume?' },
];

const objects: { label: string; detail: string; accent: Accent }[] = [
  { label: 'Flow Definition', detail: 'The required path and gate expectations', accent: 'cobalt-2' },
  { label: 'Flow Run', detail: 'One concrete execution with state and history', accent: 'green' },
  { label: 'Gate Evidence', detail: 'Tests, CI, traces, approvals, Veritas reports', accent: 'gold' },
  { label: 'Flow Report', detail: 'Current state, blocked gates, next action', accent: 'chalk-2' },
];

const notReplace: { title: string; body: string; accent: Accent }[] = [
  { title: 'Workflow engines', body: 'Camunda, Temporal, Dapr, Inngest, and Trigger.dev can still run durable work. Flow records gate state and evidence.', accent: 'gold' },
  { title: 'Agent frameworks', body: 'LangGraph, CrewAI, OpenAI Agents, Microsoft Agent Framework, and runtime SDKs can still execute agent loops.', accent: 'cobalt-2' },
  { title: 'Observability', body: 'Phoenix, LangSmith, AgentOps, and OpenTelemetry can still store traces. Flow interprets traces against gate expectations.', accent: 'green' },
  { title: 'Policy systems', body: 'OPA, security tools, and Veritas can still evaluate rules. Flow records their decisions as process evidence.', accent: 'red' },
];

const consoleFeatures = [
  { label: 'Process graph', body: 'See the required path and where the run sits on it right now.' },
  { label: 'Transition timeline', body: 'Walk every gate the run cleared, blocked on, or routed back from.' },
  { label: 'Gate detail', body: 'Inspect the evidence a gate expected and what was actually collected.' },
  { label: 'Evidence links', body: 'Jump from a gate to the tests, CI, traces, or readiness reports behind it.' },
];
---

<Layout
  title="Flow — Inspectable required paths for AI-assisted work · Kontour AI"
  description="Kontour Flow makes required process paths inspectable by recording gates, evidence, transitions, exceptions, and resumable state."
>
  <Nav active="flow" />

  <!-- Hero -->
  <Section contour size="hero" borderBottom>
    <Glow accent="cobalt-2" position="top-right" />
    <div class="container">
      <Split ratio="1-1" gap="lg" align="center">
        <div>
          <div class="hero-badges">
            <span class="trust-badge trust-badge--verified">{productBadge(flowStatus)}</span>
            <span class="install-hint">npm install -D @kontourai/flow</span>
          </div>

          <h1 class="product-title animate-fade-up">Flow</h1>
          <p class="product-tagline animate-fade-up delay-100" data-accent="cobalt-2">required paths, gates, evidence, and exceptions made inspectable</p>

          <p class="hero-copy hero-copy--wide animate-fade-up delay-200">
            Agents skip steps, accept weak evidence, summarize work as complete,
            and lose the thread after compaction. Flow is the small thing
            missing in the middle: a record of the required path, the evidence
            each gate expected, the evidence that was actually collected, and
            the exceptions that need explicit human trust. It does not replace
            workflow engines, agent runtimes, observability tools, approval
            apps, or policy engines. It explains why the work was allowed to
            advance.
          </p>

          <div class="hero-actions animate-fade-up delay-300">
            <a href="https://kontourai.github.io/flow/" target="_blank" rel="noopener" class="btn-primary" data-umami-event="flow-hero-docs">Read the docs →</a>
            <a href="https://github.com/kontourai/flow" target="_blank" rel="noopener" class="btn-ghost" data-umami-event="flow-hero-github">GitHub</a>
            <a href="/surface" class="btn-ghost" data-umami-event="flow-hero-surface">Built with Surface</a>
          </div>
        </div>

        <Terminal class="animate-fade-in delay-300" title="flow report — current run">
          <p><span class="prompt">$ </span><span class="cmd">flow status run.dev-1847 --format summary</span></p>
          <br />
          <p class="info">  flow run: agent-dev-flow / feature-search-filters</p>
          <p class="muted">  current step: verify</p>
          <br />
          <p class="pass">  PASS  plan gate: acceptance criteria linked</p>
          <p class="pass">  PASS  implementation gate: scoped files changed</p>
          <p class="warn">  BLOCK verify gate: browser evidence missing</p>
          <p class="muted">        expected: tests, lint, screenshot, Veritas readiness</p>
          <br />
          <p>  next action: <span class="warn">run browser check before publish</span></p>
          <p class="muted">  continuation: resume from verify, not chat memory</p>
          <p class="muted">  report: .flow/runs/run.dev-1847/report.md</p>
        </Terminal>
      </Split>
    </div>
  </Section>

  <!-- Quickstart -->
  <Section tone="alt" borderBottom>
    <div class="container">
      <Eyebrow accent="cobalt-2">Quickstart</Eyebrow>
      <Terminal title="flow quickstart">
        <p><span class="prompt">$ </span><span class="cmd">npm install -D @kontourai/flow</span></p>
        <p><span class="prompt">$ </span><span class="cmd">npx flow init --demo</span></p>
        <p><span class="prompt">$ </span><span class="cmd">npx flow status demo</span></p>
        <p><span class="prompt">$ </span><span class="cmd">npx flow evaluate demo --exit-code</span></p>
        <p><span class="prompt">$ </span><span class="cmd">npx flow resume demo</span></p>
      </Terminal>
    </div>
  </Section>

  <!-- See it -->
  <Section borderBottom>
    <div class="container">
      <Eyebrow accent="cobalt-2" gap="sm">See it</Eyebrow>
      <figure class="product-shot">
        <img src="/screenshots/flow-demo.gif" alt="Terminal recording: flow init --demo, status, a blocked evaluate --exit-code, and resume" loading="lazy" />
        <figcaption>Four commands, one gate an agent can't talk past: scaffold a demo run, check status, watch <code>flow evaluate --exit-code</code> refuse without evidence, resume from recorded state. <a href="https://kontourai.github.io/flow/" target="_blank" rel="noopener">Full walkthrough in the docs →</a></figcaption>
      </figure>
    </div>
  </Section>

  <!-- What Flow answers -->
  <Section size="lg">
    <div class="container">
      <Eyebrow gap="lg">What Flow answers</Eyebrow>
      <QuestionGrid items={answers} min="280" />
    </div>
  </Section>

  <!-- Example use case -->
  <Section borderTop>
    <div class="container">
      <Split ratio="1-1" gap="md" align="center">
        <div>
          <Eyebrow accent="cobalt-2">Example use case</Eyebrow>
          <h2 class="display-md diff__title">A release path that waits for evidence.</h2>
          <p class="body diff__copy">
            A team asks an agent to ship a pricing-page change. Flow records the
            required path: plan, implementation, code review, rendered-page
            verification, release readiness, and post-deploy smoke. The work can
            only advance when each gate has the evidence it asked for.
          </p>
          <p class="body diff__copy diff__copy--last">
            If the browser check is missing, the run does not become "done." It
            stays blocked with a resumable next action.
          </p>
        </div>

        <Terminal title="release-readiness-flow">
          <p class="pass">  PASS  plan: acceptance criteria present</p>
          <p class="pass">  PASS  implementation: scoped diff</p>
          <p class="pass">  PASS  review: no high findings</p>
          <p class="warn">  BLOCK verify: rendered-page screenshot missing</p>
          <p class="muted">        expected: desktop + mobile evidence</p>
          <br />
          <p>  next action: <span class="warn">capture browser evidence, then resume</span></p>
        </Terminal>
      </Split>
    </div>
  </Section>

  <!-- The difference -->
  <Section tone="alt" borderTop borderBottom>
    <div class="container">
      <Split ratio="1-1" gap="md" align="center">
        <div>
          <Eyebrow accent="cobalt-2">The difference</Eyebrow>
          <h2 class="display-md diff__title">A trace says what happened.<br />Flow says why it was enough.</h2>
          <p class="body diff__copy">
            Observability is necessary, but a trace alone does not know whether
            the right verification happened, whether approval had enough context,
            or whether the agent skipped a required handoff.
          </p>
          <p class="body diff__copy diff__copy--last">
            Flow turns required paths into evidence-gated transitions. If the
            evidence is missing, the run blocks or routes back. If the user accepts
            the gap, the exception becomes part of the record.
          </p>
        </div>

        <Grid cols={2} gap="md">
          {objects.map(({ label, detail, accent }) => (
            <div class="minicard" data-accent={accent}>
              <div class="minicard__label">{label}</div>
              <div class="minicard__detail">{detail}</div>
            </div>
          ))}
        </Grid>
      </Split>
    </div>
  </Section>

  <!-- What Flow does not replace -->
  <Section borderTop>
    <div class="container">
      <Eyebrow gap="lg">What Flow does not replace</Eyebrow>
      <Grid cols={4} gap="md">
        {notReplace.map(({ title, body, accent }) => (
          <Card accent={accent} bar="top" pad="sm">
            <h3 class="feature-title">{title}</h3>
            <p class="feature-body">{body}</p>
          </Card>
        ))}
      </Grid>
    </div>
  </Section>

  <!-- Flow Console -->
  <Section borderTop>
    <div class="container">
      <Split ratio="1-1" gap="md" align="start">
        <div>
          <Eyebrow accent="cobalt-2">Flow Console</Eyebrow>
          <h2 class="display-md fc__title">See the run<br />where the work happens.</h2>
          <p class="body fc__copy">
            <code class="codechip" data-accent="cobalt-2">flow console --run &lt;id&gt;</code>
            serves a live view of a run straight from
            <code class="code-plain">.flow/runs/&lt;id&gt;/</code>.
            Loopback only. No cloud, no login.
          </p>

          <div class="fc-list">
            {consoleFeatures.map(({ label, body }) => (
              <div class="kv fc-row">
                <div class="fc-row__key">{label}</div>
                <div class="kv__val">{body}</div>
              </div>
            ))}
          </div>
        </div>

        <Terminal title="flow console">
          <p><span class="prompt">$ </span><span class="cmd">npx flow console --run dev-1847</span></p>
          <br />
          <p class="info">  Flow Console running at http://127.0.0.1:4317</p>
          <br />
          <p class="muted">  Reading: .flow/runs/dev-1847/</p>
          <p class="muted">  run: agent-dev-flow / feature-search-filters</p>
          <br />
          <p class="muted">  GET /              200  console shell</p>
          <p class="muted">  GET /api/run         200  run graph + timeline</p>
          <p class="muted">  GET /api/gates       200  gate detail + evidence</p>
          <br />
          <p class="rule">  ───────────────────────────────</p>
          <p class="pass">  PASS  plan · implementation</p>
          <p class="warn">  BLOCK verify · browser evidence missing</p>
          <p class="muted">  loopback only · no hosted service</p>
        </Terminal>
      </Split>
    </div>
  </Section>

  <!-- Product line -->
  <Section tone="alt" borderTop>
    <div class="container">
      <Split ratio="1-1.2" gap="md" align="center">
        <div>
          <Eyebrow accent="gold">Product line</Eyebrow>
          <h2 class="display-md line__title">One transparency stack.<br />Independent products.</h2>
          <p class="body line__copy">
            Surface makes claims inspectable. Survey makes producer-side
            provenance inspectable. Flow makes process transitions inspectable.
            Flow Agents applies Flow and Veritas discipline inside Codex,
            Claude Code, Kiro, GitHub Actions, and future agent tools.
          </p>
          <p class="body line__copy line__copy--last">
            You get a workflow that simply works. Underneath, each Kontour
            product adds one focused layer of the trust stack.
          </p>
        </div>

        <Terminal title="kontour stack">
          <p><span class="info">Surface</span>  claims, evidence, policies, trust snapshots</p>
          <p><span class="info">Survey</span>   producer-side source → review → claim, projected into Surface</p>
          <p><span class="info">Flow</span>     steps, gates, transitions, exceptions, reports</p>
          <p><span class="info">Veritas</span>  repo standards, evidence checks, merge readiness</p>
          <p><span class="info">Flow Agents</span>  runtime-native workflows + work modes</p>
          <br />
          <p class="muted">  shared promise: Kontour AI shows the work behind AI.</p>
        </Terminal>
      </Split>
    </div>
  </Section>

  <Footer active="flow" />
</Layout>

<style>
  .hero-copy--wide {
    max-width: 500px;
  }

  .diff__title,
  .fc__title,
  .line__title {
    margin-bottom: 1.25rem;
  }
  .diff__copy,
  .line__copy {
    margin-bottom: 1.5rem;
  }
  .diff__copy--last,
  .line__copy--last {
    margin-bottom: 0;
  }

  .fc__copy {
    margin-bottom: 1.5rem;
  }
  .fc-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .fc-row__key {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-cobalt-2);
    min-width: 130px;
    padding-top: 1px;
  }
</style>
