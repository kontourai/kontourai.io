---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import Terminal from '@/components/Terminal.astro';
import Section from '@/components/Section.astro';
import Glow from '@/components/Glow.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Card from '@/components/Card.astro';
import Grid from '@/components/Grid.astro';
import Split from '@/components/Split.astro';
import { getProductStatus, productBadge } from '@/lib/product-status';
import type { Accent } from '@/lib/theme';

const flowAgentsStatus = getProductStatus('flow-agents');

const steps = ['Idea', 'Backlog', 'Plan', 'Build', 'Review', 'Verify', 'Evidence', 'Release', 'Learn'];

const promises: { title: string; body: string; accent: Accent }[] = [
  { title: 'Stay on the path', accent: 'cobalt-2', body: 'Loose requests turn into shaped work, plans, implementation waves, review, verification, and release decisions — without writing a perfect prompt every time.' },
  { title: 'Show the evidence', accent: 'green', body: 'Acceptance criteria, test results, browser checks, governance reports, and gaps live in durable workflow artifacts the agent reads back — not in chat memory.' },
  { title: 'Use your agent tool', accent: 'chalk-2', body: 'Install one bundle across Claude Code, Codex, Kiro, and CI. The same workflow, without rewriting it for each tool.' },
];

const runtimes = [
  { rt: 'Claude Code', detail: 'Agents, skills, and hooks wired into the Claude Code harness.' },
  { rt: 'Codex', detail: 'The same workflow path mapped to Codex agent definitions.' },
  { rt: 'Kiro', detail: 'Runtime-specific hook wiring for Kiro sessions.' },
  { rt: 'GitHub Actions', detail: 'Carry the workflow and its evidence into CI agents.' },
];

const skills = [
  { skill: 'idea-to-backlog', desc: 'Shape a raw idea into executable issues' },
  { skill: 'pull-work', desc: 'Select the next ready issue and hand it off' },
  { skill: 'plan-work', desc: 'Turn a goal into a structured execution plan' },
  { skill: 'execute-plan', desc: 'Run implementation in parallel waves' },
  { skill: 'review-work', desc: 'Critique before verification' },
  { skill: 'verify-work', desc: 'Prove the change actually works' },
  { skill: 'evidence-gate', desc: 'Decide if the work is trustworthy' },
  { skill: 'release-readiness', desc: 'Merge, release, or hold — with reasons' },
  { skill: 'deliver', desc: 'The full chain, end to end' },
  { skill: 'fix-bug', desc: 'Diagnose → fix → verify the regression' },
];

const honest: { title: string; body: string; accent: Accent }[] = [
  { title: 'Durable artifacts', accent: 'green', body: 'Workflow state, acceptance, evidence, critique, release, and learning records persist as inspectable sidecars under .flow-agents/ — so a session can be resumed, audited, or handed off.' },
  { title: 'Optional governance', accent: 'cobalt-2', body: 'Wire Veritas readiness reports in as a governance adapter to back merge decisions with repo-standard evidence. Optional, never mandatory — Flow Agents does not own the policy.' },
  { title: 'Deliberate execution', accent: 'gold', body: 'Choose local, worktree, container, cloud, or privileged execution boundaries on purpose. Evals — static, integration, behavioral — keep the bundle honest as it changes.' },
];
---

<Layout
  title="Flow Agents — Flow and Veritas discipline inside coding agents · Kontour AI"
  description="Flow Agents applies Flow-backed workflows and optional Veritas governance inside Claude Code, Codex, Kiro, and GitHub Actions without becoming an agent runtime."
>
  <Nav active="flow-agents" />

  <!-- Hero -->
  <Section contour size="hero" borderBottom>
    <Glow accent="chalk-2" position="top-right" />
    <div class="container">
      <Split ratio="1-1" gap="lg" align="center">
        <div>
          <div class="hero-badges">
            <span class="trust-badge trust-badge--verified">{productBadge(flowAgentsStatus)}</span>
            <span class="install-hint">npx @kontourai/flow-agents init</span>
          </div>

          <h1 class="product-title animate-fade-up">Flow Agents</h1>
          <p class="product-tagline animate-fade-up delay-100" data-accent="chalk-2">Flow and Veritas discipline inside the agents you already use</p>

          <p class="hero-copy hero-copy--wide animate-fade-up delay-200">
            Agents are useful out of the box. They get fragile when work is
            long, parallel, risky, or knowledge-heavy — they skip verification,
            call partial work done, and lose the thread after compaction. Flow
            Agents installs one structured path into the agent tool you already use,
            so a loose request becomes shaped work, plans, review, verification,
            and a release decision — with evidence the agent and the developer
            can both read back. It does not replace the runtime or framework; it
            gives the work a required path and inspectable evidence.
          </p>

          <div class="hero-actions animate-fade-up delay-300">
            <a href="https://kontourai.github.io/flow-agents/" target="_blank" rel="noopener" class="btn-primary" data-umami-event="flow-agents-hero-docs">Read the docs →</a>
            <a href="https://github.com/kontourai/flow-agents" target="_blank" rel="noopener" class="btn-ghost" data-umami-event="flow-agents-hero-github">GitHub</a>
            <a href="/flow" class="btn-ghost" data-umami-event="flow-agents-hero-flow">Built on Flow</a>
          </div>
        </div>

        <Terminal class="animate-fade-in delay-300" title="install Flow Agents">
          <p><span class="prompt">$ </span><span class="cmd">npx @kontourai/flow-agents init --dest ~/dev/my-project</span></p>
          <p class="muted">  # or, from a checkout: bash install.sh ~/dev/my-project</p>
          <br />
          <p class="muted">  installing Flow Agents bundle…</p>
          <p class="pass">  ✓ agents      Claude Code, Codex, Kiro, CI</p>
          <p class="pass">  ✓ skills      idea-to-backlog … learning-review</p>
          <p class="pass">  ✓ kits        Builder Kit</p>
          <p class="pass">  ✓ context     contracts, settings, hooks</p>
          <p class="pass">  ✓ evals       static · integration · behavioral</p>
          <br />
          <p class="muted">  workflow artifacts → .flow-agents/</p>
          <p class="rule">  ───────────────────────────────</p>
          <p class="info">  ready. ask your agent:</p>
          <p>  <span class="muted">"Use deliver for this issue."</span></p>
        </Terminal>
      </Split>
    </div>
  </Section>

  <!-- The workflow -->
  <Section size="lg">
    <div class="container">
      <Eyebrow gap="sm">One structured path</Eyebrow>
      <h2 class="display-md measure-lg path-title">
        From a loose request to a release decision — gate by gate.
      </h2>
      <p class="fine measure path-note">
        Skills choose the right workflow, sidecars preserve state across
        compaction, gates catch stop-short behavior, and a finding or gap routes
        the work back instead of waving it through.
      </p>

      <Grid cols={9} gap="xs">
        {steps.map((step, i) => (
          <div class="fstep">
            <span class="fstep__n">0{i + 1}</span>
            <span class="fstep__name">{step}</span>
          </div>
        ))}
      </Grid>

      <p class="path-routes">
        review → finding routes back to build · verify → gap routes back to build · evidence → not-verified routes back to plan
      </p>
    </div>
  </Section>

  <!-- Three promises -->
  <Section tone="alt" borderTop borderBottom>
    <div class="container">
      <Grid cols={3} gap="lg">
        {promises.map(({ title, body, accent }) => (
          <Card accent={accent} bar="top" pad="lg">
            <h3 class="promo__title">{title}</h3>
            <p class="promo__body">{body}</p>
          </Card>
        ))}
      </Grid>
    </div>
  </Section>

  <!-- Runtimes -->
  <Section size="lg">
    <div class="container">
      <Eyebrow gap="sm">Runs in the tools you already use</Eyebrow>
      <h2 class="display-md measure-lg runtimes-title">One bundle. Every tool maps to its native shape.</h2>

      <Grid min="260" gap="md">
        {runtimes.map(({ rt, detail }) => (
          <div class="rt">
            <div class="rt__name">{rt}</div>
            <p class="rt__detail">{detail}</p>
          </div>
        ))}
      </Grid>

      <p class="rt-note">
        Tool adapters translate one source configuration into each tool's
        native shape — so adding a tool doesn't fork the workflow. Framework
        adapters for API-based agents (LangGraph, CrewAI, and peers) are on the
        roadmap.
      </p>
    </div>
  </Section>

  <!-- Builder Kit -->
  <Section tone="alt" borderTop>
    <div class="container">
      <Split ratio="1-1" gap="md" align="start">
        <div>
          <Eyebrow accent="chalk-2">Builder Kit</Eyebrow>
          <h2 class="display-md bk__title">Opinionated building,<br />installed as a kit.</h2>
          <p class="body bk__copy">
            The Builder Kit is the first Kontour-authored Flow Kit. It owns the
            Build path end to end — shaping, probing, planning, execution,
            verification, PR readiness, merge readiness, and learning — as
            workflows your agent invokes by name.
          </p>
          <p class="body bk__copy bk__copy--last">
            Flow Kits are tool-neutral and authorable, so the Build path is a
            starting point — not the ceiling. Capture, Prepare, Understand, and
            Follow&nbsp;Up round out the work-mode model Flow Agents routes
            intent into.
          </p>
        </div>

        <Grid cols={2} gap="sm">
          {skills.map(({ skill, desc }) => (
            <div class="skill">
              <code class="skill__fn">{skill}</code>
              <span class="skill__desc">{desc}</span>
            </div>
          ))}
        </Grid>
      </Split>
    </div>
  </Section>

  <!-- Example use case -->
  <Section borderTop size="lg">
    <div class="container">
      <Split ratio="1-1" gap="md" align="center">
        <div>
          <Eyebrow>Example use case</Eyebrow>
          <h2 class="display-md ip__title">You ask for the outcome.<br />Flow Agents handles the scaffolding.</h2>
          <p class="body ip__copy">
            No new CLI to memorize. You describe a feature request in plain
            language; Flow Agents routes it from idea to backlog to plan,
            implementation, review, and verify evidence while keeping the state
            and next action durable — even across compaction, branch switches,
            and delegated subagents.
          </p>
          <p class="body ip__copy ip__copy--last">
            When evidence is missing, the workflow stops and says so, instead of
            summarizing unfinished work as done.
          </p>
        </div>

        <Terminal title="ask the agent">
          <p class="muted">  You</p>
          <p>  Use deliver for issue #214. Plan it, implement it,</p>
          <p>  verify it, and stop if evidence is missing.</p>
          <br />
          <p class="muted">  Flow Agents</p>
          <p class="pass">  ✓ plan-work     execution plan → 3 waves</p>
          <p class="pass">  ✓ execute-plan  implementation complete</p>
          <p class="pass">  ✓ review-work   1 finding → routed back → fixed</p>
          <p class="warn">  ✗ verify-work   browser check missing</p>
          <br />
          <p>  stopped at <span class="warn">evidence-gate</span></p>
          <p class="muted">  next: capture a browser check, then resume</p>
          <p class="muted">  state → .flow-agents/runs/deliver-214/</p>
        </Terminal>
      </Split>
    </div>
  </Section>

  <!-- Evidence, governance, safety -->
  <Section tone="alt" borderTop>
    <div class="container">
      <Eyebrow gap="lg">What keeps it honest</Eyebrow>
      <Grid cols={3} gap="lg">
        {honest.map(({ title, body, accent }) => (
          <Card accent={accent} bar="top" pad="md">
            <h3 class="feature-title">{title}</h3>
            <p class="feature-body">{body}</p>
          </Card>
        ))}
      </Grid>
    </div>
  </Section>

  <!-- Where it is today -->
  <Section borderTop>
    <div class="container">
      <Split ratio="1-1" gap="md" align="center">
        <div>
          <Eyebrow accent="chalk-2">Where it is today</Eyebrow>
          <h2 class="display-md today__title">Usable now.<br />Early by design.</h2>
          <p class="body today__copy">
            The core Build workflows run today. Flow Agents installs into a
            workspace from GitHub — it isn't on npm yet, and it's pre-1.0, with a
            phased rollout toward richer just-in-time guidance, more work modes,
            and deeper governance.
          </p>
          <a href="https://kontourai.github.io/flow-agents/" target="_blank" rel="noopener" data-umami-event="flow-agents-bottom-docs" class="today__link">Read the docs →</a>
        </div>

        <Terminal title="quickstart">
          <p><span class="prompt">$ </span><span class="cmd">npx @kontourai/flow-agents init --dest ~/dev/my-project</span></p>
          <br />
          <p class="muted">  then, in your agent:</p>
          <p>  <span class="muted">"Use idea-to-backlog for this feature</span></p>
          <p>  <span class="muted"> and create executable GitHub issues."</span></p>
          <br />
          <p>  <span class="muted">"Use fix-bug. Reproduce it, find root cause,</span></p>
          <p>  <span class="muted"> fix it, and verify the regression path."</span></p>
        </Terminal>
      </Split>
    </div>
  </Section>

  <Section size="note" borderTop>
    <div class="container">
      <p class="closing-note">
        Flow Agents applies Kontour Flow inside existing agent tools. Flow owns the
        gates, transitions, and evidence; Flow Agents brings them — and optional
        Veritas governance — into the coding agents you already use.
      </p>
    </div>
  </Section>

  <Footer active="flow-agents" />
</Layout>

<style>
  .hero-copy--wide {
    max-width: 520px;
  }

  .path-title {
    margin-bottom: 1rem;
  }
  .path-note {
    margin-bottom: 2.5rem;
  }
  .fstep {
    position: relative;
    padding: 1.1rem 0.75rem;
    background: var(--color-ink-1);
    border: 1px solid var(--color-edge);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    text-align: center;
  }
  .fstep__n {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--color-chalk-3);
  }
  .fstep__name {
    font-family: var(--font-display);
    font-size: 0.92rem;
    color: var(--color-chalk-2);
    letter-spacing: 0;
  }
  .path-routes {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-chalk-3);
    letter-spacing: 0;
    margin-top: 1rem;
  }

  .promo__title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--color-chalk);
    margin-bottom: 0.75rem;
    letter-spacing: 0;
  }
  .promo__body {
    font-size: 0.85rem;
    color: var(--color-chalk-3);
    line-height: 1.7;
  }

  .runtimes-title {
    margin-bottom: 2.5rem;
  }
  .rt {
    padding: 1.5rem;
    background: var(--color-ink-1);
    border: 1px solid var(--color-edge);
    border-radius: 6px;
  }
  .rt__name {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--color-chalk);
    margin-bottom: 0.5rem;
    letter-spacing: 0;
  }
  .rt__detail {
    font-size: 0.8rem;
    color: var(--color-chalk-3);
    line-height: 1.6;
    margin: 0;
  }
  .rt-note {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-chalk-3);
    line-height: 1.6;
    margin-top: 1.5rem;
    max-width: 720px;
  }

  .bk__title,
  .ip__title,
  .today__title {
    margin-bottom: 1.25rem;
  }
  .bk__copy,
  .ip__copy {
    margin-bottom: 1.5rem;
  }
  .bk__copy--last,
  .ip__copy--last {
    margin-bottom: 0;
  }
  .today__copy {
    margin-bottom: 1.5rem;
  }
  .today__link {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-chalk-2);
    text-decoration: none;
  }

  .skill {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.9rem 1rem;
    background: var(--color-ink-2);
    border: 1px solid var(--color-edge);
    border-radius: 4px;
  }
  .skill__fn {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-chalk-2);
  }
  .skill__desc {
    font-size: 0.72rem;
    color: var(--color-chalk-3);
    line-height: 1.4;
  }

  .closing-note {
    color: var(--color-chalk-3);
    font-size: 0.95rem;
    line-height: 1.7;
    font-style: italic;
    margin: 0;
  }
</style>
