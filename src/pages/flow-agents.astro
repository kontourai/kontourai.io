---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import Terminal from '@/components/Terminal.astro';
import Section from '@/components/Section.astro';
import Glow from '@/components/Glow.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Card from '@/components/Card.astro';
import Grid from '@/components/Grid.astro';
import Split from '@/components/Split.astro';
import ProductMark from '@/components/ProductMark.astro';
import { getProductStatus, productBadge } from '@/lib/product-status';
import type { Accent } from '@/lib/theme';

const flowAgentsStatus = getProductStatus('flow-agents');

const engineParts: { title: string; body: string; accent: Accent }[] = [
  { title: 'FlowDefinition interpreter', accent: 'cobalt-2', body: 'Reads required paths, steps, transitions, gates, route-backs, exceptions, and continuation state from declared flows.' },
  { title: 'Gate runtime', accent: 'green', body: 'Turns evidence expectations into local advisory stops, CI reruns, and resumable next actions instead of chat-only promises.' },
  { title: 'Harness adapters', accent: 'chalk-2', body: 'Maps the same flow into Claude Code, Codex, Kiro, GitHub Actions, and future agent or non-agent runners.' },
  { title: 'Trust primitives', accent: 'gold', body: 'Carries SDK, evidence, Trust Bundle, command-log chain, and kit-validation records so every claim can point at public artifacts.' },
];

const kits: { name: string; href: string; job: string; proof: string; accent: Accent }[] = [
  { name: 'Builder Kit', href: '/builder-kit/', accent: 'chalk-2', job: 'Agent delivery: shape -> build -> publish -> learn.', proof: 'The first-party build path for verifiable agent work.' },
  { name: 'Knowledge Kit', href: '/knowledge-kit/', accent: 'gold', job: 'Durable, provenance-gated knowledge store.', proof: 'Keeps reusable memory tied to sources, owners, and freshness.' },
  { name: 'Release-Evidence Kit', href: 'https://kontourai.github.io/flow-agents/', accent: 'green', job: 'Agentless, flows-only release evidence.', proof: 'Proof that the engine runs solutions that ship no agent.' },
  { name: 'Veritas-Governance Kit', href: 'https://kontourai.github.io/flow-agents/', accent: 'cobalt-2', job: 'Agentless, flows-only governance gates.', proof: 'Feeds repo readiness evidence into Flow without giving one kit runtime privilege.' },
];

const trustTiers: { title: string; body: string; accent: Accent }[] = [
  { title: 'Local advisory runtime gate', accent: 'chalk-2', body: 'The agent sees the required next action and can be stopped or routed back when evidence is missing. Local state is advisory and inspectable.' },
  { title: 'Controlled CI rerun', accent: 'green', body: 'CI reruns the checks in a cleaner environment, compares against git ground truth, and anchors the result outside the agent session.' },
  { title: 'Refuse or escalate', accent: 'gold', body: 'When the evidence is not there, the flow says so. A human can accept a gap, but the exception stays in the record.' },
];
---

<Layout
  title="Flow Agents - Trust runtime and kit marketplace for agent work · Kontour AI"
  description="Flow Agents is a product-neutral trust runtime for the agents and workflow kits you already run: FlowDefinition interpretation, gates, runtime adapters, evidence, and kit validation."
>
  <Nav active="flow-agents" />

  <Section contour size="hero" borderBottom>
    <Glow accent="chalk-2" position="top-right" />
    <div class="container">
      <Split ratio="1-1" gap="lg" align="center">
        <div>
          <div class="hero-badges">
            <span class="trust-badge trust-badge--verified">{productBadge(flowAgentsStatus)}</span>
            <span class="install-hint">npx @kontourai/flow-agents init</span>
          </div>

          <ProductMark product="flow-agents" size={40} class="product-hero-mark animate-fade-up" data-accent="chalk-2" />
          <h1 class="product-title animate-fade-up">Flow Agents</h1>
          <p class="product-tagline animate-fade-up delay-100" data-accent="chalk-2">trust machinery for the agent you already run</p>

          <p class="hero-copy hero-copy--wide animate-fade-up delay-200">
            Flow Agents is the engine under Kontour's agent work: a
            product-neutral runtime for Flow Definitions, gates, harness
            adapters, SDK evidence, Trust Bundles, and kit validation. It is not
            the Builder Kit. Builder is one kit on top. The engine stays
            kit-neutral so teams can install the workflows they want, bring
            their own kits, and still get evidence a reviewer can inspect.
          </p>

          <div class="hero-actions animate-fade-up delay-300">
            <a href="https://kontourai.github.io/flow-agents/" target="_blank" rel="noopener" class="btn-primary" data-umami-event="flow-agents-hero-docs">Read the docs -></a>
            <a href="/builder-kit/" class="btn-ghost" data-umami-event="flow-agents-hero-builder">Builder Kit</a>
            <a href="/knowledge-kit/" class="btn-ghost" data-umami-event="flow-agents-hero-knowledge">Knowledge Kit</a>
          </div>
        </div>

        <Terminal class="animate-fade-in delay-300" title="engine + kit install">
          <p><span class="prompt">$ </span><span class="cmd">npx @kontourai/flow-agents init --dest ~/dev/my-project</span></p>
          <br />
          <p class="pass">  ✓ engine      FlowDefinition interpreter</p>
          <p class="pass">  ✓ gates       local advisory + CI rerun hooks</p>
          <p class="pass">  ✓ adapters    Codex · Claude Code · Kiro · GitHub Actions</p>
          <p class="pass">  ✓ primitives  SDK · evidence · trust bundles</p>
          <p class="pass">  ✓ catalog     kits/catalog.json + kit.json manifests</p>
          <br />
          <p><span class="prompt">$ </span><span class="cmd">npx @kontourai/flow-agents kit list</span></p>
          <p class="info">  Builder · Knowledge · Release-Evidence · Veritas-Governance</p>
        </Terminal>
      </Split>
    </div>
  </Section>

  <Section size="lg">
    <div class="container">
      <Eyebrow gap="sm">The engine</Eyebrow>
      <h2 class="display-md measure-lg engine-title">The same trust machinery for every kit — not one blessed workflow.</h2>
      <p class="fine measure engine-note">
        The engine interprets structured triggers and renders tool-native
        instructions. No kit gets runtime privilege. "Official" and
        "first-party" are marketplace labels, not engine authority.
      </p>

      <Grid cols={4} gap="md">
        {engineParts.map(({ title, body, accent }) => (
          <Card accent={accent} bar="top" pad="sm">
            <h3 class="feature-title">{title}</h3>
            <p class="feature-body">{body}</p>
          </Card>
        ))}
      </Grid>
    </div>
  </Section>

  <Section tone="alt" borderTop borderBottom>
    <div class="container">
      <Eyebrow accent="chalk-2" gap="sm">Kit portfolio</Eyebrow>
      <h2 class="display-md kit-title">Builder is important. It is not the whole product.</h2>
      <p class="body measure kit-copy">
        Kits are swappable solutions declared in <code>kit.json</code> and
        registered in <code>kits/catalog.json</code>. Install what you want.
        Leave the rest out.
      </p>

      <Grid cols={4} gap="md">
        {kits.map(({ name, href, job, proof, accent }) => (
          <a class="kit-card" href={href} data-accent={accent}>
            <span class="kit-card__name">{name}</span>
            <span class="kit-card__job">{job}</span>
            <span class="kit-card__proof">{proof}</span>
          </a>
        ))}
      </Grid>
    </div>
  </Section>

  <Section borderBottom>
    <div class="container">
      <Split ratio="1-1" gap="md" align="center">
        <div>
          <Eyebrow accent="gold">Marketplace direction</Eyebrow>
          <h2 class="display-md market-title">A catalog for trust-bearing workflows.</h2>
          <p class="body market-copy">
            The growth path is a marketplace: official kits, community kits, and
            bring-your-own-kit workflows that declare their triggers, flows,
            adapters, skills, docs, dependencies, and validation requirements
            up front.
          </p>
          <p class="body market-copy market-copy--last">
            A kit can be first-party and still have no special runtime powers.
            The engine only follows the manifest and the structured triggers the
            kit declares.
          </p>
        </div>

        <Terminal title="catalog + manifest">
          <p><span class="cmd">kits/catalog.json</span></p>
          <p class="muted">  id: builder</p>
          <p class="muted">  name: Builder Kit</p>
          <p class="muted">  path: kits/builder</p>
          <br />
          <p><span class="cmd">kit.json</span></p>
          <p class="pass">  ✓ flows</p>
          <p class="pass">  ✓ workflow_triggers</p>
          <p class="pass">  ✓ dependencies (knowledge)</p>
          <p class="pass">  ✓ validated against contract</p>
          <p class="muted">  privilege: none</p>
        </Terminal>
      </Split>
    </div>
  </Section>

  <Section tone="alt" borderTop>
    <div class="container">
      <Eyebrow gap="lg">Trust posture</Eyebrow>
      <h2 class="display-md measure-lg trust-title">Tamper-evident. Not magic.</h2>
      <p class="fine measure trust-note">
        Flow Agents does not claim agent behavior is impossible to manipulate.
        It records what the agent claimed, what evidence exists, what git says
        changed, and what a controlled rerun could verify.
      </p>

      <Grid cols={3} gap="lg">
        {trustTiers.map(({ title, body, accent }) => (
          <Card accent={accent} bar="top" pad="md">
            <h3 class="feature-title">{title}</h3>
            <p class="feature-body">{body}</p>
          </Card>
        ))}
      </Grid>
    </div>
  </Section>

  <Section size="note" borderTop>
    <div class="container">
      <p class="closing-note">
        Flow Agents is the engine. Builder, Knowledge, Release-Evidence, and
        Veritas-Governance are kits. The engine stays neutral so the marketplace
        can grow without turning one workflow into the runtime's authority.
      </p>
    </div>
  </Section>

  <Footer active="flow-agents" />
</Layout>

<style>
  .hero-copy--wide {
    max-width: 540px;
  }
  .engine-title,
  .kit-title,
  .market-title,
  .trust-title {
    margin-bottom: 1rem;
  }
  .engine-note,
  .trust-note {
    margin-bottom: 2.25rem;
  }
  .kit-copy,
  .market-copy {
    margin-bottom: 1.5rem;
  }
  .market-copy--last {
    margin-bottom: 0;
  }
  .kit-card {
    display: flex;
    min-height: 220px;
    flex-direction: column;
    gap: 1rem;
    padding: 1.25rem;
    color: inherit;
    text-decoration: none;
    background: var(--color-ink-1);
    border: 1px solid var(--color-edge);
    border-top: 2px solid var(--accent);
    border-radius: 6px;
  }
  .kit-card:hover {
    border-color: color-mix(in srgb, var(--accent) 52%, var(--color-edge));
  }
  .kit-card__name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--accent);
    letter-spacing: 0;
  }
  .kit-card__job {
    color: var(--color-chalk);
    line-height: 1.55;
  }
  .kit-card__proof {
    margin-top: auto;
    color: var(--color-chalk-3);
    font-size: 0.82rem;
    line-height: 1.6;
  }
</style>
