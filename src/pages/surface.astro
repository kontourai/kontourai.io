---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import Terminal from '@/components/Terminal.astro';
import Section from '@/components/Section.astro';
import Glow from '@/components/Glow.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Card from '@/components/Card.astro';
import Grid from '@/components/Grid.astro';
import Split from '@/components/Split.astro';
import QuestionGrid from '@/components/QuestionGrid.astro';
import ProductMark from '@/components/ProductMark.astro';
import { getProductStatus, productBadge } from '@/lib/product-status';
import type { Accent } from '@/lib/theme';

const surfaceStatus = getProductStatus('surface');

const answers: { q: string; accent?: Accent }[] = [
  { q: 'What does this product claim?' },
  { q: 'What evidence supports the claim, and where does it come from?' },
  { q: 'Is the verification still current?', accent: 'gold' },
  { q: "What's missing, stale, or in conflict — and what should happen before anyone acts on it?", accent: 'red' },
];

const roles: { title: string; label: string; body: string; accent: Accent }[] = [
  { title: 'For your customers', label: 'Customer trust', body: "Inspect the trust state behind a product answer, report, recommendation, or agent output before they rely on it. Surface shows the claim, the evidence behind it, how current that evidence is, and what's still uncertain.", accent: 'gold' },
  { title: 'For your product', label: 'Product integration', body: 'Emit claims, evidence, and policies from your product. Surface gives you a shared shape so the same trust state can be read by people, agents, and other systems downstream.', accent: 'green' },
  { title: 'For your team', label: 'Operations', body: 'Manage the claims your product makes - ownership, evidence review, policies, transparency gaps, conflicts - from one workspace. Surface Console runs locally — no cloud, no account.', accent: 'cobalt-2' },
];

const vocab: { term: string; def: string; accent: Accent }[] = [
  { term: 'Claim', def: 'The smallest trust-bearing unit. A statement about a subject — field, value, impact, and current integrity reference.', accent: 'cobalt-2' },
  { term: 'Evidence', def: 'An observation, citation, attestation, test result, or traceable artifact that supports or challenges a Claim.', accent: 'green' },
  { term: 'Policy', def: 'The rule that decides what evidence is required, how fresh it must be, and when a Claim needs review.', accent: 'chalk-2' },
  { term: 'Trust Snapshot', def: 'A point-in-time view of Claims, Evidence, Policies, status, gaps, and conflicts — each with when it was last checked — that humans and agents can inspect.', accent: 'cobalt-2' },
  { term: 'Transparency Gap', def: 'A missing, weak, stale, private, unavailable, unverifiable, or unmapped element that limits inspectability.', accent: 'red' },
];

const statuses: { status: string; badge: string; label: string; pulse?: boolean }[] = [
  { status: 'unknown', badge: 'trust-badge--unknown', label: 'No prior verification exists.' },
  { status: 'proposed', badge: 'trust-badge--proposed', label: 'Submitted but not yet verified.' },
  { status: 'verified', badge: 'trust-badge--verified', label: 'Evidence supports it. Currently valid.' },
  { status: 'stale', badge: 'trust-badge--stale', label: 'Was valid. Freshness window exceeded.', pulse: true },
  { status: 'disputed', badge: 'trust-badge--disputed', label: 'Conflicting evidence or policy.' },
  { status: 'rejected', badge: 'trust-badge--disputed', label: 'Explicitly failed verification.' },
  { status: 'superseded', badge: 'trust-badge--unknown', label: 'Replaced by a newer verified claim.' },
];

const consoleFeatures = [
  { label: 'Run history', body: 'Switch between past runs in the toolbar to compare claim state before and after a change.' },
  { label: 'Trust Panel', body: 'See the customer-facing view of any Claim alongside your full operator context.' },
  { label: 'Filtered chips', body: 'Filter Verified, Attention, or total Claims instantly while reviewing the current Trust Snapshot.' },
  { label: 'Claim Groups', body: 'Start from a framework, checklist, or requirement set, then drill into the Claims and Evidence that decide its status.' },
  { label: 'Integrity scope', body: 'Inspect the source anchor and cryptographic fingerprints behind a verified claim.' },
  { label: 'Claim detail', body: 'Select any claim to inspect its full evidence, status, and gaps without leaving the list.' },
  { label: 'Transparency gaps', body: 'When evidence is missing, private, stale, or conflicting, the gap stays visible beside the Claim.' },
];

const moreThanStatus: { title: string; body: string; accent: Accent }[] = [
  { title: 'Claim dependencies', accent: 'cobalt-2', body: 'A claim can depend on supporting claims. When an upstream claim goes stale or disputed, that state propagates to everything built on it — no silent rot.' },
  { title: 'Reverification', accent: 'gold', body: 'Producers can advertise how to recheck a claim’s evidence, authority, freshness, or integrity — so a stale claim has a path back to verified instead of staying a dead end.' },
  { title: 'Analytics reports', accent: 'green', body: 'Beyond the human summary, an analytics format exposes evidence and gaps as queryable data for dashboards, audits, and trust intelligence.' },
];
---

<Layout
  title="Surface — Inspectable claims for AI-assisted work · Kontour AI"
  description="Surface makes claims inspectable with one shape for claims, evidence, policies, freshness, and gaps."
>
  <Nav active="surface" />

  <!-- Hero -->
  <Section contour size="hero" borderBottom>
    <Glow accent="gold" position="top-left" />
    <div class="container">
      <Split ratio="1-1" gap="lg" align="start">
        <div>
          <div class="hero-badges">
            <span class="trust-badge trust-badge--verified">{productBadge(surfaceStatus)}</span>
            <span class="install-hint">npm install -D @kontourai/surface</span>
          </div>

          <ProductMark product="surface" size={40} class="product-hero-mark animate-fade-up" data-accent="gold" />
          <h1 class="product-title animate-fade-up">Surface</h1>
          <p class="product-tagline animate-fade-up delay-100" data-accent="gold">claims, evidence, freshness, and gaps in one inspectable shape</p>

          <p class="hero-copy animate-fade-up delay-200">
            Every product makes claims. AI makes those claims faster, more
            polished, and harder to inspect. Surface gives a product one shape
            for the claim, the evidence behind it, the policy that decides what
            counts, how fresh the evidence is, and the gaps that should slow
            anyone down before they rely on it. Surface does not decide domain
            truth; it makes the trust state portable and inspectable.
          </p>

          <div class="hero-actions animate-fade-up delay-300">
            <a href="https://github.com/kontourai/surface" target="_blank" rel="noopener" class="btn-primary" data-umami-event="surface-hero-github">View on GitHub →</a>
            <a href="https://www.npmjs.com/package/@kontourai/surface" target="_blank" rel="noopener" class="btn-ghost" data-umami-event="surface-hero-npm">npm package</a>
          </div>
        </div>

        <Terminal class="animate-fade-in delay-300" title="surface report — summary">
          <p><span class="prompt">$ </span><span class="cmd">npx @kontourai/surface report --input trust-bundle.json --format summary</span></p>
          <br />
          <p class="info">  Kontour Surface trust snapshot surface-1777090239260</p>
          <p class="muted">  Source: kontour-surface-validation-fixtures</p>
          <br />
          <p>  Claims: <span class="pass">4</span> &nbsp;(unknown: 1, verified: 2, stale: 1)</p>
          <p class="muted">  Claim types: repo-governance.developer-evidence: 1, field-attested-records.public-data: 1,</p>
          <p class="muted">  &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; fact-resolution.financial-facts: 1, surface.roadmap: 1</p>
          <br />
          <p>  Claim Groups: <span class="pass">1</span></p>
          <p>  High-impact unsupported: <span class="pass">none</span></p>
          <p>  Stale: &nbsp;&nbsp;&nbsp;<span class="warn">claim.field-attested-records.registration-status</span></p>
          <p>  Conflicts: <span class="pass">none</span></p>
          <p>  Transparency gaps: <span class="warn">3</span></p>
        </Terminal>
      </Split>
    </div>
  </Section>

  <!-- What Surface answers -->
  <Section size="lg">
    <div class="container">
      <Eyebrow gap="lg">What Surface answers</Eyebrow>
      <QuestionGrid items={answers} min="300" />
    </div>
  </Section>

  <!-- Example use case -->
  <Section tone="alt" borderTop borderBottom>
    <div class="container">
      <Split ratio="1-1" gap="md" align="center">
        <div>
          <Eyebrow accent="gold">Example use case</Eyebrow>
          <h2 class="display-md section-title">Inspect a claim before an agent acts on it.</h2>
          <p class="body">
            A support agent says, "This provider directory listing is current."
            Surface turns that into an inspectable claim with a source anchor,
            freshness policy, last verification time, and any gap that should
            slow the agent down before it recommends the listing.
          </p>
        </div>

        <Terminal title="claim.provider-directory.current">
          <p class="info">  claim: provider directory listing is current</p>
          <p class="muted">  source: registry export · row 1842</p>
          <p class="pass">  evidence: verified 2026-06-07</p>
          <p class="warn">  freshness: recheck in 7 days</p>
          <p class="muted">  gap: phone number attestation private</p>
          <br />
          <p>  action: <span class="warn">show uncertainty beside recommendation</span></p>
        </Terminal>
      </Split>
    </div>
  </Section>

  <!-- Role paths -->
    <Section borderBottom>
    <div class="container">
      <Eyebrow accent="gold" gap="sm">See it</Eyebrow>
      <figure class="product-shot">
        <img src="/screenshots/surface-console.png" alt="Surface Console reviewing a producer run: verified claims, an attention band, and a stale claim flagged for refresh" loading="lazy" />
        <figcaption>The local Surface Console reviewing a producer run — verified claims, an attention band, and a stale claim flagged for refresh. <a href="https://kontourai.github.io/surface/" target="_blank" rel="noopener">Explore the docs →</a></figcaption>
      </figure>
    </div>
  </Section>

<Section borderTop>
    <div class="container">
      <Eyebrow gap="lg">What Surface gives you</Eyebrow>
      <Grid cols={3} gap="md">
        {roles.map(({ title, label, body, accent }) => (
          <Card accent={accent} bar="top" pad="sm">
            <div class="feature-label">{label}</div>
            <h3 class="role-card__title">{title}</h3>
            <p class="feature-body">{body}</p>
          </Card>
        ))}
      </Grid>
    </div>
  </Section>

  <!-- Trust vocabulary -->
  <Section tone="alt" borderTop borderBottom>
    <div class="container">
      <Eyebrow gap="lg">Trust vocabulary</Eyebrow>
      <Grid cols={3} gap="lg">
        {vocab.map(({ term, def, accent }) => (
          <div class="vocab" data-accent={accent}>
            <div class="vocab__term">{term}</div>
            <div class="vocab__def">{def}</div>
          </div>
        ))}
      </Grid>
    </div>
  </Section>

  <!-- Trust status model -->
  <Section size="md">
    <div class="container">
      <Eyebrow gap="lg">Trust status model</Eyebrow>
      <Grid min="200" gap="md">
        {statuses.map(({ status, badge, label, pulse }) => (
          <div class="status-card">
            <span class={`trust-badge ${badge}`}>
              <span class="status-dot" data-pulse={pulse}></span>
              {status}
            </span>
            <p class="status-card__label">{label}</p>
          </div>
        ))}
      </Grid>
    </div>
  </Section>

  <!-- Surface Console -->
  <Section borderTop>
    <div class="container">
      <Split ratio="1-1" gap="md" align="start">
        <div>
          <Eyebrow>Surface Console</Eyebrow>
          <h2 class="display-md console__title">See trust state<br />where the work happens.</h2>
          <p class="body console__copy">
            <code class="codechip">surface console</code> serves a live view from
            <code class="codechip codechip--muted">.surface/runs/latest.json</code>.
            Each new run updates automatically. Runs locally — no account,
            nothing to host.
          </p>

          <div class="feat-list">
            {consoleFeatures.map(({ label, body }) => (
              <div class="kv feat">
                <div class="feat__key">{label}</div>
                <div class="kv__val">{body}</div>
              </div>
            ))}
          </div>
        </div>

        <Terminal title="surface console">
          <p><span class="prompt">$ </span><span class="cmd">npx @kontourai/surface console</span></p>
          <br />
          <p class="info">  Surface Console running at http://localhost:4242</p>
          <br />
          <p class="muted">  Reading: .surface/runs/latest.json</p>
          <p class="muted">  Source: latest Surface run snapshot</p>
          <br />
          <p class="muted">  GET /              200  console shell</p>
          <p class="muted">  GET /api/read-model  200  current trust snapshot</p>
          <p class="muted">  GET /api/runs        200  [run-a, run-b, run-c]</p>
          <br />
          <p class="rule">  ───────────────────────────────</p>
          <p class="pass">  verified  8 claims</p>
          <p class="warn">  attention  2 claims</p>
          <p class="muted">  eval  accepted · confidence: high</p>
        </Terminal>
      </Split>
    </div>
  </Section>

  <!-- More than a status -->
  <Section borderTop size="lg">
    <div class="container">
      <Eyebrow>More than a status</Eyebrow>
      <h2 class="display-md measure-lg section-title">Trust state that propagates, refreshes, and answers questions.</h2>
      <Grid cols={3} gap="lg">
        {moreThanStatus.map(({ title, body, accent }) => (
          <Card accent={accent} bar="top" pad="md">
            <h3 class="feature-title">{title}</h3>
            <p class="feature-body">{body}</p>
          </Card>
        ))}
      </Grid>
    </div>
  </Section>

  <!-- Products built with Surface -->
  <Section tone="alt" borderTop>
    <div class="container">
      <Eyebrow gap="sm">Products built with Surface</Eyebrow>
      <p class="fine measure built-note">
        Products built with Surface keep their own workflow vocabulary while exposing
        Claims, Evidence, Policies, Trust Snapshots, and Transparency Gaps in a shared
        shape humans and agents can inspect.
        Surface is the reference implementation of the <a href="https://hachure.org" target="_blank" rel="noopener">Hachure open trust format</a> —
        the portable, recomputable trust format anyone can implement independently.
      </p>

      <Grid cols={2} gap="lg">
        <Card accent="green" bar="bottom" pad="lg">
          <h3 class="built__title">Veritas</h3>
          <p class="built__tag" data-accent="green">Merge autonomy for AI-authored code</p>
          <p class="built__body">
            Turns Repo Standards, evidence checks, boundary crossings, and readiness
            outcomes into Surface-backed trust state. Veritas users stay in repo-native
            language while downstream systems can inspect the evidence behind merge readiness.
          </p>
          <a href="/veritas" class="built__link" data-accent="green">Explore Veritas →</a>
        </Card>

        <Card accent="chalk-3" bar="bottom" pad="lg" class="built--muted">
          <h3 class="built__title built__title--muted">Your product</h3>
          <p class="built__tag" data-accent="chalk-3">Anything that needs product transparency</p>
          <p class="built__body built__body--muted">
            Public-data records, fact resolution, audit pipelines, fitness tracking,
            compliance filings, marketplace listings — anywhere a product needs to show the
            work behind what it asks people and agents to trust.
          </p>
          <a href="https://github.com/kontourai/surface/tree/main/examples/external-adapter" target="_blank" rel="noopener" class="built__link" data-accent="chalk-3">Build with Surface →</a>
        </Card>
      </Grid>
    </div>
  </Section>

  <Footer active="surface" />
</Layout>

<style>
  .codechip--muted {
    color: var(--color-chalk-3);
    background: none;
    padding: 0;
    font-size: 0.82rem;
  }

  .role-card__title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--color-chalk);
    margin-bottom: 0.75rem;
    letter-spacing: 0;
  }

  .vocab {
    padding: 1.5rem;
    background: var(--color-ink-2);
    border: 1px solid var(--color-edge);
    border-radius: 6px;
  }
  .vocab__term {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--accent);
    margin-bottom: 0.6rem;
    letter-spacing: 0;
  }
  .vocab__def {
    font-size: 0.82rem;
    color: var(--color-chalk-3);
    line-height: 1.65;
  }

  .status-card {
    padding: 1.25rem;
    background: var(--color-ink-1);
    border: 1px solid var(--color-edge);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    display: inline-block;
    background: currentColor;
  }
  .status-dot[data-pulse] {
    animation: pulse-dot 2s ease-in-out infinite;
  }
  .status-card__label {
    font-size: 0.78rem;
    color: var(--color-chalk-3);
    line-height: 1.5;
  }

  .console__title {
    margin-bottom: 1.25rem;
  }
  .console__copy {
    margin-bottom: 1.5rem;
  }
  .feat-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .feat__key {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-gold);
    min-width: 110px;
    padding-top: 1px;
  }

  .section-title {
    margin-bottom: 2.5rem;
  }

  .built-note {
    margin-bottom: 2.5rem;
  }
  .built__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-chalk);
    margin-bottom: 0.3rem;
    letter-spacing: 0;
  }
  .built__title--muted {
    color: var(--color-chalk-2);
  }
  .built__tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--accent, var(--color-chalk-3));
    letter-spacing: 0;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .built__body {
    color: var(--color-chalk-2);
    font-size: 0.85rem;
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }
  .built__body--muted {
    color: var(--color-chalk-3);
  }
  .built__link {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent, var(--color-chalk-3));
    text-decoration: none;
  }
  .built--muted {
    opacity: 0.6;
  }
</style>
