---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
---

<Layout
  title="Surface — Product transparency for the AI era · Kontour AI"
  description="Kontour Surface is a product transparency standard for claims, evidence, evidence traces, policies, trust snapshots, and transparency gaps."
>
  <Nav active="surface" />

  <!-- ──────────────────────────────────────────────────────
       Hero
  ────────────────────────────────────────────────────────── -->
  <section class="contour-bg" style="
    padding: 10rem var(--spacing-page) 6rem;
    border-bottom: 1px solid var(--color-edge);
    position: relative;
    overflow: hidden;
  ">
    <!-- Gold glow -->
    <div style="
      position: absolute;
      top: -100px;
      left: -100px;
      width: 700px;
      height: 600px;
      background: radial-gradient(ellipse at top left, rgba(201,163,90,0.055) 0%, transparent 65%);
      pointer-events: none;
    "></div>

    <div style="max-width: 1280px; margin: 0 auto; position: relative; z-index: 1;">
      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
        align-items: start;
      ">
        <!-- Left -->
        <div>
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 2rem;">
            <span class="trust-badge trust-badge--verified">v0.4.0</span>
            <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--color-chalk-3);">npm install -D @kontourai/surface</span>
          </div>

          <h1 class="animate-fade-up" style="
            font-family: var(--font-display);
            font-optical-sizing: auto;
            font-size: clamp(3.5rem, 6vw, 5.5rem);
            font-weight: 400;
            line-height: 0.95;
            letter-spacing: -0.03em;
            color: var(--color-chalk);
            margin-bottom: 0.5rem;
          ">Surface</h1>

          <p class="animate-fade-up delay-100" style="
            font-family: var(--font-mono);
            font-size: 0.75rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--color-gold);
            margin-bottom: 2rem;
          ">Product transparency for the AI era</p>

          <p class="animate-fade-up delay-100" style="
            font-family: var(--font-display);
            font-size: clamp(2rem, 3.5vw, 3.4rem);
            font-weight: 300;
            line-height: 1.05;
            color: var(--color-chalk);
            margin: -0.75rem 0 1.75rem;
            letter-spacing: -0.02em;
          ">Show your work. Earn trust.</p>

          <p class="animate-fade-up delay-200" style="
            font-size: 1.05rem;
            color: var(--color-chalk-2);
            line-height: 1.7;
            max-width: 460px;
            margin-bottom: 2.5rem;
          ">
            AI and product interfaces can make polished claims faster than users
            can inspect them. Surface gives products a shared way to expose each
            Claim, the Evidence behind it, the Evidence Trace, the Policy that
            applies, and the Transparency Gap or Conflict that should slow action.
          </p>

          <div class="animate-fade-up delay-300" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
            <a href="https://github.com/kontourai/surface" target="_blank" rel="noopener" class="btn-primary" data-umami-event="surface-hero-github">
              View on GitHub →
            </a>
            <a href="https://www.npmjs.com/package/@kontourai/surface" target="_blank" rel="noopener" class="btn-ghost" data-umami-event="surface-hero-npm">
              npm package
            </a>
          </div>
        </div>

        <!-- Right: Trust report output -->
        <div class="animate-fade-in delay-300">
          <div class="terminal">
            <div class="terminal-bar">
              <div class="terminal-dot"></div>
              <div class="terminal-dot"></div>
              <div class="terminal-dot"></div>
              <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--color-chalk-3); margin-left: 0.5rem;">surface report — summary</span>
            </div>
            <div class="terminal-body">
              <p><span class="prompt">$ </span><span class="cmd">npx surface report --input examples/surface-fixtures.json --format summary</span></p>
              <br />
              <p class="info">  Kontour Surface trust snapshot surface-1777090239260</p>
              <p class="muted">  Source: kontour-surface-validation-fixtures</p>
              <br />
              <p>  Claims: <span class="pass">4</span> &nbsp;(unknown: 1, verified: 2, stale: 1)</p>
              <p class="muted">  Claim types: repo-governance.developer-evidence: 1, field-attested-records.public-data: 1,</p>
              <p class="muted">  &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; fact-resolution.financial-facts: 1, surface.roadmap: 1</p>
              <br />
              <p>  Claim Groups: <span class="pass">1</span></p>
              <p>  High-impact unsupported: <span class="pass">none</span></p>
              <p>  Stale: &nbsp;&nbsp;&nbsp;<span class="warn">claim.field-attested-records.registration-status</span></p>
              <p>  Conflicts: <span class="pass">none</span></p>
              <p>  Transparency gaps: <span class="warn">3</span></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       What Surface answers
  ────────────────────────────────────────────────────────── -->
  <section style="padding: 6rem var(--spacing-page);">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 3rem;">What Surface answers</div>

      <div style="
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1rem;
      ">
        {[
          { q: 'What is the claim?', color: 'var(--color-chalk-2)' },
          { q: 'What evidence supports it?', color: 'var(--color-chalk-2)' },
          { q: 'What evidence trace shows how it was produced?', color: 'var(--color-chalk-2)' },
          { q: 'Which policy decides whether it is current enough?', color: 'var(--color-chalk-2)' },
          { q: 'How long is that verification valid?', color: 'var(--color-gold)' },
          { q: 'What transparency gap or conflict is visible?', color: 'var(--color-gold)' },
          { q: 'Which claim group or requirement does this support?', color: 'var(--color-cobalt-2)' },
          { q: 'What should an agent do before relying on it?', color: 'var(--color-red)' },
        ].map(({ q, color }, i) => (
          <div key={i} style="
            display: flex;
            align-items: flex-start;
            gap: 1rem;
            padding: 1.25rem;
            background: var(--color-ink-1);
            border: 1px solid var(--color-edge);
            border-radius: 4px;
          ">
            <span style={`
              font-family: var(--font-mono);
              font-size: 0.65rem;
              color: var(--color-chalk-3);
              padding-top: 2px;
              min-width: 1.5rem;
            `}>0{i + 1}</span>
            <span style={`
              font-size: 0.9rem;
              color: ${color};
              line-height: 1.5;
            `}>{q}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Role paths
  ────────────────────────────────────────────────────────── -->
  <section style="
    padding: 5rem var(--spacing-page);
    border-top: 1px solid var(--color-edge);
  ">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 2.5rem;">Surface paths</div>

      <div style="
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
      ">
        {[
          { action: 'View the Surface', role: 'Viewer', body: 'Inspect a Trust Panel before relying on a product answer, report, profile, recommendation, or agent output.', color: 'var(--color-gold)' },
          { action: 'Shape the Surface', role: 'Operator', body: 'Use the Surface Console to manage Claims, Policies, ownership, review queues, Transparency Gaps, and Conflicts.', color: 'var(--color-cobalt-2)' },
          { action: 'Build with Surface', role: 'Builder', body: 'Emit Claims, Evidence, Evidence Traces, Policies, materiality mappings, and Trust Snapshots from your product.', color: 'var(--color-green)' },
          { action: 'Verify with Surface', role: 'Verifier', body: 'Check evidence, authority, freshness, and integrity under policy without turning Surface into a certification service.', color: 'var(--color-red)' },
        ].map(({ action, role, body, color }) => (
          <div key={action} class="card" style="padding: 1.5rem; position: relative; overflow: hidden;">
            <div style={`
              position: absolute;
              top: 0;
              left: 0;
              right: 0;
              height: 2px;
              background: linear-gradient(90deg, ${color}, transparent);
            `}></div>
            <div style={`
              font-family: var(--font-mono);
              font-size: 0.65rem;
              color: ${color};
              letter-spacing: 0.08em;
              text-transform: uppercase;
              margin-bottom: 0.75rem;
            `}>{role}</div>
            <h3 style="
              font-family: var(--font-display);
              font-size: 1.35rem;
              font-weight: 400;
              color: var(--color-chalk);
              margin-bottom: 0.75rem;
              letter-spacing: -0.01em;
            ">{action}</h3>
            <p style="font-size: 0.82rem; color: var(--color-chalk-3); line-height: 1.65;">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Trust vocabulary
  ────────────────────────────────────────────────────────── -->
  <section style="
    padding: 5rem var(--spacing-page);
    border-top: 1px solid var(--color-edge);
    border-bottom: 1px solid var(--color-edge);
    background: var(--color-ink-1);
  ">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 2.5rem;">Trust vocabulary</div>

      <div style="
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
      ">
        {[
          {
            term: 'Claim',
            def: 'The smallest trust-bearing unit. A statement about a subject — field, value, impact, and current integrity reference.',
            color: 'var(--color-cobalt-2)',
          },
          {
            term: 'Evidence',
            def: 'An observation, citation, attestation, test result, or traceable artifact that supports or challenges a Claim.',
            color: 'var(--color-green)',
          },
          {
            term: 'Evidence Trace',
            def: 'The inspectable path showing source, method, actor or system, timestamp, tool context, logs, and integrity scope.',
            color: 'var(--color-green)',
          },
          {
            term: 'Policy',
            def: 'The rule that decides what evidence is required, how fresh it must be, and when a Claim needs review.',
            color: 'var(--color-chalk-2)',
          },
          {
            term: 'Trust Snapshot',
            def: 'A point-in-time view of Claims, Evidence, Policies, status, gaps, and conflicts that humans and agents can inspect.',
            color: 'var(--color-cobalt-2)',
          },
          {
            term: 'Trust Panel',
            def: 'The viewer-facing interface that exposes the trust state behind a product claim or output.',
            color: 'var(--color-cobalt-2)',
          },
          {
            term: 'Surface Console',
            def: 'The operator workspace for shaping product transparency: claims, ownership, policies, evidence review, and gaps.',
            color: 'var(--color-chalk)',
          },
          {
            term: 'Transparency Gap',
            def: 'A missing, weak, stale, private, unavailable, unverifiable, or unmapped element that limits inspectability.',
            color: 'var(--color-red)',
          },
          {
            term: 'Conflict',
            def: 'A visible disagreement between Claims, Evidence, Policies, source state, or authority traces.',
            color: 'var(--color-red)',
          },
        ].map(({ term, def, color }) => (
          <div key={term} style="
            padding: 1.5rem;
            background: var(--color-ink-2);
            border: 1px solid var(--color-edge);
            border-radius: 6px;
          ">
            <div style={`
              font-family: var(--font-display);
              font-size: 1.15rem;
              font-weight: 400;
              color: ${color};
              margin-bottom: 0.6rem;
              letter-spacing: -0.01em;
            `}>{term}</div>
            <div style="
              font-size: 0.82rem;
              color: var(--color-chalk-3);
              line-height: 1.65;
            ">{def}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Trust status model
  ────────────────────────────────────────────────────────── -->
  <section style="padding: 5rem var(--spacing-page);">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 2.5rem;">Trust status model</div>

      <div style="
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1rem;
      ">
        {[
          { status: 'unknown',     badge: 'trust-badge--unknown',    label: 'No prior verification exists.' },
          { status: 'proposed',    badge: 'trust-badge--proposed',   label: 'Submitted but not yet verified.' },
          { status: 'verified',    badge: 'trust-badge--verified',   label: 'Evidence supports it. Currently valid.' },
          { status: 'stale',       badge: 'trust-badge--stale',      label: 'Was valid. Freshness window exceeded.' },
          { status: 'disputed',    badge: 'trust-badge--disputed',   label: 'Conflicting evidence or policy.' },
          { status: 'rejected',    badge: 'trust-badge--disputed',   label: 'Explicitly failed verification.' },
          { status: 'superseded',  badge: 'trust-badge--unknown',    label: 'Replaced by a newer verified claim.' },
        ].map(({ status, badge, label }) => (
          <div key={status} style="
            padding: 1.25rem;
            background: var(--color-ink-1);
            border: 1px solid var(--color-edge);
            border-radius: 4px;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
          ">
            <span class={`trust-badge ${badge}`}>
              <span style={`
                width: 5px;
                height: 5px;
                border-radius: 50%;
                display: inline-block;
                background: currentColor;
                ${status === 'stale' ? 'animation: pulse-dot 2s ease-in-out infinite;' : ''}
              `}></span>
              {status}
            </span>
            <p style="font-size: 0.78rem; color: var(--color-chalk-3); line-height: 1.5;">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Where it fits
  ────────────────────────────────────────────────────────── -->
  <section style="
    padding: 5rem var(--spacing-page);
    border-top: 1px solid var(--color-edge);
  ">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 1rem;">Where it fits</div>
      <p style="
        color: var(--color-chalk-3);
        font-size: 0.9rem;
        line-height: 1.65;
        max-width: 640px;
        margin-bottom: 2.5rem;
      ">
        Any product that makes claims users or agents rely on can build with Surface
        as its product transparency layer. Fitness data, financial records, marketplace
        listings, audit pipelines, AI agent output — the same shape works anywhere
        you need to show the work behind the answer.
      </p>

      <div style="
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
      ">
        {[
          {
            name: 'Public Data',
            subtitle: 'Field-level provenance',
            desc: 'A record directory, a public dataset, a marketplace listing. Claim that each field is current, show where it came from, and surface when it was last verified — before anyone acts on it.',
            signals: ['sourced', 'attested', 'reviewed', 'fresh'],
            color: 'var(--color-cobalt-2)',
          },
          {
            name: 'Fact Resolution',
            subtitle: 'High-stakes values',
            desc: 'A fact-extraction workflow that picks among candidates and cites its sources. Show the decision trail, flag what could not be corroborated, and mark what needs a human review.',
            signals: ['extracted', 'selected', 'cited', 'reviewed'],
            color: 'var(--color-gold)',
          },
          {
            name: 'Security & Compliance',
            subtitle: 'Requirements with drilldown',
            desc: 'Dependency scans, policy checks, access reviews. Roll requirements up into a requirement-set view while preserving the exact Claim, Evidence, and Evidence Trace behind each verdict.',
            signals: ['scanned', 'policy-checked', 'requirement-rollup', 'current'],
            color: 'var(--color-red)',
          },
        ].map(({ name, subtitle, desc, signals, color }) => (
          <div key={name} class="card" style="padding: 2rem; position: relative; overflow: hidden;">
            <div style={`
              position: absolute;
              bottom: 0;
              left: 0;
              right: 0;
              height: 2px;
              background: linear-gradient(90deg, ${color}, transparent);
            `}></div>

            <h3 style="
              font-family: var(--font-display);
              font-size: 1.5rem;
              font-weight: 400;
              color: var(--color-chalk);
              margin-bottom: 0.3rem;
              letter-spacing: -0.01em;
            ">{name}</h3>

            <p style={`
              font-family: var(--font-mono);
              font-size: 0.68rem;
              color: ${color};
              letter-spacing: 0.08em;
              text-transform: uppercase;
              margin-bottom: 1rem;
            `}>{subtitle}</p>

            <p style="
              color: var(--color-chalk-2);
              font-size: 0.85rem;
              line-height: 1.65;
              margin-bottom: 1.5rem;
            ">{desc}</p>

            <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
              {signals.map(sig => (
                <span key={sig} style="
                  font-family: var(--font-mono);
                  font-size: 0.6rem;
                  padding: 0.12rem 0.45rem;
                  border: 1px solid var(--color-edge-2);
                  border-radius: 2px;
                  color: var(--color-chalk-3);
                  letter-spacing: 0.06em;
                ">{sig}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Surface Console
  ────────────────────────────────────────────────────────── -->
  <section style="
    padding: 5rem var(--spacing-page);
    border-top: 1px solid var(--color-edge);
  ">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: start;
      ">
        <div>
          <div class="label-sm" style="margin-bottom: 1.5rem;">Surface Console</div>
          <h2 class="display-md" style="color: var(--color-chalk); margin-bottom: 1.25rem;">
            See trust state<br />
            where the work happens.
          </h2>
          <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.75; margin-bottom: 1.5rem;">
            <code style="font-family: var(--font-mono); font-size: 0.85rem; color: var(--color-gold); background: rgba(201,163,90,0.08); padding: 0.1rem 0.35rem; border-radius: 2px;">surface console</code> serves a live view from
            <code style="font-family: var(--font-mono); font-size: 0.82rem; color: var(--color-chalk-3);">.surface/runs/latest.json</code>.
            Each new run updates automatically. No cloud, no login.
          </p>

          <div style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem;">
            {[
              { label: 'Run history', body: 'Switch between past runs in the toolbar to compare claim state before and after a change.' },
              { label: 'Trust Panel', body: 'Open the viewer-facing trust state for a Claim without losing the operator context.' },
              { label: 'Filtered chips', body: 'Filter Verified, Attention, or total Claims instantly while reviewing the current Trust Snapshot.' },
              { label: 'Claim Groups', body: 'Start from a framework, checklist, or requirement set, then drill into the Claims and Evidence that decide its status.' },
              { label: 'Integrity scope', body: 'Inspect the source anchor, file fingerprints, and configuration hashes behind a verified claim.' },
              { label: 'Master-detail', body: 'On desktop, selecting a claim opens a sticky side panel without hiding the list.' },
              { label: 'Transparency gaps', body: 'When evidence is missing, private, stale, or conflicting, the gap stays visible beside the Claim.' },
            ].map(({ label, body }) => (
              <div key={label} style="
                display: flex;
                gap: 1rem;
                padding: 1rem 1.25rem;
                background: var(--color-ink-1);
                border: 1px solid var(--color-edge);
                border-radius: 4px;
              ">
                <div style="
                  font-family: var(--font-mono);
                  font-size: 0.7rem;
                  color: var(--color-gold);
                  min-width: 110px;
                  padding-top: 1px;
                ">{label}</div>
                <div style="font-size: 0.82rem; color: var(--color-chalk-3); line-height: 1.6;">{body}</div>
              </div>
            ))}
          </div>
        </div>

        <div class="terminal">
          <div class="terminal-bar">
            <div class="terminal-dot"></div>
            <div class="terminal-dot"></div>
            <div class="terminal-dot"></div>
            <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--color-chalk-3); margin-left: 0.5rem;">surface console</span>
          </div>
          <div class="terminal-body">
            <p><span class="prompt">$ </span><span class="cmd">npx surface console</span></p>
            <br />
            <p class="info">  Surface Console running at http://localhost:4242</p>
            <br />
            <p class="muted">  Reading: .surface/runs/latest.json</p>
            <p class="muted">  Source: latest Surface run snapshot</p>
            <br />
            <p class="muted">  GET /              200  console shell</p>
            <p class="muted">  GET /api/read-model  200  current trust snapshot</p>
            <p class="muted">  GET /api/runs        200  [run-a, run-b, run-c]</p>
            <br />
            <p style="color: var(--color-chalk-3);">  ───────────────────────────────</p>
            <p class="pass">  verified  8 claims</p>
            <p class="warn">  attention  2 claims</p>
            <p class="muted">  eval  accepted · confidence: high</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Products built with Surface
  ────────────────────────────────────────────────────────── -->
  <section style="
    padding: 5rem var(--spacing-page);
    border-top: 1px solid var(--color-edge);
    background: var(--color-ink-1);
  ">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 1rem;">Products built with Surface</div>
      <p style="
        color: var(--color-chalk-3);
        font-size: 0.9rem;
        line-height: 1.65;
        max-width: 640px;
        margin-bottom: 2.5rem;
      ">
        Products built with Surface keep their own workflow vocabulary while exposing
        Claims, Evidence, Policies, Trust Snapshots, and Transparency Gaps in a shared
        shape humans and agents can inspect.
      </p>

      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
      ">
        <div class="card" style="padding: 2rem; position: relative; overflow: hidden;">
          <div style="
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--color-green), transparent);
          "></div>

          <h3 style="
            font-family: var(--font-display);
            font-size: 1.5rem;
            font-weight: 400;
            color: var(--color-chalk);
            margin-bottom: 0.3rem;
            letter-spacing: -0.01em;
          ">Veritas</h3>

          <p style="
            font-family: var(--font-mono);
            font-size: 0.68rem;
            color: var(--color-green);
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 1rem;
          ">Merge autonomy for AI-authored code</p>

          <p style="
            color: var(--color-chalk-2);
            font-size: 0.85rem;
            line-height: 1.65;
            margin-bottom: 1.5rem;
          ">
            Turns Repo Standards, evidence checks, boundary crossings, and readiness
            outcomes into Surface-backed trust state. Veritas users stay in repo-native
            language while downstream systems can inspect the evidence behind merge readiness.
          </p>

          <a href="/veritas" style="
            font-family: var(--font-mono);
            font-size: 0.72rem;
            color: var(--color-green);
            text-decoration: none;
