---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
---

<Layout
  title="Surface — The trust substrate · Kontour AI"
  description="Kontour Surface is a portable shape for claims, evidence, freshness, and conflict — the foundation any provenance product can build on."
>
  <Nav active="surface" />

  <!-- ──────────────────────────────────────────────────────
       Hero
  ────────────────────────────────────────────────────────── -->
  <section class="contour-bg" style="
    padding: 10rem var(--spacing-page) 6rem;
    border-bottom: 1px solid var(--color-edge);
    position: relative;
    overflow: hidden;
  ">
    <!-- Gold glow -->
    <div style="
      position: absolute;
      top: -100px;
      left: -100px;
      width: 700px;
      height: 600px;
      background: radial-gradient(ellipse at top left, rgba(201,163,90,0.055) 0%, transparent 65%);
      pointer-events: none;
    "></div>

    <div style="max-width: 1280px; margin: 0 auto; position: relative; z-index: 1;">
      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
        align-items: start;
      ">
        <!-- Left -->
        <div>
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 2rem;">
            <span class="trust-badge trust-badge--verified">v0.2.0</span>
            <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--color-chalk-3);">npm install -D @kontourai/surface</span>
          </div>

          <h1 class="animate-fade-up" style="
            font-family: var(--font-display);
            font-optical-sizing: auto;
            font-size: clamp(3.5rem, 6vw, 5.5rem);
            font-weight: 400;
            line-height: 0.95;
            letter-spacing: -0.03em;
            color: var(--color-chalk);
            margin-bottom: 0.5rem;
          ">Surface</h1>

          <p class="animate-fade-up delay-100" style="
            font-family: var(--font-mono);
            font-size: 0.75rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--color-gold);
            margin-bottom: 2rem;
          ">The trust substrate · Show your work</p>

          <p class="animate-fade-up delay-200" style="
            font-size: 1.05rem;
            color: var(--color-chalk-2);
            line-height: 1.7;
            max-width: 460px;
            margin-bottom: 2.5rem;
          ">
            A portable shape for claims, the evidence behind them, the policies
            that decide what counts as verified, and the events that change a
            claim's status over time. The foundation any provenance product
            can build on.
          </p>

          <div class="animate-fade-up delay-300" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
            <a href="https://github.com/kontourai/surface" target="_blank" rel="noopener" class="btn-primary" data-umami-event="surface-hero-github">
              View on GitHub →
            </a>
            <a href="https://www.npmjs.com/package/@kontourai/surface" target="_blank" rel="noopener" class="btn-ghost" data-umami-event="surface-hero-npm">
              npm package
            </a>
          </div>
        </div>

        <!-- Right: Trust report output -->
        <div class="animate-fade-in delay-300">
          <div class="terminal">
            <div class="terminal-bar">
              <div class="terminal-dot"></div>
              <div class="terminal-dot"></div>
              <div class="terminal-dot"></div>
              <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--color-chalk-3); margin-left: 0.5rem;">surface report — summary</span>
            </div>
            <div class="terminal-body">
              <p><span class="prompt">$ </span><span class="cmd">npx surface report --input examples/surface-fixtures.json --format summary</span></p>
              <br />
              <p class="info">  Kontour Surface report surface-1777090239260</p>
              <p class="muted">  Source: kontour-surface-validation-fixtures</p>
              <br />
              <p>  Claims: <span class="pass">4</span> &nbsp;(unknown: 1, verified: 2, stale: 1)</p>
              <p class="muted">  Surfaces: repo-governance.developer-proof: 1, field-attested-records.public-data: 1,</p>
              <p class="muted">  &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; fact-resolution.financial-facts: 1, surface.roadmap: 1</p>
              <br />
              <p>  High-impact unsupported: <span class="pass">none</span></p>
              <p>  Stale: &nbsp;&nbsp;&nbsp;<span class="warn">claim.field-attested-records.registration-status</span></p>
              <p>  Disputed: <span class="pass">none</span></p>
              <p>  Fault lines: <span class="warn">3</span></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       What Surface answers
  ────────────────────────────────────────────────────────── -->
  <section style="padding: 6rem var(--spacing-page);">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 3rem;">What Surface answers</div>

      <div style="
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1rem;
      ">
        {[
          { q: 'What is the claim?', color: 'var(--color-chalk-2)' },
          { q: 'What evidence supports it?', color: 'var(--color-chalk-2)' },
          { q: 'Who or what verified it?', color: 'var(--color-chalk-2)' },
          { q: 'How was it verified?', color: 'var(--color-chalk-2)' },
          { q: 'How long is that verification valid?', color: 'var(--color-gold)' },
          { q: 'What is stale, unsupported, or disputed?', color: 'var(--color-gold)' },
          { q: 'What should an agent do before relying on it?', color: 'var(--color-red)' },
        ].map(({ q, color }, i) => (
          <div key={i} style="
            display: flex;
            align-items: flex-start;
            gap: 1rem;
            padding: 1.25rem;
            background: var(--color-ink-1);
            border: 1px solid var(--color-edge);
            border-radius: 4px;
          ">
            <span style={`
              font-family: var(--font-mono);
              font-size: 0.65rem;
              color: var(--color-chalk-3);
              padding-top: 2px;
              min-width: 1.5rem;
            `}>0{i + 1}</span>
            <span style={`
              font-size: 0.9rem;
              color: ${color};
              line-height: 1.5;
            `}>{q}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Trust vocabulary
  ────────────────────────────────────────────────────────── -->
  <section style="
    padding: 5rem var(--spacing-page);
    border-top: 1px solid var(--color-edge);
    border-bottom: 1px solid var(--color-edge);
    background: var(--color-ink-1);
  ">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 2.5rem;">Trust vocabulary</div>

      <div style="
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
      ">
        {[
          {
            term: 'Claim',
            def: 'The smallest trust-bearing unit. A statement about a subject — field, value, impact, and current integrity reference.',
            color: 'var(--color-cobalt-2)',
          },
          {
            term: 'Evidence',
            def: 'Why a claim deserves trust, plus the method: observation, validation, corroboration, attestation.',
            color: 'var(--color-green)',
          },
          {
            term: 'Policy',
            def: 'What makes a claim valid, and for how long. Freshness windows, required methods, commit-scoped validity.',
            color: 'var(--color-chalk-2)',
          },
          {
            term: 'Event',
            def: 'A verification, dispute, supersede, or rejection that changes a claim\'s status over time.',
            color: 'var(--color-cobalt-2)',
          },
          {
            term: 'Trust Status',
            def: 'Derived from claim, evidence, policy, and events: unknown, proposed, verified, stale, disputed, rejected, superseded.',
            color: 'var(--color-gold)',
          },
          {
            term: 'Fault Line',
            def: 'A discoverable conflict or gap across the input: provenance gaps, stale proof, missing corroboration, contradiction.',
            color: 'var(--color-red)',
          },
          {
            term: 'Trust Report',
            def: 'The portable output. Per-claim derived status, confidence basis, fault lines, proof requirements, and a summary.',
            color: 'var(--color-chalk)',
          },
          {
            term: 'Surface',
            def: 'The named region where a claim lives — a product area, a record type, a workflow step. Used for routing and ownership.',
            color: 'var(--color-chalk-2)',
          },
        ].map(({ term, def, color }) => (
          <div key={term} style="
            padding: 1.5rem;
            background: var(--color-ink-2);
            border: 1px solid var(--color-edge);
            border-radius: 6px;
          ">
            <div style={`
              font-family: var(--font-display);
              font-size: 1.15rem;
              font-weight: 400;
              color: ${color};
              margin-bottom: 0.6rem;
              letter-spacing: -0.01em;
            `}>{term}</div>
            <div style="
              font-size: 0.82rem;
              color: var(--color-chalk-3);
              line-height: 1.65;
            ">{def}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Trust status model
  ────────────────────────────────────────────────────────── -->
  <section style="padding: 5rem var(--spacing-page);">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 2.5rem;">Trust status model</div>

      <div style="
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1rem;
      ">
        {[
          { status: 'unknown',     badge: 'trust-badge--unknown',    label: 'No prior verification exists.' },
          { status: 'proposed',    badge: 'trust-badge--proposed',   label: 'Submitted but not yet verified.' },
          { status: 'verified',    badge: 'trust-badge--verified',   label: 'Evidence supports it. Currently valid.' },
          { status: 'stale',       badge: 'trust-badge--stale',      label: 'Was valid. Freshness window exceeded.' },
          { status: 'disputed',    badge: 'trust-badge--disputed',   label: 'Conflicting evidence or policy.' },
          { status: 'rejected',    badge: 'trust-badge--disputed',   label: 'Explicitly failed verification.' },
          { status: 'superseded',  badge: 'trust-badge--unknown',    label: 'Replaced by a newer verified claim.' },
        ].map(({ status, badge, label }) => (
          <div key={status} style="
            padding: 1.25rem;
            background: var(--color-ink-1);
            border: 1px solid var(--color-edge);
            border-radius: 4px;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
          ">
            <span class={`trust-badge ${badge}`}>
              <span style={`
                width: 5px;
                height: 5px;
                border-radius: 50%;
                display: inline-block;
                background: currentColor;
                ${status === 'stale' ? 'animation: pulse-dot 2s ease-in-out infinite;' : ''}
              `}></span>
              {status}
            </span>
            <p style="font-size: 0.78rem; color: var(--color-chalk-3); line-height: 1.5;">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Producer patterns
  ────────────────────────────────────────────────────────── -->
  <section style="
    padding: 5rem var(--spacing-page);
    border-top: 1px solid var(--color-edge);
  ">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 1rem;">Producer patterns</div>
      <p style="
        color: var(--color-chalk-3);
        font-size: 0.9rem;
        line-height: 1.65;
        max-width: 640px;
        margin-bottom: 2.5rem;
      ">
        Any system that needs to express claims, evidence, freshness, and conflict can build on Surface.
        Producers author claims in a committed file, collect evidence per run, and emit <code style="font-family: var(--font-mono); font-size: 0.82rem;">TrustInput</code> via the SDK.
      </p>

      <div style="
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
      ">
        {[
          {
            name: 'Field-Attested Records',
            subtitle: 'Public-data verification',
            desc: 'Crawls, attestations, review flags, and freshness. Claim that a record field is current, then show the source, timestamp, and review state before anyone relies on it.',
            signals: ['web crawl', 'attestation', 'review flag', 'freshness'],
            color: 'var(--color-cobalt-2)',
          },
          {
            name: 'Fact Resolution',
            subtitle: 'High-stakes fact verification',
            desc: 'Extraction, resolution, citations, and review signals. Verify that a value came from a specific source and decision trail.',
            signals: ['extraction', 'source ref', 'citation', 'review signal'],
            color: 'var(--color-gold)',
          },
          {
            name: 'Dependency Audit',
            subtitle: 'Security claim coverage',
            desc: 'Tool output from npm audit, Snyk, or similar maps to authored package-safety claims. Tool vendors can ship authoritative evidence importers as Veritas plugins.',
            signals: ['audit output', 'package range', 'severity', 'plugin'],
            color: 'var(--color-red)',
          },
        ].map(({ name, subtitle, desc, signals, color }) => (
          <div key={name} class="card" style="padding: 2rem; position: relative; overflow: hidden;">
            <div style={`
              position: absolute;
              bottom: 0;
              left: 0;
              right: 0;
              height: 2px;
              background: linear-gradient(90deg, ${color}, transparent);
            `}></div>

            <h3 style="
              font-family: var(--font-display);
              font-size: 1.5rem;
              font-weight: 400;
              color: var(--color-chalk);
              margin-bottom: 0.3rem;
              letter-spacing: -0.01em;
            ">{name}</h3>

            <p style={`
              font-family: var(--font-mono);
              font-size: 0.68rem;
              color: ${color};
              letter-spacing: 0.08em;
              text-transform: uppercase;
              margin-bottom: 1rem;
            `}>{subtitle}</p>

            <p style="
              color: var(--color-chalk-2);
              font-size: 0.85rem;
              line-height: 1.65;
              margin-bottom: 1.5rem;
            ">{desc}</p>

            <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
              {signals.map(sig => (
                <span key={sig} style="
                  font-family: var(--font-mono);
                  font-size: 0.6rem;
                  padding: 0.12rem 0.45rem;
                  border: 1px solid var(--color-edge-2);
                  border-radius: 2px;
                  color: var(--color-chalk-3);
                  letter-spacing: 0.06em;
                ">{sig}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Real consumers
  ────────────────────────────────────────────────────────── -->
  <section style="
    padding: 5rem var(--spacing-page);
    border-top: 1px solid var(--color-edge);
    background: var(--color-ink-1);
  ">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 1rem;">Real consumers</div>
      <p style="
        color: var(--color-chalk-3);
        font-size: 0.9rem;
        line-height: 1.65;
        max-width: 640px;
        margin-bottom: 2.5rem;
      ">
        Products that depend on Surface as their trust substrate. Each keeps its own
        workflow vocabulary; portable truth flows through Surface at the boundary.
      </p>

      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
      ">
        <div class="card" style="padding: 2rem; position: relative; overflow: hidden;">
          <div style="
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--color-green), transparent);
          "></div>

          <h3 style="
            font-family: var(--font-display);
            font-size: 1.5rem;
            font-weight: 400;
            color: var(--color-chalk);
            margin-bottom: 0.3rem;
            letter-spacing: -0.01em;
          ">Veritas</h3>

          <p style="
            font-family: var(--font-mono);
            font-size: 0.68rem;
            color: var(--color-green);
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 1rem;
          ">Repo lint for AI agents</p>

          <p style="
            color: var(--color-chalk-2);
            font-size: 0.85rem;
            line-height: 1.65;
            margin-bottom: 1.5rem;
          ">
            Projects every code-change run into <code style="font-family: var(--font-mono); font-size: 0.78rem; color: var(--color-green);">surface.input</code>
            so the same evidence the agent acted on can become a portable trust report
            downstream consumers can read.
          </p>

          <a href="/veritas" style="
            font-family: var(--font-mono);
            font-size: 0.72rem;
            color: var(--color-green);
            text-decoration: none;
          ">Explore Veritas →</a>
        </div>

        <div class="card" style="padding: 2rem; position: relative; overflow: hidden; opacity: 0.6;">
          <div style="
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--color-chalk-3), transparent);
          "></div>

          <h3 style="
            font-family: var(--font-display);
            font-size: 1.5rem;
            font-weight: 400;
            color: var(--color-chalk-2);
            margin-bottom: 0.3rem;
            letter-spacing: -0.01em;
          ">Your product</h3>

          <p style="
            font-family: var(--font-mono);
            font-size: 0.68rem;
            color: var(--color-chalk-3);
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 1rem;
          ">Anything that needs to show provenance</p>

          <p style="
            color: var(--color-chalk-3);
            font-size: 0.85rem;
            line-height: 1.65;
            margin-bottom: 1.5rem;
          ">
            Public-data records, fact resolution, audit pipelines, fitness tracking,
            tax filings, marketplace listings — anywhere you need to prove an
            assertion is verified, fresh, and uncontested.
          </p>

          <a href="https://github.com/kontourai/surface/tree/main/examples/external-adapter" target="_blank" rel="noopener" style="
            font-family: var(--font-mono);
            font-size: 0.72rem;
            color: var(--color-chalk-3);
            text-decoration: none;
          ">Build an adapter →</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  @media (max-width: 900px) {
    section > div > div[style*="grid-template-columns: 1fr 1fr"] {
      display: flex !important;
      flex-direction: column !important;
    }
    section > div > div[style*="grid-template-columns: repeat(3, 1fr)"] {
      display: flex !important;
      flex-direction: column !important;
    }
  }
</style>
