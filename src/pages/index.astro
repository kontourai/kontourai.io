---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import Section from '@/components/Section.astro';
import Glow from '@/components/Glow.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Grid from '@/components/Grid.astro';
import Split from '@/components/Split.astro';
import Terminal from '@/components/Terminal.astro';
import Subscribe from '@/components/Subscribe.astro';
import ProductMark from '@/components/ProductMark.astro';
import type { ProductMarkSlug } from '@/components/ProductMark.astro';
import type { Accent } from '@/lib/theme';

// Six products in layered order: trust foundation → evidence → process →
// readiness → agent discipline → operating plane.
// `job` describes what each product does on its own (the card grid);
// `relation` describes how it connects to its neighbours (the layer stack).
const productCards: {
  key: string;
  name: string;
  href: string;
  accent: Accent;
  job: string;
  relation: string;
}[] = [
  {
    key: 'surface',
    name: 'Surface',
    href: '/surface',
    accent: 'gold',
    job: 'One shape for claims, evidence, freshness, policies, and gaps — readable by a person, an agent, or another system.',
    relation: 'The foundation: every other product reads and writes its trust state as one Surface shape.',
  },
  {
    key: 'survey',
    name: 'Survey',
    href: '/survey',
    accent: 'gold-2',
    job: 'Turns sources, extractions, candidates, and reviews into Surface-ready claims with provenance attached.',
    relation: 'Feeds Surface — turning raw sources, extractions, and reviews into claims with provenance attached.',
  },
  {
    key: 'flow',
    name: 'Flow',
    href: '/flow',
    accent: 'cobalt-2',
    job: 'Shows why a process was allowed to advance — gate by gate, with the evidence behind each transition.',
    relation: 'Reads that evidence to gate work, advancing a process only when the proof for each step is there.',
  },
  {
    key: 'veritas',
    name: 'Veritas',
    href: '/veritas',
    accent: 'green',
    job: "Turns your repo's standards into evidence-backed readiness reports that agents and reviewers can rely on.",
    relation: 'Brings the same evidence to merge — readiness reports a reviewer or agent can act on.',
  },
  {
    key: 'flow-agents',
    name: 'Flow Agents',
    href: '/flow-agents',
    accent: 'chalk-2',
    job: 'Flow and Veritas discipline inside Claude Code, Codex, Kiro, and GitHub Actions — without becoming a runtime.',
    relation: 'Carries Flow and Veritas discipline into the agent tools you already run, without becoming a runtime.',
  },
  {
    key: 'console',
    name: 'Console',
    href: '/console',
    accent: 'cobalt',
    job: 'Claim status, process state, proof, queues, decisions, and next actions across all products in one operating plane.',
    relation: 'Sits over all of it — one operating plane for status, proof, queues, and decisions across the suite.',
  },
];
---

<Layout
  title="Kontour AI — Show the work behind AI"
  description="Kontour makes AI-assisted work inspectable — what was claimed, what supports it, which gates it passed, and what is still uncertain — so people and agents can decide what deserves trust before acting on it."
>
  <Nav active="home" />

  <!-- Hero ---------------------------------------------------------------- -->
  <Section contour size="cover">
    <Glow accent="gold" position="top-center" />

    <div class="container container--hero">
      <div class="hero-inner">
        <div class="animate-fade-up hero-kicker">
          <span class="label-sm">Kontour AI</span>
        </div>

        <h1 class="display-xl animate-fade-up delay-100 hero-title">
          Show the work<br />behind AI.
        </h1>

        <p class="lead measure animate-fade-up delay-200 hero-lead">
          Agents write code, run processes, and make claims faster than anyone
          can inspect by hand. Kontour shows what was claimed, what supports it,
          which gates it passed, and what's still uncertain — so people and
          agents can decide what deserves trust before they act.
        </p>

        <div class="animate-fade-up delay-300 hero-actions">
          <a href="/early-access/" class="btn-primary" data-umami-event="home-hero-early-access">Get early access →</a>
          <a href="https://github.com/kontourai" target="_blank" rel="noopener" class="btn-ghost" data-umami-event="home-hero-github">View on GitHub</a>
        </div>
      </div>
    </div>
  </Section>

  <!-- Product grid -------------------------------------------------------- -->
  <Section tone="alt" borderTop>
    <div class="container">
      <Eyebrow accent="gold">The product line</Eyebrow>
      <h2 class="display-md grid-title">
        Six products. One job.
      </h2>
      <p class="body measure grid-intro">
        Pull a finished product off the shelf or build on the open primitives
        underneath it. Either way, the trust state stays inspectable by people,
        agents, and systems downstream.
      </p>

      <Grid cols={3} gap="lg">
        {productCards.map(({ key, name, href, accent, job }) => (
          <a href={href} class="product-card" data-accent={accent} data-umami-event={`home-product-${key}`}>
            <div class="product-card__bar" data-accent={accent}></div>
            <div class="product-card__body">
              <div class="product-card__head">
                <span class="product-card__name" data-accent={accent}>
                  <ProductMark product={key as ProductMarkSlug} size={20} class="product-card__mark" data-accent={accent} />
                  {name}
                </span>
              </div>
              <p class="product-card__job">{job}</p>
              <span class="product-card__cta">Explore {name} →</span>
            </div>
          </a>
        ))}
      </Grid>
    </div>
  </Section>

  <!-- How it fits together ------------------------------------------------ -->
  <Section borderTop>
    <Glow accent="cobalt-2" position="top-left" />
    <div class="container">
      <Eyebrow accent="cobalt-2">How it fits together</Eyebrow>
      <h2 class="display-md layer-title">
        A layered stack. Each product shows<br />the work at its own level.
      </h2>
      <p class="body measure layer-intro">
        Surface is the trust foundation. Survey feeds it. Flow gates work.
        Veritas backs merge decisions. Flow Agents brings discipline into the
        tools you already use. Console makes the whole thing operable.
      </p>

      <div class="layer-stack" role="list" aria-label="Kontour product layer stack">
        {productCards.map(({ key, name, href, accent, relation }) => (
          <div class="layer-row" role="listitem">
            <div class="layer-row__accent-bar" data-accent={accent}></div>
            <div class="layer-row__inner">
              <div class="layer-row__left">
                <span class="layer-row__name" data-accent={accent}>{name}</span>
              </div>
              <p class="layer-row__job">{relation}</p>
              <a href={href} class="layer-row__link" data-accent={accent} data-umami-event={`home-layer-${key}`}>→</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- Terminal quickstart ------------------------------------------------- -->
  <Section tone="alt" borderTop borderBottom>
    <div class="container">
      <Split ratio="1-1" gap="lg" align="center">
        <div>
          <Eyebrow accent="gold">30-second taste</Eyebrow>
          <h2 class="display-md qs-title">Start with Surface.</h2>
          <p class="body qs-copy">
            Install the foundation, point it at a trust bundle, and get a
            snapshot of what's verified, stale, and missing — before anything
            acts on it.
          </p>
          <div class="qs-actions">
            <a href="/surface" class="btn-primary" data-umami-event="home-qs-surface">Surface docs →</a>
            <a href="/developers" class="btn-ghost" data-umami-event="home-qs-developers">Developer overview</a>
          </div>
        </div>

        <Terminal title="surface — first run">
          <p><span class="prompt">$ </span><span class="cmd">npm install -D @kontourai/surface</span></p>
          <br />
          <p><span class="prompt">$ </span><span class="cmd">npx surface report --format summary</span></p>
          <br />
          <p class="info">  Kontour Surface trust snapshot surface-1777090239260</p>
          <p class="muted">  Source: kontour-surface-validation-fixtures</p>
          <br />
          <p>  Claims: <span class="pass">4</span> &nbsp;(unknown: 1, verified: 2, stale: 1)</p>
          <p>  High-impact unsupported: <span class="pass">none</span></p>
          <p class="warn">  Stale: claim.field-attested-records.registration-status</p>
          <p>  Transparency gaps: <span class="warn">3</span></p>
          <br />
          <p class="rule">  ────────────────────────────────</p>
          <p class="pass">  verdict: current — recheck 1 claim before acting</p>
        </Terminal>
      </Split>
    </div>
  </Section>

  <!-- Promise ------------------------------------------------------------- -->
  <Section tone="alt">
    <div class="container container--readable promise">
      <Eyebrow accent="gold">The promise</Eyebrow>
      <h2 class="display-md promise__title">
        Evidence-backed confidence.<br />Not certainty theater.
      </h2>
      <p class="body measure promise__copy">
        AI can make any output look finished. Kontour shows the work behind it —
        the claim, the evidence, the required path, the gate decisions, and the
        gaps — so people and agents can tell what actually holds up before they
        act on it.
      </p>
    </div>
  </Section>

  <!-- CTA ----------------------------------------------------------------- -->
  <Section borderTop size="lg">
    <Glow accent="gold" position="top-center" />
    <div class="container container--readable cta">
      <Eyebrow accent="gold">Early access</Eyebrow>
      <h2 class="display-md cta__title">Tell us where trust breaks.</h2>
      <p class="body measure cta__copy">
        We're building in public. Drop your email for build updates and an early
        look — or start a focused design-partner conversation about the workflow
        you want to make inspectable.
      </p>
      <Subscribe source="home" cta="Get early access" event="home-subscribe" />
      <p class="cta__alt">
        Prefer to talk specifics? <a href="/early-access/" class="cta__alt-link" data-umami-event="home-cta-early-access">Start a design-partner thread →</a>
      </p>
    </div>
  </Section>

  <Footer active="home" />
</Layout>

<style>
  /* Hero ----------------------------------------------------------------- */
  .hero-inner {
    max-width: 760px;
  }
  .hero-kicker {
    margin-bottom: 2.25rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
  }
  .hero-kicker__sep {
    margin: 0 0.75rem;
    color: var(--color-edge-2);
  }
  .hero-kicker__v1 {
    color: var(--color-gold);
  }
  .hero-title {
    margin-bottom: 1.5rem;
  }
  .hero-lead {
    margin-bottom: 2.5rem;
  }
  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* Product grid --------------------------------------------------------- */
  .grid-title {
    margin-bottom: 1rem;
  }
  .grid-intro {
    margin-bottom: 3rem;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    background: var(--color-ink-2);
    border: 1px solid var(--color-edge);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.18s, background 0.18s;
  }
  .product-card:hover {
    border-color: var(--accent, var(--color-edge-2));
    background: var(--color-ink-3);
  }
  .product-card__bar {
    height: 3px;
    background: var(--accent, var(--color-edge));
    flex-shrink: 0;
  }
  .product-card__body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .product-card__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .product-card__name {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--accent, var(--color-chalk));
    letter-spacing: 0;
    line-height: 1.3;
  }
  .product-card__mark {
    flex-shrink: 0;
    /* Inherits the accent via currentColor from .product-card__name. */
  }
  .product-card__job {
    color: var(--color-chalk-2);
    font-size: 0.85rem;
    line-height: 1.65;
    flex: 1;
    margin-bottom: 1.25rem;
  }
  .product-card__cta {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--accent, var(--color-chalk-3));
    letter-spacing: 0;
    text-transform: uppercase;
    margin-top: auto;
  }

  /* Layer stack ---------------------------------------------------------- */
  .layer-title {
    margin-bottom: 1rem;
  }
  .layer-intro {
    margin-bottom: 3rem;
  }
  .layer-stack {
    border: 1px solid var(--color-edge);
    border-radius: 6px;
    overflow: hidden;
  }
  .layer-row {
    border-bottom: 1px solid var(--color-edge);
  }
  .layer-row:last-child {
    border-bottom: none;
  }
  .layer-row__accent-bar {
    height: 2px;
    background: var(--accent, var(--color-edge));
  }
  .layer-row__inner {
    display: grid;
    grid-template-columns: 9rem 1fr auto;
    gap: 1rem 1.5rem;
    align-items: center;
    padding: 1rem 1.5rem;
    background: var(--color-ink-2);
    transition: background 0.15s;
  }
  .layer-row:hover .layer-row__inner {
    background: var(--color-ink-3);
  }
  .layer-row__name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 400;
    color: var(--accent, var(--color-chalk));
    letter-spacing: 0;
    white-space: nowrap;
  }
  .layer-row__job {
    color: var(--color-chalk-3);
    font-size: 0.8rem;
    line-height: 1.6;
    margin: 0;
  }
  .layer-row__link {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--accent, var(--color-chalk-3));
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    transition: color 0.15s;
  }
  .layer-row__link:hover {
    color: var(--color-chalk);
  }

  @media (max-width: 600px) {
    .layer-row__inner {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
    }
    .layer-row__left {
      grid-column: 1;
      grid-row: 1;
    }
    .layer-row__link {
      grid-column: 2;
      grid-row: 1;
    }
    .layer-row__job {
      grid-column: 1 / -1;
      grid-row: 2;
    }
  }

  /* Quickstart ----------------------------------------------------------- */
  .qs-title {
    margin-bottom: 1rem;
  }
  .qs-copy {
    margin-bottom: 2rem;
  }
  .qs-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* Promise + CTA -------------------------------------------------------- */
  .promise {
    text-align: center;
  }
  .promise__title {
    margin-bottom: 1.25rem;
  }
  .promise__copy {
    margin: 0 auto;
  }

  .cta__title {
    margin-bottom: 1.25rem;
  }
  .cta__copy {
    margin-bottom: 2rem;
  }
  .cta__alt {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-chalk-3);
    margin-top: 1.5rem;
  }
  .cta__alt-link {
    color: var(--color-chalk-2);
    text-decoration: none;
  }
  .cta__alt-link:hover {
    color: var(--color-chalk);
  }
</style>
