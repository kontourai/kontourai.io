---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import Section from '@/components/Section.astro';
import Glow from '@/components/Glow.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import type { Accent } from '@/lib/theme';

const products: { name: string; accent: Accent; body: string }[] = [
  {
    name: 'Surface',
    accent: 'gold',
    body: "Makes claims inspectable. One shape for claims, evidence, freshness, policies, and gaps so the same trust state can be read by a person, an agent, or another system.",
  },
  {
    name: 'Survey',
    accent: 'gold-2',
    body: 'Makes the producer side of claims inspectable before Surface. Sources, extractions, candidates, and reviews become Surface-ready claims with provenance attached.',
  },
  {
    name: 'Flow',
    accent: 'cobalt-2',
    body: 'Makes required process paths inspectable. Flow shows why work was allowed to advance — gate by gate, with the evidence behind each transition.',
  },
  {
    name: 'Veritas',
    accent: 'green',
    body: "Makes code and change readiness inspectable. Veritas turns your repo's standards into evidence-backed readiness reports agents and reviewers can rely on.",
  },
  {
    name: 'Flow Agents',
    accent: 'chalk-2',
    body: 'Applies Flow and Veritas discipline inside the agent tools people already use: Claude Code, Codex, Kiro, and GitHub Actions.',
  },
  {
    name: 'Console',
    accent: 'cobalt',
    body: 'Makes the suite operable. Claim status, process state, proof, queues, decisions, and next actions across products in one place, without owning their semantics.',
  },
];
---

<Layout
  title="Kontour AI — Show the work behind AI"
  description="Kontour AI builds inspectability infrastructure for AI-assisted work."
>
  <Nav active="home" />

  <Section contour size="cover">
    <Glow accent="gold" position="top-center" />

    <div class="container container--hero">
      <div class="animate-fade-up hero-kicker">
        <span class="label-sm">Kontour AI</span>
        <span class="hero-kicker__sep">-</span>
        <span class="label-sm hero-kicker__live">Building in progress</span>
      </div>

      <h1 class="display-xl animate-fade-up delay-100 hero-title">
        Show the work<br />
        behind AI.
      </h1>

      <p class="lead measure animate-fade-up delay-200 hero-lead">
        Kontour AI builds inspectability infrastructure for AI-assisted work.
        Agents write code, run processes, and make claims faster than people
        can manually inspect. Kontour shows what was claimed, what supports it,
        which gates the work passed, and what's still uncertain — so people and
        agents can decide what deserves trust before acting on it.
      </p>

      <div class="animate-fade-up delay-300 hero-actions">
        <a href="https://github.com/kontourai" target="_blank" rel="noopener" class="btn-primary" data-umami-event="home-hero-github">Follow the build →</a>
        <a href="mailto:hello@kontourai.io" class="btn-ghost" data-umami-event="home-hero-contact">Get in touch</a>
      </div>
    </div>
  </Section>

  <Section tone="alt" borderTop>
    <div class="container container--narrow">
      <Eyebrow accent="gold">What we're building</Eyebrow>
      <h2 class="display-md build-title">
        One product line for showing the work behind AI.
      </h2>

      <div class="product-list">
        {products.map(({ name, accent, body }) => (
          <div class="product-row">
            <div class="product-row__name" data-accent={accent}>{name}</div>
            <p class="product-row__body">{body}</p>
          </div>
        ))}
      </div>

      <p class="build-note">
        Building in public. Follow along on GitHub as packages, consoles, and early previews ship.
      </p>
    </div>
  </Section>

  <Section tone="alt" borderTop>
    <div class="container container--readable promise">
      <Eyebrow accent="gold">The promise</Eyebrow>
      <h2 class="display-md promise__title">
        Evidence-backed confidence.<br />Not certainty theater.
      </h2>
      <p class="body measure promise__copy">
        AI can make any output look finished. Kontour shows the work behind it —
        the claim, the evidence, the required path, the gate decisions, and the
        gaps — so people and agents can tell what actually holds up before they
        act on it.
      </p>
    </div>
  </Section>

  <Footer active="home" />
</Layout>

<style>
  .hero-kicker {
    margin-bottom: 2.25rem;
  }
  .hero-kicker__sep {
    margin: 0 0.75rem;
    color: var(--color-edge-2);
  }
  .hero-kicker__live {
    color: var(--color-gold);
  }
  .hero-title {
    max-width: 980px;
    margin-bottom: 1.5rem;
  }
  .hero-lead {
    margin-bottom: 2.5rem;
  }
  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .build-title {
    margin-bottom: 2rem;
  }
  .product-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .product-row {
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: 1.5rem;
    align-items: baseline;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-edge);
  }
  .product-row__name {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--accent, var(--color-chalk));
    letter-spacing: 0;
  }
  .product-row__body {
    color: var(--color-chalk-2);
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0;
  }
  .build-note {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-chalk-3);
    letter-spacing: 0;
    margin: 0;
  }

  .promise {
    text-align: center;
  }
  .promise__title {
    margin-bottom: 1.25rem;
  }
  .promise__copy {
    margin: 0 auto;
  }

  @media (max-width: 600px) {
    .product-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
