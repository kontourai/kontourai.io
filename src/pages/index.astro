---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import Section from '@/components/Section.astro';
import Glow from '@/components/Glow.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Subscribe from '@/components/Subscribe.astro';
---

<Layout
  title="Kontour AI — Ship AI-built code you can stand behind"
  description="Flow Agents puts gates in the agent loop, so AI-built code earns its merge with evidence a human can check. Survey is the proof: real pipelines that turn raw sources into claims bound to what they stood on."
>
  <Nav active="home" />

  <!-- Hero: single Flow Agents headline ----------------------------------- -->
  <Section contour size="cover">
    <Glow accent="gold" position="top-center" />

    <div class="container container--hero">
      <div class="hero-inner">
        <div class="animate-fade-up hero-kicker">
          <span class="label-sm">Kontour · Flow Agents</span>
        </div>

        <h1 class="display-xl animate-fade-up delay-100 hero-title">
          Ship AI-built code<br />you can stand behind.
        </h1>

        <p class="lead measure animate-fade-up delay-200 hero-lead">
          AI agents write more code than anyone can review by hand. Flow Agents
          puts gates in the loop — every change has to earn its merge with
          evidence a human can check, not a model's say-so.
        </p>

        <div class="animate-fade-up delay-300 hero-actions">
          <a href="/early-access/" class="btn-primary" data-umami-event="home-hero-early-access">Get early access →</a>
          <a href="/flow-agents/" class="btn-ghost" data-umami-event="home-hero-flow-agents">How Flow Agents works</a>
          <a href="https://github.com/kontourai" target="_blank" rel="noopener" class="btn-ghost" data-umami-event="home-hero-github">View on GitHub</a>
        </div>
      </div>
    </div>
  </Section>

  <!-- Enforcement framing ------------------------------------------------- -->
  <Section tone="alt" borderTop>
    <Glow accent="cobalt-2" position="top-left" />
    <div class="container container--readable enforce">
      <Eyebrow accent="cobalt-2">Enforcement, not suggestion</Eyebrow>
      <h2 class="display-md enforce__title">
        Prompts are advice.<br />Gates are laws.
      </h2>
      <p class="body measure enforce__copy">
        A prompt asks an agent to be careful. A gate refuses to let work pass
        until the evidence is there. Flow Agents runs the plan → build → review →
        verify loop against gates an agent can't talk its way past — so "done"
        means checked, not claimed.
      </p>
      <div class="enforce__actions">
        <a href="/flow-agents/" class="btn-ghost" data-umami-event="home-enforce-flow-agents">See the Builder Kit loop →</a>
      </div>
    </div>
  </Section>

  <!-- Survey proof story (subordinate to the hero) ------------------------ -->
  <Section borderTop>
    <div class="container proof">
      <Eyebrow accent="gold">The proof</Eyebrow>
      <h2 class="display-md proof__title">
        Grounded claims, not confident guesses.
      </h2>
      <p class="body measure proof__copy">
        Flow Agents is the discipline; <strong>Survey</strong> is the receipts.
        Survey runs real pipelines — an outdoor-recreation directory and a
        document-heavy public-filing workflow — that turn raw sources into
        claims bound to their evidence, so every answer can show what it stood
        on instead of asking you to trust the tone.
      </p>

      <blockquote class="proof__pull">
        Memory tells the agent what it knows. Kontour proves what its answers
        stood on.
      </blockquote>

      <div class="proof__actions">
        <a href="/survey/" class="btn-ghost" data-umami-event="home-proof-survey">How Survey produces claims →</a>
      </div>
    </div>
  </Section>

  <!-- Promise ------------------------------------------------------------- -->
  <Section tone="alt" borderTop>
    <div class="container container--readable promise">
      <Eyebrow accent="gold">The promise</Eyebrow>
      <h2 class="display-md promise__title">
        Evidence-backed confidence.<br />Not certainty theater.
      </h2>
      <p class="body measure promise__copy">
        We can't certify that an agent is right — no one can. What Kontour does
        is make what an answer stood on, and what it skipped, visible and
        attributable instead of hidden behind a green checkmark.
      </p>
    </div>
  </Section>

  <!-- CTA ----------------------------------------------------------------- -->
  <Section borderTop size="lg">
    <Glow accent="gold" position="top-center" />
    <div class="container container--readable cta">
      <Eyebrow accent="gold">Early access</Eyebrow>
      <h2 class="display-md cta__title">Tell us where trust breaks.</h2>
      <p class="body measure cta__copy">
        We're building in public. Drop your email for build updates and an early
        look — or start a focused design-partner conversation about the workflow
        you want to make inspectable.
      </p>
      <Subscribe source="home" cta="Get early access" event="home-subscribe" />
      <p class="cta__alt">
        Want the architecture tour? Six products, one job — on the
        <a href="/developers/" class="cta__alt-link" data-umami-event="home-cta-developers">developers page →</a>
      </p>
    </div>
  </Section>

  <Footer active="home" />
</Layout>

<style>
  /* Hero ----------------------------------------------------------------- */
  .hero-inner {
    max-width: 760px;
  }
  .hero-kicker {
    margin-bottom: 2.25rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
  }
  .hero-title {
    margin-bottom: 1.5rem;
  }
  .hero-lead {
    margin-bottom: 2.5rem;
  }
  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* Enforcement ---------------------------------------------------------- */
  .enforce__title {
    margin-bottom: 1.25rem;
  }
  .enforce__copy {
    margin-bottom: 2rem;
  }
  .enforce__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* Survey proof --------------------------------------------------------- */
  .proof__title {
    margin-bottom: 1.25rem;
  }
  .proof__copy {
    margin-bottom: 2rem;
  }
  .proof__copy strong {
    color: var(--color-chalk);
    font-weight: 500;
  }
  .proof__pull {
    margin: 0 0 2rem;
    padding: 1.1rem 1.5rem;
    border-left: 3px solid var(--color-gold);
    background: var(--color-ink-2);
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1.5;
    color: var(--color-chalk);
    max-width: 680px;
  }
  .proof__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* Promise + CTA -------------------------------------------------------- */
  .promise {
    text-align: center;
  }
  .promise__title {
    margin-bottom: 1.25rem;
  }
  .promise__copy {
    margin: 0 auto;
  }

  .cta__title {
    margin-bottom: 1.25rem;
  }
  .cta__copy {
    margin-bottom: 2rem;
  }
  .cta__alt {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-chalk-3);
    margin-top: 1.5rem;
  }
  .cta__alt-link {
    color: var(--color-chalk-2);
    text-decoration: none;
  }
  .cta__alt-link:hover {
    color: var(--color-chalk);
  }
</style>
