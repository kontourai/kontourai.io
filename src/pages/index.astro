---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import Section from '@/components/Section.astro';
import Glow from '@/components/Glow.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Card from '@/components/Card.astro';
import Grid from '@/components/Grid.astro';
import Split from '@/components/Split.astro';
import Subscribe from '@/components/Subscribe.astro';
import type { Accent } from '@/lib/theme';

// The hero "trust snapshot" — what an end user actually sees before relying on
// an answer: each claim, its current status, and when it was last checked.
const snapshot: { name: string; desc: string; status: string; badge: string; checked: string; pulse?: boolean }[] = [
  { name: 'Listing is available', desc: 'The slot still shows open in the provider’s live calendar.', status: 'verified', badge: 'trust-badge--verified', checked: 'checked 2m ago' },
  { name: 'License is active', desc: 'State board lists license #A-4471 active, no disciplinary flags.', status: 'verified', badge: 'trust-badge--verified', checked: 'checked 1h ago' },
  { name: 'Price matches the source', desc: 'The quoted $149 matches the provider’s published rate card.', status: 'stale', badge: 'trust-badge--stale', checked: 'checked 9d ago', pulse: true },
  { name: 'Identity confirmed', desc: 'Business name and address match the state registration record.', status: 'unverified', badge: 'trust-badge--unknown', checked: 'not checked yet' },
];

// Off-the-shelf products: built on the primitives, usable today.
const products: { name: string; label: string; accent: Accent; body: string }[] = [
  {
    name: 'Veritas',
    label: 'Ships today · npm',
    accent: 'green',
    body: "Merge autonomy for AI-authored code. Turns your repo's standards into evidence-backed readiness reports that agents and reviewers can rely on — with just-in-time guidance while the work happens.",
  },
  {
    name: 'Flow Agents',
    label: 'Ships today · install',
    accent: 'chalk-2',
    body: 'Workflow discipline inside the agent tools you already use — Claude Code, Codex, Kiro, GitHub Actions. Durable plans, review, verification, and release evidence that survive compaction and handoffs.',
  },
];

// Primitives: the open shapes builders compose into their own products.
const primitives: { name: string; accent: Accent; body: string }[] = [
  {
    name: 'Surface',
    accent: 'gold',
    body: 'One shape for claims, evidence, freshness, policies, and gaps — so the same trust state can be read by a person, an agent, or another system.',
  },
  {
    name: 'Flow',
    accent: 'cobalt-2',
    body: 'Process transparency for required-path work. Shows why work was allowed to advance, gate by gate, with the evidence behind each transition.',
  },
  {
    name: 'Survey',
    accent: 'gold-2',
    body: 'The producer side of claims. Turns sources, extractions, candidates, and reviews into Surface-ready claims with provenance attached.',
  },
];
---

<Layout
  title="Kontour AI — Show the work behind AI"
  description="Show the work behind AI. Kontour makes AI-assisted work inspectable — what was claimed, what supports it, which gates it passed, and what is still uncertain — so people and agents can decide what deserves trust before acting on it."
>
  <Nav active="home" />

  <Section contour size="cover">
    <Glow accent="gold" position="top-center" />

    <div class="container container--hero">
      <Split ratio="1-1" gap="lg" align="center">
        <div>
          <div class="animate-fade-up hero-kicker">
            <span class="label-sm">Kontour AI</span>
            <span class="hero-kicker__sep">-</span>
            <span class="label-sm hero-kicker__live">Building in progress</span>
          </div>

          <h1 class="display-xl animate-fade-up delay-100 hero-title">
            Show the work<br />
            behind AI.
          </h1>

          <p class="lead measure animate-fade-up delay-200 hero-lead">
            Agents write code, run processes, and make claims faster than anyone
            can inspect by hand. Kontour shows what was claimed, what supports it,
            which gates it passed, and what's still uncertain — so people and
            agents can decide what deserves trust before they act.
          </p>

          <div class="animate-fade-up delay-300 hero-actions">
            <a href="/early-access/" class="btn-primary" data-umami-event="home-hero-early-access">Get early access →</a>
            <a href="https://github.com/kontourai" target="_blank" rel="noopener" class="btn-ghost" data-umami-event="home-hero-github">Follow the build</a>
          </div>
        </div>

        <div class="snapshot card-elevated animate-fade-in delay-300" role="group" aria-label="Example Kontour trust snapshot">
          <div class="snapshot__bar">
            <span class="snapshot__title">trust snapshot</span>
            <span class="snapshot__meta">as of just now</span>
          </div>
          <div class="snapshot__rows">
            {snapshot.map(({ name, desc, status, badge, checked, pulse }) => (
              <div class="snapshot__row">
                <div class="snapshot__claim">
                  <span class="snapshot__name">{name}</span>
                  <span class="snapshot__desc">{desc}</span>
                </div>
                <span class="snapshot__checked">{checked}</span>
                <span class={`trust-badge ${badge}`}>
                  <span class="snapshot__dot" data-pulse={pulse}></span>
                  {status}
                </span>
              </div>
            ))}
          </div>
          <div class="snapshot__verdict">
            <span class="snapshot__verdict-key">now</span>
            <span class="snapshot__verdict-val">Current — recheck 1 claim before you rely on it</span>
          </div>
        </div>
      </Split>
    </div>
  </Section>

  <Section tone="alt" borderTop>
    <div class="container">
      <Eyebrow accent="gold">What we're building</Eyebrow>
      <h2 class="display-md build-title">
        Two layers. One job:<br />show the work behind AI.
      </h2>
      <p class="body measure build-intro">
        Pull a finished product off the shelf, or build on the open primitives
        underneath it. Either way, the trust state stays inspectable by people,
        agents, and the systems downstream.
      </p>

      <div class="layer">
        <Eyebrow accent="green" gap="lg">Products you can use today</Eyebrow>
        <Grid cols={2} gap="lg">
          {products.map(({ name, label, accent, body }) => (
            <Card accent={accent} bar="top" pad="lg">
              <div class="feature-label" data-accent={accent}>{label}</div>
              <h3 class="product-card__name">{name}</h3>
              <p class="product-card__body">{body}</p>
            </Card>
          ))}
        </Grid>
      </div>

      <div class="layer">
        <Eyebrow accent="gold" gap="lg">Primitives to build on</Eyebrow>
        <Grid cols={3} gap="lg">
          {primitives.map(({ name, accent, body }) => (
            <Card accent={accent} bar="top" pad="md">
              <h3 class="primitive-card__name" data-accent={accent}>{name}</h3>
              <p class="feature-body">{body}</p>
            </Card>
          ))}
        </Grid>
      </div>

      <Card accent="cobalt" bar="top" pad="lg" class="console-row">
        <div class="console-row__inner">
          <div>
            <div class="feature-label" data-accent="cobalt">Over the suite</div>
            <h3 class="product-card__name">Console</h3>
          </div>
          <p class="console-row__body">
            Console sits above the primitives — one place to visualize and manage
            claim status, process state, proof, queues, decisions, and next actions
            across every product, without owning their semantics.
          </p>
        </div>
      </Card>
    </div>
  </Section>

  <Section tone="alt" borderTop>
    <div class="container container--readable promise">
      <Eyebrow accent="gold">The promise</Eyebrow>
      <h2 class="display-md promise__title">
        Evidence-backed confidence.<br />Not certainty theater.
      </h2>
      <p class="body measure promise__copy">
        AI can make any output look finished. Kontour shows the work behind it —
        the claim, the evidence, the required path, the gate decisions, and the
        gaps — so people and agents can tell what actually holds up before they
        act on it.
      </p>
    </div>
  </Section>

  <Section borderTop size="lg">
    <Glow accent="gold" position="top-center" />
    <div class="container container--readable cta">
      <Eyebrow accent="gold">Early access</Eyebrow>
      <h2 class="display-md cta__title">Tell us where trust breaks.</h2>
      <p class="body measure cta__copy">
        We're building in public. Drop your email for build updates and an early
        look — or start a focused design-partner conversation about the workflow
        you want to make inspectable.
      </p>
      <Subscribe source="home" cta="Get early access" event="home-subscribe" />
      <p class="cta__alt">
        Prefer to talk specifics? <a href="/early-access/" class="cta__alt-link" data-umami-event="home-cta-early-access">Start a design-partner thread →</a>
      </p>
    </div>
  </Section>

  <Footer active="home" />
</Layout>

<style>
  .hero-kicker {
    margin-bottom: 2.25rem;
  }
  .hero-kicker__sep {
    margin: 0 0.75rem;
    color: var(--color-edge-2);
  }
  .hero-kicker__live {
    color: var(--color-gold);
  }
  .hero-title {
    margin-bottom: 1.5rem;
  }
  .hero-lead {
    margin-bottom: 2.5rem;
  }
  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* Hero trust snapshot ------------------------------------------------ */
  .snapshot {
    padding: 0;
    overflow: hidden;
  }
  .snapshot__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid var(--color-edge);
    background: var(--color-ink-1);
  }
  .snapshot__title {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--color-chalk-2);
  }
  .snapshot__meta {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--color-chalk-3);
  }
  .snapshot__rows {
    display: flex;
    flex-direction: column;
  }
  .snapshot__row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 0.5rem 1rem;
    align-items: start;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid var(--color-edge);
  }
  .snapshot__claim {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }
  .snapshot__name {
    font-size: 0.82rem;
    color: var(--color-chalk-2);
    line-height: 1.4;
  }
  .snapshot__desc {
    font-size: 0.68rem;
    color: var(--color-chalk-3);
    line-height: 1.45;
  }
  .snapshot__checked {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0;
    color: var(--color-chalk-3);
    white-space: nowrap;
    padding-top: 2px;
  }
  .snapshot__dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    display: inline-block;
    background: currentColor;
  }
  .snapshot__dot[data-pulse] {
    animation: pulse-dot 2s ease-in-out infinite;
  }
  .snapshot__verdict {
    display: flex;
    gap: 0.85rem;
    align-items: baseline;
    padding: 0.95rem 1.25rem;
    background: var(--color-ink-1);
  }
  .snapshot__verdict-key {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    color: var(--color-gold);
  }
  .snapshot__verdict-val {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-chalk-2);
    line-height: 1.5;
  }

  @media (max-width: 560px) {
    .snapshot__row {
      grid-template-columns: 1fr auto;
    }
    .snapshot__checked {
      display: none;
    }
  }

  /* Product / primitive layers ---------------------------------------- */
  .build-title {
    margin-bottom: 1.25rem;
  }
  .build-intro {
    margin-bottom: 3.5rem;
  }
  .layer {
    margin-bottom: 3.5rem;
  }
  .product-card__name {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--color-chalk);
    letter-spacing: 0;
    margin-bottom: 0.85rem;
  }
  .product-card__body {
    color: var(--color-chalk-2);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  .primitive-card__name {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--accent, var(--color-chalk));
    letter-spacing: 0;
    margin-bottom: 0.75rem;
  }
  .console-row__inner {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: 1.5rem;
    align-items: center;
  }
  .console-row__body {
    color: var(--color-chalk-2);
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0;
  }
  @media (max-width: 700px) {
    .console-row__inner {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
  }

  /* Promise + CTA ------------------------------------------------------ */
  .promise {
    text-align: center;
  }
  .promise__title {
    margin-bottom: 1.25rem;
  }
  .promise__copy {
    margin: 0 auto;
  }

  .cta__title {
    margin-bottom: 1.25rem;
  }
  .cta__copy {
    margin-bottom: 2rem;
  }
  .cta__alt {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-chalk-3);
    margin-top: 1.5rem;
  }
  .cta__alt-link {
    color: var(--color-chalk-2);
    text-decoration: none;
  }
  .cta__alt-link:hover {
    color: var(--color-chalk);
  }
</style>
