---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import Section from '@/components/Section.astro';
import Glow from '@/components/Glow.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import type { Accent } from '@/lib/theme';

const products: { name: string; accent: Accent; body: string }[] = [
  {
    name: 'Surface',
    accent: 'gold',
    body: "The shared transparency foundation under our products. One shape for claims, evidence, freshness, and gaps.",
  },
  {
    name: 'Survey',
    accent: 'gold-2',
    body: 'Producer-side trust for Surface. Turns sources, extractions, candidates, and reviews into Surface-ready claims with provenance attached.',
  },
  {
    name: 'Flow',
    accent: 'cobalt-2',
    body: 'Process transparency for any required-path work. Why work was allowed to advance — gate by gate, with the evidence behind each transition.',
  },
  {
    name: 'Veritas',
    accent: 'green',
    body: "Merge autonomy for AI-authored code. Your repo's standards turned into evidence-backed readiness reports agents and reviewers can rely on.",
  },
  {
    name: 'Flow Agents',
    accent: 'chalk-2',
    body: 'Keeping coding agents on the required path across Claude Code, Codex, Kiro, and GitHub Actions.',
  },
  {
    name: 'Console',
    accent: 'cobalt',
    body: 'The suite-level operating plane. Claim status, process state, proof, queues, decisions, and next actions from every Kontour product in one place.',
  },
];
---

<Layout
  title="Kontour AI — Show the work behind AI"
  description="Kontour AI shows the work behind AI."
>
  <Nav active="home" />

  <Section contour size="cover">
    <Glow accent="gold" position="top-center" />

    <div class="container container--hero">
      <div class="animate-fade-up hero-kicker">
        <span class="label-sm">Kontour AI</span>
        <span class="hero-kicker__sep">-</span>
        <span class="label-sm hero-kicker__live">Building in progress</span>
      </div>

      <h1 class="display-xl animate-fade-up delay-100 hero-title">
        Show the work<br />
        behind AI.
      </h1>

      <p class="lead measure animate-fade-up delay-200 hero-lead">
        Agents write code, run processes, and make claims faster than people
        can review them. Kontour AI is building the products that show what
        was claimed, what supports it, which gates the work passed, and
        what's still uncertain — so anyone can decide whether the work
        deserves trust before acting on it.
      </p>

      <div class="animate-fade-up delay-300 hero-actions">
        <a href="https://github.com/kontourai" target="_blank" rel="noopener" class="btn-primary" data-umami-event="home-hero-github">Follow the build →</a>
        <a href="mailto:hello@kontourai.io" class="btn-ghost" data-umami-event="home-hero-contact">Get in touch</a>
      </div>
    </div>
  </Section>

  <Section tone="alt" borderTop>
    <div class="container container--narrow">
      <Eyebrow accent="gold">What we're building</Eyebrow>
      <h2 class="display-md build-title">
        Six products. One shared promise: show the work behind every step AI takes.
      </h2>

      <div class="product-list">
        {products.map(({ name, accent, body }) => (
          <div class="product-row">
            <div class="product-row__name" data-accent={accent}>{name}</div>
            <p class="product-row__body">{body}</p>
          </div>
        ))}
      </div>

      <p class="build-note">
        Building in public. Follow along on GitHub for updates as each product ships.
      </p>
    </div>
  </Section>

  <Section tone="alt" borderTop>
    <div class="container container--readable promise">
      <Eyebrow accent="gold">The promise</Eyebrow>
      <h2 class="display-md promise__title">
        Evidence-backed confidence.<br />Not certainty theater.
      </h2>
      <p class="body measure promise__copy">
        AI can make any output look finished. Kontour shows the work behind it —
        the claim, the evidence, and the gaps — so people and agents can tell
        what actually holds up before they act on it.
      </p>
    </div>
  </Section>

  <Footer active="home" />
</Layout>

<style>
  .hero-kicker {
    margin-bottom: 2.25rem;
  }
  .hero-kicker__sep {
    margin: 0 0.75rem;
    color: var(--color-edge-2);
  }
  .hero-kicker__live {
    color: var(--color-gold);
  }
  .hero-title {
    max-width: 980px;
    margin-bottom: 1.5rem;
  }
  .hero-lead {
    margin-bottom: 2.5rem;
  }
  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .build-title {
    margin-bottom: 2rem;
  }
  .product-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .product-row {
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: 1.5rem;
    align-items: baseline;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-edge);
  }
  .product-row__name {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--accent, var(--color-chalk));
    letter-spacing: 0;
  }
  .product-row__body {
    color: var(--color-chalk-2);
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0;
  }
  .build-note {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-chalk-3);
    letter-spacing: 0;
    margin: 0;
  }

  .promise {
    text-align: center;
  }
  .promise__title {
    margin-bottom: 1.25rem;
  }
  .promise__copy {
    margin: 0 auto;
  }

  @media (max-width: 600px) {
    .product-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
