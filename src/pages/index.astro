---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
---

<Layout
  title="Kontour AI — Show the work behind AI"
  description="Kontour AI shows the work behind AI."
>
  <Nav active="home" />

  <section class="contour-bg" style="
    position: relative;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 8rem var(--spacing-page) 5rem;
    overflow: hidden;
  ">
    <div style="
      position: absolute;
      top: 14%;
      left: 50%;
      transform: translateX(-50%);
      width: 900px;
      height: 620px;
      background: radial-gradient(ellipse at center, rgba(201,163,90,0.045) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    "></div>

    <div style="max-width: 1180px; margin: 0 auto; width: 100%; position: relative; z-index: 1;">
      <div class="animate-fade-up" style="margin-bottom: 2.25rem;">
        <span class="label-sm">Kontour AI</span>
        <span style="margin: 0 0.75rem; color: var(--color-edge-2);">-</span>
        <span class="label-sm" style="color: var(--color-gold);">Building in progress</span>
      </div>

      <h1 class="display-xl animate-fade-up delay-100" style="
        max-width: 980px;
        color: var(--color-chalk);
        margin-bottom: 1.5rem;
      ">
        Show the work<br />
        behind AI.
      </h1>

      <p class="animate-fade-up delay-200" style="
        font-family: var(--font-sans);
        font-size: clamp(1rem, 1.8vw, 1.2rem);
        color: var(--color-chalk-2);
        max-width: 680px;
        line-height: 1.7;
        margin-bottom: 2.5rem;
        font-weight: 400;
      ">
        Agents write code, run processes, and make claims faster than people
        can review them. Kontour AI is building the products that show what
        was claimed, what supports it, which gates the work passed, and
        what's still uncertain - so anyone can decide whether the work
        deserves trust before acting on it.
      </p>

      <div class="animate-fade-up delay-300" style="display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center;">
        <a href="https://github.com/kontourai" target="_blank" rel="noopener" class="btn-primary" data-umami-event="home-hero-github">Follow the build -></a>
        <a href="mailto:hello@kontour.ai" class="btn-ghost" data-umami-event="home-hero-contact">Get in touch</a>
      </div>
    </div>
  </section>

  <section style="
    padding: 5rem var(--spacing-page);
    border-top: 1px solid var(--color-edge);
    background: var(--color-ink-1);
  ">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="max-width: 720px; margin-bottom: 3rem;">
        <div class="label-sm" style="margin-bottom: 1rem; color: var(--color-gold);">Four products. One shared promise.</div>
        <h2 class="display-md" style="color: var(--color-chalk); margin-bottom: 1rem;">
          Surface and Flow are the substrates. Veritas and Flow Agents are the AI-specific products built on top.
        </h2>
      </div>

      <div style="
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
      ">
        {[
          {
            href: '/surface',
            name: 'Surface',
            badge: 'v0.4',
            color: 'var(--color-gold)',
            body: "The shared foundation under Kontour's products. One shape for claims, evidence, freshness, and gaps so the same trust state can be read by a person, an agent, or another system.",
          },
          {
            href: '/flow',
            name: 'Flow',
            badge: 'v0.1',
            color: 'var(--color-cobalt-2)',
            body: 'Process transparency for any required-path work. Flow shows why a process was allowed to move forward - gate by gate, with the evidence behind each transition.',
          },
          {
            href: '/veritas',
            name: 'Veritas',
            badge: 'v0.4',
            color: 'var(--color-green)',
            body: "Merge autonomy for AI-authored code. Veritas turns your repo's standards into evidence-backed readiness reports the agent reads back.",
          },
          {
            href: '/flow-agents',
            name: 'Flow Agents',
            badge: 'coming soon',
            color: 'var(--color-chalk-2)',
            body: 'Keep your coding agent on the required path across Claude Code, Codex, Kiro, and GitHub Actions. Flow Agents brings Flow-backed workflows and Kontour evidence into the agent tools you already use.',
          },
        ].map(({ href, name, badge, color, body }) => (
          <a href={href} class="card" style="padding: 1.5rem; text-decoration: none; position: relative; overflow: hidden;">
            <div style={`
              position: absolute;
              top: 0;
              left: 0;
              right: 0;
              height: 2px;
              background: linear-gradient(90deg, ${color}, transparent);
            `}></div>
            <div style="display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; margin-bottom: 1.25rem;">
              <h3 style="
                font-family: var(--font-display);
                font-size: 1.45rem;
                font-weight: 400;
                color: var(--color-chalk);
                margin: 0;
              ">{name}</h3>
              <span class="trust-badge trust-badge--proposed">{badge}</span>
            </div>
            <p style="color: var(--color-chalk-2); font-size: 0.86rem; line-height: 1.65; margin: 0;">{body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section style="
    padding: 5rem var(--spacing-page);
    border-top: 1px solid var(--color-edge);
    background: var(--color-ink-1);
  ">
    <div style="max-width: 980px; margin: 0 auto; text-align: center;">
      <div class="label-sm" style="margin-bottom: 1.5rem; color: var(--color-gold);">Early signal</div>
      <h2 class="display-md" style="color: var(--color-chalk); margin-bottom: 1.25rem;">
        Evidence-backed confidence.<br />Not certainty theater.
      </h2>
      <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.75; margin: 0 auto; max-width: 640px;">
        We are still shaping the product line. The public promise is intentionally
        simple for now: make AI-era work more inspectable before people rely on it.
      </p>
    </div>
  </section>

  <Footer active="home" />
</Layout>

<style>
  @media (max-width: 1000px) {
    section div[style*="grid-template-columns: repeat(4"] {
      display: grid !important;
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }

  @media (max-width: 640px) {
    section div[style*="grid-template-columns: repeat(4"] {
      display: flex !important;
      flex-direction: column !important;
    }
  }
</style>
