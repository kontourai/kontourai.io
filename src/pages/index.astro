---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
---

<Layout
  title="Kontour AI — Trust infrastructure for AI-era products"
  description="Kontour AI maps what your product claims, what proves it, where trust is missing or stale, and what needs verification next."
>
  <Nav active="home" />

  <!-- ──────────────────────────────────────────────────────
       Hero
  ────────────────────────────────────────────────────────── -->
  <section class="contour-bg" style="
    position: relative;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 8rem var(--spacing-page) 6rem;
    overflow: hidden;
  ">
    <!-- Radial glow -->
    <div style="
      position: absolute;
      top: 20%;
      left: 50%;
      transform: translateX(-50%);
      width: 900px;
      height: 600px;
      background: radial-gradient(ellipse at center, rgba(201,163,90,0.04) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    "></div>

    <!-- Content -->
    <div style="max-width: 1280px; margin: 0 auto; width: 100%; position: relative; z-index: 1;">
      <!-- Eye-brow label -->
      <div class="animate-fade-up" style="margin-bottom: 2.5rem;">
        <span class="label-sm">Trust Infrastructure</span>
        <span style="margin: 0 0.75rem; color: var(--color-edge-2);">—</span>
        <span class="label-sm" style="color: var(--color-chalk-3);">Open source</span>
      </div>

      <!-- Headline -->
      <h1 class="display-xl animate-fade-up delay-100" style="
        max-width: 900px;
        color: var(--color-chalk);
        margin-bottom: 1.5rem;
      ">
        Map what your<br />
        product <em style="color: var(--color-gold); font-style: italic;">claims</em>.<br />
        Prove it.
      </h1>

      <!-- Sub -->
      <p class="animate-fade-up delay-200" style="
        font-family: var(--font-sans);
        font-size: clamp(1rem, 1.8vw, 1.2rem);
        color: var(--color-chalk-2);
        max-width: 520px;
        line-height: 1.65;
        margin-bottom: 2.5rem;
        font-weight: 400;
      ">
        AI increases the volume and polish of product claims.
        Kontour makes the evidence inspectable — what's verified,
        what's stale, and what still needs proof.
      </p>

      <!-- CTA -->
      <div class="animate-fade-up delay-300" style="display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center;">
        <a href="/veritas" class="btn-primary" data-umami-event="home-hero-explore-veritas">Explore Veritas →</a>
        <a href="/surface" class="btn-ghost" data-umami-event="home-hero-explore-surface">Explore Surface</a>
      </div>

      <!-- Trust state strip -->
      <div class="animate-fade-in delay-500" style="
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
        margin-top: 4rem;
        padding-top: 2.5rem;
        border-top: 1px solid var(--color-edge);
      ">
        <span class="trust-badge trust-badge--verified">
          <span style="width: 5px; height: 5px; border-radius: 50%; background: var(--color-green); display: inline-block;"></span>
          verified
        </span>
        <span class="trust-badge trust-badge--proposed">
          <span style="width: 5px; height: 5px; border-radius: 50%; background: var(--color-cobalt-2); display: inline-block;"></span>
          proposed
        </span>
        <span class="trust-badge trust-badge--stale">
          <span style="width: 5px; height: 5px; border-radius: 50%; background: var(--color-gold); display: inline-block; animation: pulse-dot 2s ease-in-out infinite;"></span>
          stale
        </span>
        <span class="trust-badge trust-badge--disputed">
          <span style="width: 5px; height: 5px; border-radius: 50%; background: var(--color-red); display: inline-block;"></span>
          disputed
        </span>
        <span class="trust-badge trust-badge--unknown">
          <span style="width: 5px; height: 5px; border-radius: 50%; background: var(--color-chalk-3); display: inline-block;"></span>
          unknown
        </span>
        <span style="
          font-family: var(--font-mono);
          font-size: 0.65rem;
          color: var(--color-chalk-3);
          display: flex;
          align-items: center;
          margin-left: 0.25rem;
        ">— every claim has a state</span>
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Problem / Signal
  ────────────────────────────────────────────────────────── -->
  <section style="padding: 6rem var(--spacing-page); border-top: 1px solid var(--color-edge);">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
      ">
        <!-- Left: text -->
        <div>
          <div class="label-sm" style="margin-bottom: 1.5rem; color: var(--color-gold);">The Problem</div>
          <h2 class="display-lg" style="color: var(--color-chalk); margin-bottom: 1.5rem;">
            AI agents are<br />
            <em style="color: var(--color-chalk-2); font-style: italic;">confident</em>.<br />
            Evidence is not.
          </h2>
          <p style="
            color: var(--color-chalk-2);
            font-size: 1rem;
            line-height: 1.75;
            max-width: 440px;
          ">
            Every AI agent asserts. Every feature claims. Every product says it does what it says.
            What's missing is the chain from assertion to evidence — and a way to see
            where that chain is broken, stale, or never existed.
          </p>
          <p style="
            color: var(--color-chalk-3);
            font-size: 0.9rem;
            line-height: 1.75;
            max-width: 440px;
            margin-top: 1rem;
            font-family: var(--font-mono);
            font-style: italic;
          ">
            "Evidence-backed confidence. Not certainty theater."
          </p>
        </div>

        <!-- Right: fault line diagram -->
        <div style="position: relative;">
          <div class="card" style="padding: 2rem;">
            <div class="label-sm" style="margin-bottom: 1.5rem;">claim trace &nbsp;·&nbsp; api.rateLimit</div>

            <!-- Claim chain -->
            {[
              { label: 'claim', value: 'Rate limit: 100 req/min per key', status: 'verified', meta: 'source: README, spec/rate-limit.test.ts' },
              { label: 'evidence', value: 'test output — 312 ms ago', status: 'verified', meta: 'proof lane: npm test' },
              { label: 'check', value: 'CI run #1847', status: 'stale', meta: '6 days since last verification' },
              { label: 'policy', value: 'freshness window: 72h', status: 'disputed', meta: '⚠ window exceeded — requires re-verification' },
            ].map((row, i) => (
              <div key={i} style={`
                display: grid;
                grid-template-columns: 4.5rem 1fr;
                gap: 0.75rem;
                padding: 0.75rem 0;
                ${i < 3 ? 'border-bottom: 1px solid var(--color-edge);' : ''}
                align-items: start;
              `}>
                <div class="label-sm" style="padding-top: 2px;">{row.label}</div>
                <div>
                  <div style={`
                    font-family: var(--font-mono);
                    font-size: 0.78rem;
                    color: ${
                      row.status === 'verified' ? 'var(--color-chalk)' :
                      row.status === 'stale' ? 'var(--color-gold)' :
                      'var(--color-red)'
                    };
                    margin-bottom: 0.2rem;
                  `}>{row.value}</div>
                  <div style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--color-chalk-3);">{row.meta}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Products
  ────────────────────────────────────────────────────────── -->
  <section style="padding: 6rem var(--spacing-page); border-top: 1px solid var(--color-edge);">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 3rem; text-align: center;">Two products. One trust layer.</div>

      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
      ">

        <!-- Veritas card -->
        <a href="/veritas" data-umami-event="home-product-card-veritas" style="text-decoration: none;" class="card" style="
          padding: 2.5rem;
          display: block;
          position: relative;
          overflow: hidden;
        ">
          <div style="
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--color-green), transparent);
          "></div>

          <div style="padding: 2.5rem;">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;">
              <div class="trust-badge trust-badge--verified">v0.1.3</div>
              <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--color-chalk-3);">@kontourai/veritas</span>
            </div>

            <h3 class="display-md" style="color: var(--color-chalk); margin-bottom: 1rem;">
              Veritas
            </h3>

            <p style="
              font-family: var(--font-mono);
              font-size: 0.75rem;
              color: var(--color-chalk-3);
              letter-spacing: 0.04em;
              margin-bottom: 1.25rem;
              line-height: 1.5;
            ">BESPOKE LINT FOR AI AGENTS</p>

            <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.7; margin-bottom: 2rem;">
              Repo-local governance that tells AI agents exactly what changed
              violated your rules — before they finish work. Works with Claude Code,
              Cursor, Codex, and Copilot.
            </p>

            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 2rem;">
              {['artifacts', 'governance-block', 'if-changed', 'proof-lanes'].map(tag => (
                <span key={tag} style="
                  font-family: var(--font-mono);
                  font-size: 0.6rem;
                  padding: 0.15rem 0.5rem;
                  border: 1px solid var(--color-edge-2);
                  border-radius: 2px;
                  color: var(--color-chalk-3);
                  letter-spacing: 0.08em;
                ">{tag}</span>
              ))}
            </div>

            <div style="
              font-family: var(--font-mono);
              font-size: 0.75rem;
              color: var(--color-green);
              display: flex;
              align-items: center;
              gap: 0.4rem;
            ">
              Explore Veritas →
            </div>
          </div>
        </a>

        <!-- Surface card -->
        <a href="/surface" data-umami-event="home-product-card-surface" style="text-decoration: none;" class="card" style="
          display: block;
          position: relative;
          overflow: hidden;
        ">
          <div style="
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--color-gold), transparent);
          "></div>

          <div style="padding: 2.5rem;">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;">
              <div class="trust-badge trust-badge--proposed">v0.1.0</div>
              <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--color-chalk-3);">@kontourai/surface</span>
            </div>

            <h3 class="display-md" style="color: var(--color-chalk); margin-bottom: 1rem;">
              Surface
            </h3>

            <p style="
              font-family: var(--font-mono);
              font-size: 0.75rem;
              color: var(--color-chalk-3);
              letter-spacing: 0.04em;
              margin-bottom: 1.25rem;
              line-height: 1.5;
            ">THE TRUST MAP FOR AI-ERA PRODUCTS</p>

            <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.7; margin-bottom: 2rem;">
              Maps what your product claims, what evidence supports it, where
              trust is missing or stale, and what humans or AI agents need to
              verify next.
            </p>

            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 2rem;">
              {['claims', 'evidence', 'drift', 'fault-lines', 'coverage'].map(tag => (
                <span key={tag} style="
                  font-family: var(--font-mono);
                  font-size: 0.6rem;
                  padding: 0.15rem 0.5rem;
                  border: 1px solid var(--color-edge-2);
                  border-radius: 2px;
                  color: var(--color-chalk-3);
                  letter-spacing: 0.08em;
                ">{tag}</span>
              ))}
            </div>

            <div style="
              font-family: var(--font-mono);
              font-size: 0.75rem;
              color: var(--color-gold);
              display: flex;
              align-items: center;
              gap: 0.4rem;
            ">
              Explore Surface →
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Philosophy
  ────────────────────────────────────────────────────────── -->
  <section style="
    padding: 7rem var(--spacing-page);
    border-top: 1px solid var(--color-edge);
    text-align: center;
    position: relative;
    overflow: hidden;
  ">
    <div style="
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 50% 100%, rgba(201,163,90,0.035) 0%, transparent 65%);
      pointer-events: none;
    "></div>

    <div style="max-width: 760px; margin: 0 auto; position: relative; z-index: 1;">
      <div class="label-sm" style="margin-bottom: 2rem; color: var(--color-gold);">Philosophy</div>

      <blockquote style="
        font-family: var(--font-display);
        font-size: clamp(1.8rem, 3.5vw, 3rem);
        font-weight: 300;
        font-style: italic;
        color: var(--color-chalk);
        line-height: 1.2;
        letter-spacing: -0.02em;
        margin: 0 0 2rem;
      ">
        "Evidence-backed<br />
        confidence.<br />
        Not certainty theater."
      </blockquote>

      <p style="
        color: var(--color-chalk-3);
        font-size: 0.9rem;
        line-height: 1.75;
        max-width: 520px;
        margin: 0 auto;
      ">
        Surface does not market itself as objective truth. It shows the evidence chain,
        the verification method, and the current trust state. If a claim is weak,
        stale, or disputed — the system makes that obvious.
      </p>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Quick install
  ────────────────────────────────────────────────────────── -->
  <section style="
    padding: 5rem var(--spacing-page);
    border-top: 1px solid var(--color-edge);
  ">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 4rem;
        align-items: center;
      ">
        <div>
          <div class="label-sm" style="margin-bottom: 1.5rem; color: var(--color-green);">Get started</div>
          <h2 class="display-md" style="color: var(--color-chalk); margin-bottom: 1rem;">
            Wire Veritas into<br />your repo in minutes.
          </h2>
          <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.7; margin-bottom: 2rem;">
            Bootstrap your adapter, define proof requirements,
            and get lint-style feedback straight into your AI agent's context.
          </p>
          <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
            <a href="/veritas" class="btn-primary" data-umami-event="home-final-read-docs">Read the docs →</a>
            <a href="https://github.com/kontourai/veritas" target="_blank" rel="noopener" class="btn-ghost" data-umami-event="home-final-github-veritas">GitHub</a>
          </div>
        </div>

        <!-- Terminal -->
        <div class="terminal">
          <div class="terminal-bar">
            <div class="terminal-dot"></div>
            <div class="terminal-dot"></div>
            <div class="terminal-dot"></div>
            <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--color-chalk-3); margin-left: 0.5rem; letter-spacing: 0.05em;">veritas — setup</span>
          </div>
          <div class="terminal-body">
            <p><span class="prompt">$ </span><span class="cmd">npm install -g @kontourai/veritas</span></p>
            <p style="color: var(--color-chalk-3); margin: 0.25rem 0;">  added 1 package in 0.8s</p>
            <br />
            <p><span class="prompt">$ </span><span class="cmd">veritas init</span></p>
            <p class="pass">  ✓ detected repo shape</p>
            <p class="pass">  ✓ wrote .veritas/repo.adapter.json</p>
            <p class="pass">  ✓ wrote .veritas/policy-packs/default.policy-pack.json</p>
            <p class="pass">  ✓ governance block added to CLAUDE.md, AGENTS.md</p>
            <br />
            <p><span class="prompt">$ </span><span class="cmd">veritas shadow run</span></p>
            <p class="info">  [feedback] 2 rules checked, 1 pass, 1 warn</p>
            <p class="warn">  WARN  if-changed: src/api/ changed — tests/api/ must also appear</p>
            <p class="muted">  evidence written → .veritas/evidence/</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  @media (max-width: 768px) {
    section > div > div[style*="grid-template-columns: 1fr 1fr"] {
      display: flex !important;
      flex-direction: column !important;
    }
    section > div > div[style*="grid-template-columns: 1fr 1.2fr"] {
      display: flex !important;
      flex-direction: column !important;
    }
  }
</style>
