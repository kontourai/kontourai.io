---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import Section from '@/components/Section.astro';
import Glow from '@/components/Glow.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Card from '@/components/Card.astro';
import Grid from '@/components/Grid.astro';
import Terminal from '@/components/Terminal.astro';
import { receipts, statusCounts, badgeVariant, getReceipt } from '@/lib/receipts';
import pkg from '../../../package.json';

// Second re-derive path (#111): the advertised hachure/ajv commands render
// the exact pinned versions from package.json, and check-receipts.mjs runs
// that same pinned stack over every bundle in `validate` — the copy below may
// only exist while that check is green.
const hachurePin = pkg.devDependencies.hachure;
const ajvPin = pkg.devDependencies.ajv;

// Lead exhibit (#107): the blocked verdict opens the page. Everything shown
// about it is derived from the committed bundle, same as the cards below — the
// story beats read the claim/evidence/policy objects, not hand-authored copy.
// Records are selected by type/id (not position) and guarded so a refreshed
// bundle that no longer carries the expected shape fails the static build
// loudly instead of rendering mismatched facts.
const blocked = getReceipt('governance-readiness-not-ready');
if (!blocked) throw new Error('receipts lead exhibit: governance-readiness-not-ready missing from catalog');
const blockedClaims = blocked.bundle.claims.filter((c) => c.claimType === 'software-readiness-verdict');
if (blockedClaims.length !== 1) {
  throw new Error(`receipts lead exhibit: expected exactly one software-readiness-verdict claim, found ${blockedClaims.length}`);
}
const blockedClaim = blockedClaims[0];
// The exhibit's whole point is a refusal — if a refreshed bundle stops being
// one, fail the build rather than render refusal copy over passing facts.
if (blockedClaim.status !== 'disputed') {
  throw new Error(`receipts lead exhibit: claim status is ${blockedClaim.status}, expected disputed`);
}
const blockedVerdict = blockedClaim.value as {
  verdict?: string;
  blocking?: { failedRequirements?: string[] };
};
const blockedRequirements = blockedVerdict.blocking?.failedRequirements ?? [];
if (blockedVerdict.verdict !== 'not-ready' || blockedRequirements.length === 0) {
  throw new Error('receipts lead exhibit: claim value is not a blocked not-ready verdict with failed requirements');
}
const blockedEvidenceRecords = blocked.bundle.evidence.filter((e) => e.claimId === blockedClaim.id);
if (blockedEvidenceRecords.length !== 1 || blockedEvidenceRecords[0].passing !== false) {
  throw new Error('receipts lead exhibit: expected exactly one failing evidence record for the blocked claim');
}
const blockedEvidence = blockedEvidenceRecords[0];
const blockedPolicy = blocked.bundle.policies.find((p) => p.claimType === blockedClaim.claimType);
if (!blockedPolicy?.acceptanceCriteria?.length) {
  throw new Error('receipts lead exhibit: policy acceptance criteria missing from bundle');
}
---

<Layout
  title="Trust receipts — real recomputable bundles · Kontour AI"
  description="Open and download real Hachure trust.bundle artifacts produced by Kontour's own pipelines, then recompute them yourself with the named validator."
>
  <Nav active="receipts" />

  <!-- Hero -->
  <Section contour size="hero" borderBottom>
    <Glow accent="gold" position="top-right" />
    <div class="container container--readable">
      <Eyebrow accent="gold">Receipts</Eyebrow>
      <h1 class="product-title animate-fade-up">Check the receipts yourself</h1>
      <p class="hero-copy animate-fade-up delay-200">
        We claim Kontour makes AI-assisted work inspectable and recomputable.
        Here are real <span class="mono-inline">trust.bundle</span> artifacts to
        test that claim — each produced by one of our own pipelines, rendered
        from its actual contents, downloadable as the raw file, and validated by
        the same tool we tell you to run. Nothing here is a hand-written sample.
      </p>
      <p class="receipts-note animate-fade-up delay-200">
        Honest framing: these are <strong>Kontour's own pipeline receipts</strong>
        (dogfood). They demonstrate the format is real and checkable — not that
        an outside team has adopted it. Landing an external team's receipt is an
        open pursuit we track separately, not a claim this page makes.
      </p>
    </div>
  </Section>

  <!-- Lead exhibit: the blocked run (demo, not archive) -->
  <Section tone="alt" size="lg" borderBottom>
    <Glow accent="red" position="top-left" />
    <div class="container container--readable">
      <Eyebrow accent="red-2">Lead exhibit — a blocked verdict</Eyebrow>
      <h2 class="section-heading">The receipt that says no.</h2>
      <p class="section-lead">
        Green receipts prove the format works. This one shows what a <em>refusal</em> looks
        like: a readiness record whose evidence failed, projected into the same recomputable
        format. The verdict isn't narrated — it derives from the artifact, and recomputing
        the bundle yields the same refusal. Every fact below is read from the bundle itself —
        open it and check.
      </p>

      <div class="blocked-story">
        <div class="blocked-beat" data-accent="chalk-2">
          <p class="label-sm blocked-beat__label">The claim on the table</p>
          <p class="body blocked-beat__body">
            A <span class="mono-inline">{blockedClaim.claimType}</span> on a pinned
            working tree, impact <span class="mono-inline">{blockedClaim.impactLevel}</span>.
            Policy: {blockedPolicy.acceptanceCriteria[0]}
          </p>
        </div>
        <div class="blocked-beat" data-accent="gold">
          <p class="label-sm blocked-beat__label">What the record showed</p>
          <p class="body blocked-beat__body">
            "{blockedEvidence.excerptOrSummary}" — recorded with
            <span class="mono-inline">passing: {String(blockedEvidence.passing)}</span> by
            <span class="mono-inline">{blockedEvidence.collectedBy}</span>. The blocking
            requirement went unmet, so no verified evidence event exists.
          </p>
        </div>
        <div class="blocked-beat" data-accent="red-2">
          <p class="label-sm blocked-beat__label">Why the verdict refuses</p>
          <p class="body blocked-beat__body">
            The verdict derives to <span class="mono-inline">{blockedVerdict.verdict}</span> and
            the claim's status to <span class="mono-inline">{blockedClaim.status}</span> —
            computed from the failing evidence on
            <span class="mono-inline">{blockedRequirements.join(', ')}</span>, not narrated.
            Recompute the bundle and you get the same answer; rendering this green would
            take a different artifact, not a different story.
          </p>
        </div>
      </div>

      <p class="fine blocked-framing">
        Honest framing: this exhibit is the Governance Kit's committed not-ready readiness
        record run through its deterministic adapter — it demonstrates the refusal shape in
        the real format, not a live delivery stopped mid-run. Publishing a stop-gate receipt
        from a live blocked delivery is an open pursuit we track in the backlog, not a claim
        this page makes.
      </p>

      <div class="blocked-actions">
        <a
          class="btn-ghost"
          href={`/receipts/${blocked.slug}/`}
          data-umami-event="receipts-lead-blocked"
        >
          Open the blocked receipt →
        </a>
        <a
          class="receipt-download"
          href={`/receipts/${blocked.slug}.trust.bundle`}
          download
          data-umami-event="receipts-lead-download"
        >
          Download .bundle
        </a>
      </div>
    </div>
  </Section>

  <!-- Receipt catalog -->
  <Section size="lg" borderBottom>
    <div class="container container--readable">
      <Eyebrow accent="gold">The archive</Eyebrow>
      <h2 class="section-heading archive-heading">Every published receipt, green or not.</h2>
      <Grid min="300" gap="lg" class="archive-grid">
        {receipts.map((receipt) => {
          const counts = statusCounts(receipt.bundle);
          return (
            <Card accent={receipt.accent} bar="top" pad="lg" data-accent={receipt.accent}>
              <p class="label-sm receipt-pipeline">{receipt.pipeline}</p>
              <h3 class="receipt-title">{receipt.title}</h3>
              <p class="receipt-summary">{receipt.summary}</p>

              <div class="receipt-badges">
                {counts.map((entry) => (
                  <span class={`trust-badge trust-badge--${badgeVariant(entry.status)}`}>
                    {entry.count} {entry.status}
                  </span>
                ))}
              </div>

              <dl class="receipt-provenance">
                <dt>Source</dt>
                <dd class="mono-inline">{receipt.provenance.repo}</dd>
                <dt>Pinned</dt>
                <dd class="mono-inline">{receipt.provenance.commit.slice(0, 12)}</dd>
              </dl>

              <div class="receipt-actions">
                <a class="receipt-link" href={`/receipts/${receipt.slug}/`}>View receipt →</a>
                <a
                  class="receipt-download"
                  href={`/receipts/${receipt.slug}.trust.bundle`}
                  download
                >
                  Download .bundle
                </a>
              </div>

              <div class="receipt-verify">
                <p class="label-sm receipt-verify-label">Check it yourself</p>
                <code class="receipt-verify-cmd">npx @kontourai/surface@2.1.2 report --input {receipt.slug}.trust.bundle --format summary</code>
              </div>
            </Card>
          );
        })}
      </Grid>
    </div>
  </Section>

  <!-- Recompute -->
  <Section tone="alt" borderTop size="lg">
    <div class="container container--readable">
      <Eyebrow accent="green">Recompute, don't trust</Eyebrow>
      <h2 class="section-heading">Validate any of these yourself</h2>
      <p class="section-lead">
        Every bundle above is a Hachure trust.bundle. Download one and run it
        through <span class="mono-inline">@kontourai/surface</span>'s
        <span class="mono-inline">validateTrustBundle</span> — the named
        validator. The CLI wraps it: a valid bundle prints its trust summary and
        exits 0; a malformed one exits non-zero.
      </p>
      <Terminal title="verify a downloaded receipt">
        <div><span class="prompt">$</span> <span class="cmd">npx @kontourai/surface@2.1.2 report \</span></div>
        <div><span class="cmd">    --input flow-agents-delivery.trust.bundle --format summary</span></div>
        <div class="muted">Kontour Surface report …</div>
        <div class="pass">Claims: 34 (proposed: 1, assumed: 1, verified: 32)</div>
        <div class="info">Facets: flow-agents.workflow: 34</div>
        <div class="muted"># exit 0 — the bundle validated</div>
      </Terminal>
      <p class="section-lead recompute-second">
        Don't take one implementation's word for it either. Every bundle here
        also validates under the separate <span class="mono-inline">hachure</span> reference
        CLI — two implementations, same verdict. A green check on this repo
        means every published bundle passed both validators. Honest scope:
        the implementations are separate (a handwritten validator vs the
        spec's normative schemas), but both are currently Kontour-maintained —
        implementation-independent, not yet organizationally independent.
      </p>
      <Terminal title="second opinion — the reference CLI">
        <div><span class="prompt">$</span> <span class="cmd">npx -y -p ajv@{ajvPin} -p hachure@{hachurePin} hachure validate \</span></div>
        <div><span class="cmd">    governance-readiness-not-ready.trust.bundle</span></div>
        <div class="pass">valid TrustBundle (schemaVersion 5)</div>
      </Terminal>
      <p class="section-lead recompute-foot">
        Each receipt page repeats the exact command for its file and links the
        provenance commit, so you can trace the artifact back to the run that
        produced it.
      </p>
    </div>
  </Section>

  <Footer />
</Layout>

<style>
  .container--readable {
    margin-inline: auto;
  }
  .mono-inline {
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--color-chalk-2);
  }
  .receipts-note {
    margin-top: 1.5rem;
    max-width: 60ch;
    color: var(--color-chalk-2);
    font-size: 0.95rem;
    line-height: 1.7;
    border-left: 2px solid var(--color-edge-2);
    padding-left: 1rem;
  }
  .receipt-pipeline {
    color: var(--accent, var(--color-chalk-3));
    margin-bottom: 0.75rem;
  }
  .receipt-title {
    font-size: 1.25rem;
    line-height: 1.25;
    margin: 0 0 0.75rem;
    color: var(--color-chalk);
  }
  .receipt-summary {
    color: var(--color-chalk-2);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }
  .receipt-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }
  .receipt-provenance {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.25rem 0.75rem;
    margin: 0 0 1.5rem;
    font-size: 0.8rem;
  }
  .receipt-provenance dt {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.65rem;
    color: var(--color-chalk-3);
    align-self: center;
  }
  .receipt-provenance dd {
    margin: 0;
    color: var(--color-chalk-2);
  }
  .receipt-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }
  .receipt-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent, var(--color-gold));
    text-decoration: none;
  }
  .receipt-link:hover {
    text-decoration: underline;
  }
  .receipt-download {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-chalk-2);
    text-decoration: none;
    border: 1px solid var(--color-edge-2);
    border-radius: 4px;
    padding: 0.3rem 0.7rem;
  }
  .receipt-download:hover {
    border-color: var(--accent, var(--color-edge-2));
    color: var(--color-chalk);
  }
  .receipt-verify {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-edge);
  }
  .receipt-verify-label {
    margin: 0 0 0.5rem;
  }
  .receipt-verify-cmd {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--color-chalk-2);
    background: var(--color-ink-2);
    border: 1px solid var(--color-edge);
    border-radius: 4px;
    padding: 0.5rem 0.7rem;
    overflow-wrap: anywhere;
    user-select: all;
  }
  .section-heading {
    font-size: 1.75rem;
    margin: 0 0 1rem;
    color: var(--color-chalk);
  }
  .section-lead {
    color: var(--color-chalk-2);
    line-height: 1.7;
    max-width: 68ch;
    margin: 0 0 1.5rem;
  }
  .recompute-foot {
    margin-top: 1.5rem;
    margin-bottom: 0;
    font-size: 0.9rem;
  }
  .recompute-second {
    margin-top: 2rem;
  }

  /* Lead exhibit: the blocked run */
  .blocked-story {
    display: grid;
    gap: 1.25rem;
    margin: 2rem 0;
  }
  .blocked-beat {
    border-left: 2px solid var(--accent, var(--color-edge-2));
    padding-left: 1.1rem;
  }
  .blocked-beat__label {
    color: var(--accent, var(--color-chalk-3));
    margin: 0 0 0.4rem;
  }
  .blocked-beat__body {
    margin: 0;
    max-width: 72ch;
  }
  .blocked-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }
  .blocked-framing {
    margin: 1.75rem 0 0;
    max-width: 72ch;
  }
  .archive-heading {
    margin-bottom: 2rem;
  }
</style>
