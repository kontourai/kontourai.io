---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import Terminal from '@/components/Terminal.astro';
import Section from '@/components/Section.astro';
import Glow from '@/components/Glow.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Card from '@/components/Card.astro';
import Grid from '@/components/Grid.astro';
import Split from '@/components/Split.astro';
import type { Accent } from '@/lib/theme';

const pipeline = [
  { step: 'Source', body: 'Where the value came from — a page, a document, an API record, a manual entry — with its reference, time, and checksum.' },
  { step: 'Extraction', body: 'The value pulled from that source, with a locator, an excerpt, the extractor, and a confidence.' },
  { step: 'Candidate', body: 'Competing values for the same target, kept side by side instead of silently dropped.' },
  { step: 'Review', body: 'The outcome a human or policy assigns — verified, assumed, rejected, or needs-review.' },
  { step: 'Claim', body: 'A Surface-ready claim with its full provenance trail attached, ready to be reported on.' },
];

const boundary: { title: string; accent: Accent; items: string[] }[] = [
  { title: 'Survey owns', accent: 'gold-2', items: ['Raw source identity & retrieval context', 'Extraction observations & locators', 'Candidate sets and resolutions', 'Review outcomes', 'Projection into Surface TrustInput'] },
  { title: 'Producers own', accent: 'cobalt-2', items: ['Acquisition, crawling, and parsing', 'Candidate ranking and scoring', 'Review UX and policy', 'Materiality and domain rules', 'Whether a value is verified or assumed'] },
  { title: 'Surface owns', accent: 'gold', items: ['Claim status vocabulary', 'Evidence display & support strength', 'Claim dependencies & derived edges', 'Freshness and stale cascades', 'Trust reports and console views'] },
];

const helpers = [
  { fn: 'fieldObservation', desc: 'One scalar field value with its source, extraction, review, and claim defaults filled in.' },
  { fn: 'repeatedObservation', desc: 'A repeated field or entity list described as one aggregate observation.' },
  { fn: 'candidateReviewRecord', desc: 'Multiple candidates for one target, assembled into a shared candidate set with links.' },
  { fn: 'reviewedCandidateResolution', desc: 'Attaches a review outcome to the selected candidate and supersedes the rest.' },
  { fn: 'uploadedDocumentSource', desc: 'A stable RawSource for a document a producer already retrieved.' },
  { fn: 'apiRecordSource', desc: 'A stable RawSource for a structured record pulled from an API.' },
  { fn: 'webPageSource', desc: 'A stable RawSource for a crawled web page, with locator scheme and checksum.' },
  { fn: 'manualEntrySource', desc: 'A stable RawSource for a value entered by hand, kept inspectable like the rest.' },
];
---

<Layout
  title="Survey — Producer-side trust for Surface · Kontour AI"
  description="Kontour Survey turns producer observations — sources, extractions, candidates, and reviews — into Surface-ready claims, without absorbing your domain policy."
>
  <Nav active="survey" />

  <!-- Hero -->
  <Section contour size="hero" borderBottom>
    <Glow accent="gold-2" position="top-right" />
    <div class="container">
      <Split ratio="1-1" gap="lg" align="center">
        <div>
          <div class="hero-badges">
            <span class="trust-badge trust-badge--verified">v0.4.5</span>
            <span class="install-hint">npm install -D @kontourai/survey</span>
          </div>

          <h1 class="product-title animate-fade-up">Survey</h1>
          <p class="product-tagline animate-fade-up delay-100" data-accent="gold-2">producer-side trust for Surface</p>

          <p class="hero-copy animate-fade-up delay-200">
            Before a claim can be trusted, someone has to form it — from a
            source, an extraction, competing candidates, and a review. Survey
            is the small contract for that producer side: it turns your
            observations into Surface-ready claims with their provenance
            attached, without absorbing your domain policy.
          </p>

          <div class="hero-actions animate-fade-up delay-300">
            <a href="https://www.npmjs.com/package/@kontourai/survey" target="_blank" rel="noopener" class="btn-primary" data-umami-event="survey-hero-npm">npm package →</a>
            <a href="/surface" class="btn-ghost" data-umami-event="survey-hero-surface">Projects into Surface</a>
          </div>
        </div>

        <Terminal class="animate-fade-in delay-300" title="quickstart.ts">
<pre class="code"><span class="t-com">// observation in → Surface-ready claim out</span>
<span class="t-kw">import</span> {'{'} buildSurveyTrustInput,
         SurveyInputBuilder {'}'} <span class="t-kw">from</span> <span class="t-str">"@kontourai/survey"</span>;
<span class="t-kw">import</span> {'{'} buildTrustReport {'}'} <span class="t-kw">from</span> <span class="t-str">"@kontourai/surface"</span>;

<span class="t-kw">const</span> input = <span class="t-kw">new</span> <span class="t-fn">SurveyInputBuilder</span>({'{'}
  source: <span class="t-str">"crawler:run-1"</span>,
{'}'})
  .<span class="t-fn">addObservation</span>(observation)
  .<span class="t-fn">build</span>();

<span class="t-com">// hand the trust state to Surface</span>
<span class="t-kw">const</span> report = <span class="t-fn">buildTrustReport</span>(
  <span class="t-fn">buildSurveyTrustInput</span>(input),
);</pre>
        </Terminal>
      </Split>
    </div>
  </Section>

  <!-- The pipeline -->
  <Section size="lg">
    <div class="container">
      <Eyebrow accent="gold-2" gap="sm">The producer pipeline</Eyebrow>
      <h2 class="display-md measure-lg pipeline-title">
        One path from raw source to a claim Surface can verify.
      </h2>

      <Grid cols={5} gap="sm">
        {pipeline.map(({ step, body }, i) => (
          <div class="pstep">
            <div class="pstep__head">
              <span class="pstep__n">0{i + 1}</span>
              <span class="pstep__name">{step}</span>
            </div>
            <p class="pstep__body">{body}</p>
          </div>
        ))}
      </Grid>
    </div>
  </Section>

  <!-- Boundary -->
  <Section tone="alt" borderTop borderBottom>
    <div class="container">
      <Eyebrow gap="sm">A deliberately narrow boundary</Eyebrow>
      <p class="fine boundary-note">
        Survey does not crawl pages, parse PDFs, rank candidates, decide review
        policy, or claim a value is true. It gives producers a consistent
        contract so the same provenance shape reaches Surface every time.
      </p>

      <Grid cols={3} gap="lg">
        {boundary.map(({ title, accent, items }) => (
          <Card accent={accent} pad="md">
            <h3 class="boundary__title">{title}</h3>
            <ul class="def-list">
              {items.map(item => (
                <li class="def-item">
                  <span class="def-item__dash">—</span>
                  <span class="def-item__text">{item}</span>
                </li>
              ))}
            </ul>
          </Card>
        ))}
      </Grid>
    </div>
  </Section>

  <!-- Authoring helpers -->
  <Section size="lg">
    <div class="container">
      <Eyebrow gap="sm">Authoring helpers</Eyebrow>
      <h2 class="display-md helpers-title">
        Describe the common cases without hand-assembling every record.
      </h2>

      <Grid min="300" gap="md">
        {helpers.map(({ fn, desc }) => (
          <div class="helper">
            <code class="helper__fn">{fn}()</code>
            <span class="helper__desc">{desc}</span>
          </div>
        ))}
      </Grid>
    </div>
  </Section>

  <!-- Worked example -->
  <Section tone="alt" borderTop>
    <div class="container">
      <Split ratio="1-1.15" gap="md" align="center">
        <div>
          <Eyebrow accent="gold-2">A worked example</Eyebrow>
          <h2 class="display-md worked__title">One field. Full provenance.</h2>
          <p class="body worked__copy">
            A crawler reads a registration status off a public record. With
            <code class="codechip" data-accent="gold-2">fieldObservation</code>,
            the source, extraction, review outcome, and claim travel together —
            so Surface can report not just the value, but where it came from
            and how fresh it is.
          </p>
          <p class="body worked__copy worked__copy--last">
            Conflicting candidates don't disappear. A losing source stays on the
            trail as <code class="code-plain">superseded</code>,
            and an unresolved conflict projects to Surface as
            <code class="code-plain">disputed</code>.
          </p>
        </div>

        <Terminal title="field-observation.ts">
<pre class="code"><span class="t-kw">import</span> {'{'} fieldObservation,
         SurveyInputBuilder {'}'} <span class="t-kw">from</span> <span class="t-str">"@kontourai/survey"</span>;

<span class="t-kw">const</span> input = <span class="t-kw">new</span> <span class="t-fn">SurveyInputBuilder</span>({'{'} source: <span class="t-str">"crawler:run-1"</span> {'}'})
  .<span class="t-fn">addObservation</span>(<span class="t-fn">fieldObservation</span>({'{'}
    id: <span class="t-str">"entity-123.status.current"</span>,
    field: <span class="t-str">"registrationStatus"</span>,
    value: <span class="t-str">"ACTIVE"</span>,
    rawSource: {'{'}
      kind: <span class="t-str">"web-page"</span>,
      sourceRef: <span class="t-str">"https://records.test/123"</span>,
      observedAt: <span class="t-fn">now</span>(),
      locatorScheme: <span class="t-str">"html"</span>,
    {'}'},
    extraction: {'{'}
      confidence: <span class="t-num">0.97</span>,
      locator: <span class="t-str">"css:#registration-status"</span>,
      extractor: <span class="t-str">"example-crawler"</span>,
      extractedAt: <span class="t-fn">now</span>(),
    {'}'},
    reviewOutcome: {'{'} status: <span class="t-str">"verified"</span> {'}'},
    claim: {'{'}
      subjectType: <span class="t-str">"public-record.entity"</span>,
      subjectId: <span class="t-str">"entity-123"</span>,
      claimType: <span class="t-str">"public-data.field"</span>,
      impactLevel: <span class="t-str">"medium"</span>,
      collectedBy: <span class="t-str">"example-crawler"</span>,
    {'}'},
  {'}'}))
  .<span class="t-fn">build</span>();</pre>
        </Terminal>
      </Split>
    </div>
  </Section>

  <!-- Surface handoff -->
  <Section borderTop>
    <div class="container">
      <Split ratio="1-1" gap="md" align="center">
        <div>
          <Eyebrow accent="gold">Built for Surface</Eyebrow>
          <h2 class="display-md handoff__title">Survey produces.<br />Surface verifies.</h2>
          <p class="body handoff__copy">
            <code class="codechip" data-accent="gold-2">buildSurveyTrustInput</code>
            projects Survey records into a Surface
            <code class="codechip" data-accent="gold">TrustInput</code>.
            From there, Surface owns claim status, evidence, dependencies,
            freshness, and the trust reports humans and agents inspect.
          </p>
          <a href="/surface" data-umami-event="survey-explore-surface" class="handoff__link">Explore Surface →</a>
        </div>

        <Terminal title="survey → surface">
          <p class="muted">  Survey records</p>
          <p>  source → extraction → candidate → review → <span class="info">claim</span></p>
          <br />
          <p class="muted">  buildSurveyTrustInput()</p>
          <p class="rule">  ───────────────────────────────</p>
          <p class="info">  Surface TrustInput</p>
          <p class="pass">  verified  registrationStatus = ACTIVE</p>
          <p class="muted">  evidence  web-page · css:#registration-status</p>
          <p class="muted">  freshness owned by Surface policy</p>
        </Terminal>
      </Split>
    </div>
  </Section>

  <Footer active="survey" />
</Layout>

<style>
  .pipeline-title {
    margin-bottom: 2.5rem;
  }
  .pstep {
    position: relative;
    padding: 1.5rem 1.25rem;
    background: var(--color-ink-1);
    border: 1px solid var(--color-edge);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .pstep__head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .pstep__n {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--color-chalk-3);
  }
  .pstep__name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--color-gold-2);
    letter-spacing: 0;
  }
  .pstep__body {
    font-size: 0.78rem;
    color: var(--color-chalk-3);
    line-height: 1.6;
    margin: 0;
  }

  .boundary-note {
    max-width: 680px;
    margin-bottom: 2.5rem;
  }
  .boundary__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-chalk);
    margin-bottom: 1.25rem;
    letter-spacing: 0;
  }

  .helpers-title {
    margin-bottom: 2.5rem;
    max-width: 720px;
  }
  .helper {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.1rem 1.25rem;
    background: var(--color-ink-1);
    border: 1px solid var(--color-edge);
    border-radius: 4px;
  }
  .helper__fn {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-gold-2);
  }
  .helper__desc {
    font-size: 0.78rem;
    color: var(--color-chalk-3);
    line-height: 1.45;
  }

  .worked__title,
  .handoff__title {
    margin-bottom: 1.25rem;
  }
  .worked__copy {
    margin-bottom: 1.5rem;
  }
  .worked__copy--last {
    margin-bottom: 0;
  }
  .handoff__copy {
    margin-bottom: 1.5rem;
  }
  .handoff__link {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-gold);
    text-decoration: none;
  }
</style>
