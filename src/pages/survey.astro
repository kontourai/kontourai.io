---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
---

<Layout
  title="Survey — Producer-side trust for Surface · Kontour AI"
  description="Kontour Survey turns producer observations — sources, extractions, candidates, and reviews — into Surface-ready claims, without absorbing your domain policy."
>
  <Nav active="survey" />

  <!-- ──────────────────────────────────────────────────────
       Hero
  ────────────────────────────────────────────────────────── -->
  <section class="contour-bg" style="
    padding: 10rem var(--spacing-page) 6rem;
    border-bottom: 1px solid var(--color-edge);
    position: relative;
    overflow: hidden;
  ">
    <!-- Gold-2 accent glow -->
    <div style="
      position: absolute;
      top: 0;
      right: 5%;
      width: 680px;
      height: 460px;
      background: radial-gradient(ellipse at top right, rgba(232,194,116,0.05) 0%, transparent 68%);
      pointer-events: none;
    "></div>

    <div style="max-width: 1280px; margin: 0 auto; position: relative; z-index: 1;">
      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
        align-items: center;
      ">
        <!-- Left -->
        <div>
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 2rem;">
            <span class="trust-badge trust-badge--stale">v0.3.0</span>
            <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--color-chalk-3);">npm install -D @kontourai/survey</span>
          </div>

          <h1 class="animate-fade-up" style="
            font-family: var(--font-display);
            font-optical-sizing: auto;
            font-size: clamp(3.5rem, 6vw, 5.5rem);
            font-weight: 400;
            line-height: 1.3;
            letter-spacing: -0.03em;
            color: var(--color-chalk);
            margin-bottom: 0.5rem;
          ">Survey</h1>

          <p class="animate-fade-up delay-100" style="
            font-family: var(--font-mono);
            font-size: 0.75rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--color-gold-2);
            margin-bottom: 2rem;
          ">producer-side trust for Surface</p>

          <p class="animate-fade-up delay-200" style="
            font-size: 1.05rem;
            color: var(--color-chalk-2);
            line-height: 1.7;
            max-width: 480px;
            margin-bottom: 2.5rem;
          ">
            Before a claim can be trusted, someone has to form it — from a
            source, an extraction, competing candidates, and a review. Survey
            is the small contract for that producer side: it turns your
            observations into Surface-ready claims with their provenance
            attached, without absorbing your domain policy.
          </p>

          <div class="animate-fade-up delay-300" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
            <a href="https://www.npmjs.com/package/@kontourai/survey" target="_blank" rel="noopener" class="btn-primary" data-umami-event="survey-hero-npm">
              npm package →
            </a>
            <a href="/surface" class="btn-ghost" data-umami-event="survey-hero-surface">
              Projects into Surface
            </a>
          </div>
        </div>

        <!-- Right: quickstart code -->
        <div class="animate-fade-in delay-300">
          <div class="terminal">
            <div class="terminal-bar">
              <div class="terminal-dot"></div>
              <div class="terminal-dot"></div>
              <div class="terminal-dot"></div>
              <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--color-chalk-3); margin-left: 0.5rem;">quickstart.ts</span>
            </div>
            <div class="terminal-body">
<pre style="margin: 0; white-space: pre; overflow-x: auto; font-family: var(--font-mono); font-size: 0.72rem; line-height: 1.7; color: var(--color-chalk-2);"><span style="color: var(--color-chalk-3);">// observation in → Surface-ready claim out</span>
<span style="color: var(--color-gold-2);">import</span> {'{'} buildSurveyTrustInput,
         SurveyInputBuilder {'}'} <span style="color: var(--color-gold-2);">from</span> <span style="color: var(--color-green);">"@kontourai/survey"</span>;
<span style="color: var(--color-gold-2);">import</span> {'{'} buildTrustReport {'}'} <span style="color: var(--color-gold-2);">from</span> <span style="color: var(--color-green);">"@kontourai/surface"</span>;

<span style="color: var(--color-gold-2);">const</span> input = <span style="color: var(--color-gold-2);">new</span> <span style="color: var(--color-cobalt-2);">SurveyInputBuilder</span>({'{'}
  source: <span style="color: var(--color-green);">"crawler:run-1"</span>,
{'}'})
  .<span style="color: var(--color-cobalt-2);">addObservation</span>(observation)
  .<span style="color: var(--color-cobalt-2);">build</span>();

<span style="color: var(--color-chalk-3);">// hand the trust state to Surface</span>
<span style="color: var(--color-gold-2);">const</span> report = <span style="color: var(--color-cobalt-2);">buildTrustReport</span>(
  <span style="color: var(--color-cobalt-2);">buildSurveyTrustInput</span>(input),
);</pre>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       The pipeline
  ────────────────────────────────────────────────────────── -->
  <section style="padding: 6rem var(--spacing-page);">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 1rem; color: var(--color-gold-2);">The producer pipeline</div>
      <h2 class="display-md" style="color: var(--color-chalk); margin-bottom: 2.5rem; max-width: 760px;">
        One path from raw source to a claim Surface can verify.
      </h2>

      <div style="
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 0.75rem;
        align-items: stretch;
      ">
        {[
          { step: 'Source', body: 'Where the value came from — a page, a document, an API record, a manual entry — with its reference, time, and checksum.' },
          { step: 'Extraction', body: 'The value pulled from that source, with a locator, an excerpt, the extractor, and a confidence.' },
          { step: 'Candidate', body: 'Competing values for the same target, kept side by side instead of silently dropped.' },
          { step: 'Review', body: 'The outcome a human or policy assigns — verified, assumed, rejected, or needs-review.' },
          { step: 'Claim', body: 'A Surface-ready claim with its full provenance trail attached, ready to be reported on.' },
        ].map(({ step, body }, i) => (
          <div key={step} style="
            position: relative;
            padding: 1.5rem 1.25rem;
            background: var(--color-ink-1);
            border: 1px solid var(--color-edge);
            border-radius: 6px;
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
          ">
            <div style="display: flex; align-items: center; gap: 0.6rem;">
              <span style="
                font-family: var(--font-mono);
                font-size: 0.62rem;
                color: var(--color-chalk-3);
              ">0{i + 1}</span>
              <span style={`
                font-family: var(--font-display);
                font-size: 1.05rem;
                color: var(--color-gold-2);
                letter-spacing: -0.01em;
              `}>{step}</span>
            </div>
            <p style="font-size: 0.78rem; color: var(--color-chalk-3); line-height: 1.6; margin: 0;">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Boundary
  ────────────────────────────────────────────────────────── -->
  <section style="
    padding: 5rem var(--spacing-page);
    border-top: 1px solid var(--color-edge);
    border-bottom: 1px solid var(--color-edge);
    background: var(--color-ink-1);
  ">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 1rem;">A deliberately narrow boundary</div>
      <p style="
        color: var(--color-chalk-3);
        font-size: 0.9rem;
        line-height: 1.65;
        max-width: 680px;
        margin-bottom: 2.5rem;
      ">
        Survey does not crawl pages, parse PDFs, rank candidates, decide review
        policy, or claim a value is true. It gives producers a consistent
        contract so the same provenance shape reaches Surface every time.
      </p>

      <div style="
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
      ">
        {[
          {
            title: 'Survey owns',
            color: 'var(--color-gold-2)',
            items: ['Raw source identity & retrieval context', 'Extraction observations & locators', 'Candidate sets and resolutions', 'Review outcomes', 'Projection into Surface TrustInput'],
          },
          {
            title: 'Producers own',
            color: 'var(--color-cobalt-2)',
            items: ['Acquisition, crawling, and parsing', 'Candidate ranking and scoring', 'Review UX and policy', 'Materiality and domain rules', 'Whether a value is verified or assumed'],
          },
          {
            title: 'Surface owns',
            color: 'var(--color-gold)',
            items: ['Claim status vocabulary', 'Evidence display & support strength', 'Claim dependencies & derived edges', 'Freshness and stale cascades', 'Trust reports and console views'],
          },
        ].map(({ title, color, items }) => (
          <div key={title} class="card" style="padding: 1.75rem; position: relative; overflow: hidden;">
            <div style={`
              position: absolute;
              top: 0;
              left: 0;
              right: 0;
              height: 2px;
              background: linear-gradient(90deg, ${color}, transparent);
            `}></div>
            <h3 style={`
              font-family: var(--font-display);
              font-size: 1.25rem;
              font-weight: 400;
              color: var(--color-chalk);
              margin-bottom: 1.25rem;
              letter-spacing: -0.01em;
            `}>{title}</h3>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem;">
              {items.map(item => (
                <li key={item} style="display: flex; gap: 0.6rem; align-items: flex-start;">
                  <span style={`color: ${color}; font-family: var(--font-mono); font-size: 0.7rem; padding-top: 2px;`}>—</span>
                  <span style="font-size: 0.82rem; color: var(--color-chalk-2); line-height: 1.55;">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Authoring helpers
  ────────────────────────────────────────────────────────── -->
  <section style="padding: 6rem var(--spacing-page);">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="label-sm" style="margin-bottom: 1rem;">Authoring helpers</div>
      <h2 class="display-md" style="color: var(--color-chalk); margin-bottom: 2.5rem; max-width: 720px;">
        Describe the common cases without hand-assembling every record.
      </h2>

      <div style="
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1rem;
      ">
        {[
          { fn: 'fieldObservation', desc: 'One scalar field value with its source, extraction, review, and claim defaults filled in.' },
          { fn: 'repeatedObservation', desc: 'A repeated field or entity list described as one aggregate observation.' },
          { fn: 'candidateReviewRecord', desc: 'Multiple candidates for one target, assembled into a shared candidate set with links.' },
          { fn: 'reviewedCandidateResolution', desc: 'Attaches a review outcome to the selected candidate and supersedes the rest.' },
          { fn: 'uploadedDocumentSource', desc: 'A stable RawSource for a document a producer already retrieved.' },
          { fn: 'apiRecordSource', desc: 'A stable RawSource for a structured record pulled from an API.' },
          { fn: 'webPageSource', desc: 'A stable RawSource for a crawled web page, with locator scheme and checksum.' },
          { fn: 'manualEntrySource', desc: 'A stable RawSource for a value entered by hand, kept inspectable like the rest.' },
        ].map(({ fn, desc }) => (
          <div key={fn} style="
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
            padding: 1.1rem 1.25rem;
            background: var(--color-ink-1);
            border: 1px solid var(--color-edge);
            border-radius: 4px;
          ">
            <code style="
              font-family: var(--font-mono);
              font-size: 0.78rem;
              color: var(--color-gold-2);
            ">{fn}()</code>
            <span style="font-size: 0.78rem; color: var(--color-chalk-3); line-height: 1.45;">{desc}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Worked example
  ────────────────────────────────────────────────────────── -->
  <section style="
    padding: 5rem var(--spacing-page);
    border-top: 1px solid var(--color-edge);
    background: var(--color-ink-1);
  ">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="
        display: grid;
        grid-template-columns: 1fr 1.15fr;
        gap: 4rem;
        align-items: center;
      ">
        <div>
          <div class="label-sm" style="margin-bottom: 1.5rem; color: var(--color-gold-2);">A worked example</div>
          <h2 class="display-md" style="color: var(--color-chalk); margin-bottom: 1.25rem;">
            One field. Full provenance.
          </h2>
          <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.75; margin-bottom: 1.5rem;">
            A crawler reads a registration status off a public record. With
            <code style="font-family: var(--font-mono); font-size: 0.85rem; color: var(--color-gold-2); background: rgba(232,194,116,0.08); padding: 0.1rem 0.35rem; border-radius: 2px;">fieldObservation</code>,
            the source, extraction, review outcome, and claim travel together —
            so Surface can report not just the value, but where it came from
            and how fresh it is.
          </p>
          <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.75; margin: 0;">
            Conflicting candidates don't disappear. A losing source stays on the
            trail as <code style="font-family: var(--font-mono); font-size: 0.85rem; color: var(--color-chalk-3);">superseded</code>,
            and an unresolved conflict projects to Surface as
            <code style="font-family: var(--font-mono); font-size: 0.85rem; color: var(--color-chalk-3);">disputed</code>.
          </p>
        </div>

        <div class="terminal">
          <div class="terminal-bar">
            <div class="terminal-dot"></div>
            <div class="terminal-dot"></div>
            <div class="terminal-dot"></div>
            <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--color-chalk-3); margin-left: 0.5rem;">field-observation.ts</span>
          </div>
          <div class="terminal-body">
<pre style="margin: 0; white-space: pre; overflow-x: auto; font-family: var(--font-mono); font-size: 0.72rem; line-height: 1.7; color: var(--color-chalk-2);"><span style="color: var(--color-gold-2);">import</span> {'{'} fieldObservation,
         SurveyInputBuilder {'}'} <span style="color: var(--color-gold-2);">from</span> <span style="color: var(--color-green);">"@kontourai/survey"</span>;

<span style="color: var(--color-gold-2);">const</span> input = <span style="color: var(--color-gold-2);">new</span> <span style="color: var(--color-cobalt-2);">SurveyInputBuilder</span>({'{'} source: <span style="color: var(--color-green);">"crawler:run-1"</span> {'}'})
  .<span style="color: var(--color-cobalt-2);">addObservation</span>(<span style="color: var(--color-cobalt-2);">fieldObservation</span>({'{'}
    id: <span style="color: var(--color-green);">"entity-123.status.current"</span>,
    field: <span style="color: var(--color-green);">"registrationStatus"</span>,
    value: <span style="color: var(--color-green);">"ACTIVE"</span>,
    rawSource: {'{'}
      kind: <span style="color: var(--color-green);">"web-page"</span>,
      sourceRef: <span style="color: var(--color-green);">"https://records.test/123"</span>,
      observedAt: <span style="color: var(--color-cobalt-2);">now</span>(),
      locatorScheme: <span style="color: var(--color-green);">"html"</span>,
    {'}'},
    extraction: {'{'}
      confidence: <span style="color: var(--color-gold-2);">0.97</span>,
      locator: <span style="color: var(--color-green);">"css:#registration-status"</span>,
      extractor: <span style="color: var(--color-green);">"example-crawler"</span>,
      extractedAt: <span style="color: var(--color-cobalt-2);">now</span>(),
    {'}'},
    reviewOutcome: {'{'} status: <span style="color: var(--color-green);">"verified"</span> {'}'},
    claim: {'{'}
      subjectType: <span style="color: var(--color-green);">"public-record.entity"</span>,
      subjectId: <span style="color: var(--color-green);">"entity-123"</span>,
      claimType: <span style="color: var(--color-green);">"public-data.field"</span>,
      impactLevel: <span style="color: var(--color-green);">"medium"</span>,
      collectedBy: <span style="color: var(--color-green);">"example-crawler"</span>,
    {'}'},
  {'}'}))
  .<span style="color: var(--color-cobalt-2);">build</span>();</pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────
       Surface handoff
  ────────────────────────────────────────────────────────── -->
  <section style="padding: 5rem var(--spacing-page); border-top: 1px solid var(--color-edge);">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
      ">
        <div>
          <div class="label-sm" style="margin-bottom: 1.5rem; color: var(--color-gold);">Built for Surface</div>
          <h2 class="display-md" style="color: var(--color-chalk); margin-bottom: 1.25rem;">
            Survey produces.<br />Surface verifies.
          </h2>
          <p style="color: var(--color-chalk-2); font-size: 0.95rem; line-height: 1.75; margin-bottom: 1.5rem;">
            <code style="font-family: var(--font-mono); font-size: 0.85rem; color: var(--color-gold-2);">buildSurveyTrustInput</code>
            projects Survey records into a Surface
            <code style="font-family: var(--font-mono); font-size: 0.85rem; color: var(--color-gold);">TrustInput</code>.
            From there, Surface owns claim status, evidence, dependencies,
            freshness, and the trust reports humans and agents inspect.
          </p>
          <a href="/surface" data-umami-event="survey-explore-surface" style="
            font-family: var(--font-mono);
            font-size: 0.78rem;
            color: var(--color-gold);
            text-decoration: none;
          ">Explore Surface →</a>
        </div>

        <div class="terminal">
          <div class="terminal-bar">
            <div class="terminal-dot"></div>
            <div class="terminal-dot"></div>
            <div class="terminal-dot"></div>
            <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--color-chalk-3); margin-left: 0.5rem;">survey → surface</span>
          </div>
          <div class="terminal-body">
            <p class="muted">  Survey records</p>
            <p>  source → extraction → candidate → review → <span class="info">claim</span></p>
            <br />
            <p class="muted">  buildSurveyTrustInput()</p>
            <p style="color: var(--color-chalk-3);">  ───────────────────────────────</p>
            <p class="info">  Surface TrustInput</p>
            <p class="pass">  verified  registrationStatus = ACTIVE</p>
            <p class="muted">  evidence  web-page · css:#registration-status</p>
            <p class="muted">  freshness owned by Surface policy</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer active="survey" />
</Layout>

<style>
  @media (max-width: 1000px) {
    section > div > div[style*="grid-template-columns: repeat(5"] {
      display: grid !important;
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }

  @media (max-width: 900px) {
    section > div > div[style*="grid-template-columns: 1fr 1fr"],
    section > div > div[style*="grid-template-columns: 1fr 1.15fr"],
    section > div > div[style*="grid-template-columns: repeat(3, 1fr)"] {
      display: flex !important;
      flex-direction: column !important;
    }
  }

  @media (max-width: 600px) {
    section > div > div[style*="grid-template-columns: repeat(5"] {
      display: flex !important;
      flex-direction: column !important;
    }
  }
</style>
