---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
---

<Layout title="404 — Not found · Kontour AI" noindex>
  <Nav />
  <main class="notfound">
    <p class="label-sm notfound__kicker">404</p>
    <h1 class="display-md notfound__title">Claim not found.</h1>
    <p class="notfound__status">
      trust status: <span class="trust-badge trust-badge--unknown notfound__badge">unknown</span>
    </p>
    <a href="/" class="btn-ghost">← Return home</a>
  </main>
</Layout>

<style>
  .notfound {
    min-height: calc(100dvh - 56px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-page);
    text-align: center;
  }
  .notfound__kicker {
    margin-bottom: 1.5rem;
  }
  .notfound__title {
    color: var(--color-chalk-2);
    margin-bottom: 1rem;
  }
  .notfound__status {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-chalk-3);
    margin-bottom: 2rem;
  }
  .notfound__badge {
    margin-left: 0.25rem;
  }
</style>
