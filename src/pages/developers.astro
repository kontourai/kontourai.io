---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import Section from '@/components/Section.astro';
import Glow from '@/components/Glow.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Card from '@/components/Card.astro';
import Grid from '@/components/Grid.astro';
import Terminal from '@/components/Terminal.astro';
import { kits } from '@/lib/products';
import type { Accent } from '@/lib/theme';
import pkg from '../../package.json';

// Second-validator pins rendered from package.json, same as the receipts
// pages (#111) — the advertised command can't drift from what CI exercises.
const hachurePin = pkg.devDependencies.hachure;
const ajvPin = pkg.devDependencies.ajv;

// The two paged kits come from the shared catalog copy; the two agentless
// kits ship in the same engine repo and link to the engine docs.
const kitCards: { name: string; href: string; job: string; note: string; accent: Accent; external?: boolean; event: string }[] = [
  { name: 'Builder Kit', href: '/builder-kit/', accent: 'chalk-2', event: 'developers-kit-builder', job: kits[0].job, note: 'The first-party delivery path: gated states, review and verify loops, receipts on the way out.' },
  { name: 'Knowledge Kit', href: '/knowledge-kit/', accent: 'gold', event: 'developers-kit-knowledge', job: kits[1].job, note: 'Durable knowledge with provenance, freshness, and gated promotion — memory that carries receipts.' },
  { name: 'Release Evidence Kit', href: 'https://kontourai.github.io/flow-agents/', accent: 'green', external: true, event: 'developers-kit-release-evidence', job: 'Agentless, flows-only release evidence.', note: 'Proof the engine runs solutions that ship no agent at all.' },
  { name: 'Veritas Governance Kit', href: 'https://kontourai.github.io/flow-agents/', accent: 'cobalt-2', external: true, event: 'developers-kit-veritas-governance', job: 'Agentless, flows-only governance gates.', note: 'Feeds repo readiness evidence into Flow gates.' },
];

const useCases = [
  {
    title: 'Sales / RevOps',
    detail: 'Keep account, pipeline, renewal, and enablement claims tied to sources, freshness, approvals, and next actions.',
  },
  {
    title: 'Software delivery',
    detail:
      "Make code-change readiness, release gates, browser checks, and missing evidence visible before merge. Live example: this site's own PRs merge behind a required Trust Verify check, and the receipts page publishes the resulting bundles.",
  },
  {
    title: 'Public data and records',
    detail: 'Track claim provenance, review status, staleness, and disputed facts for directories or public datasets.',
  },
  {
    title: 'Regulated advisory review',
    detail: 'Separate authored recommendations from evidence, reviewer authority, exception handling, and final status.',
  },
  {
    title: 'Support and customer operations',
    detail: 'Route unresolved promises, stale facts, policy exceptions, and follow-up work back to the owning system.',
  },
  {
    title: 'Research and knowledge operations',
    detail: 'Preserve where assertions came from, what changed, which gaps remain, and who can rely on the output.',
  },
];

const states = [
  {
    label: 'Current state',
    body: 'Published trust receipts you can recompute under two validators, the /trust bypass list, Veritas readiness evidence, the Flow Agents engine with Builder and Knowledge kits, runtime hooks across Claude Code / Codex / Kiro / opencode / pi, AWS Strands framework-adapter previews, and Console 2.x projections — all inspectable now.',
    accent: 'green',
  },
  {
    label: 'Near-term direction',
    body: 'Kit-marketplace conformance certification, richer Console projections (hosted mode grew a durable economics store), and tighter cross-product handoffs are being wired in product by product.',
    accent: 'cobalt-2',
  },
  {
    label: 'Future possibilities',
    body: 'Kubernetes-style operators and hosted coordination are possible future integrations. They are not current requirements for using the products.',
    accent: 'gold',
  },
] as const;

const labRepos = [
  {
    slug: 'hachure',
    label: 'Hachure (spec)',
    repo: 'https://github.com/hachure-org/spec',
    description:
      'The open trust.bundle format: normative schemas, conformance vectors, and the L0–L2 signing assurance levels. Surface and the hachure reference CLI are two implementations of it — the receipts page shows both validating the same artifacts.',
  },
  {
    slug: 'datum',
    label: 'Datum',
    repo: 'https://github.com/kontourai/datum',
    description:
      'Portfolio AI provider/model registry: define providers, models, roles once; resolve which backend, which model, whose key, what base URL. Never makes model calls.',
  },
  {
    slug: 'bearing',
    label: 'Bearing',
    repo: 'https://github.com/kontourai/bearing',
    description:
      'Evidence-backed model capability intelligence: provenance-bearing model observations compiled into deterministic catalog snapshots, with runtime-aware ranking — without invoking models.',
  },
  {
    slug: 'traverse',
    label: 'Traverse',
    repo: 'https://github.com/kontourai/traverse',
    description:
      "Schema-directed content extraction that produces provenance-bearing, review-ready extraction proposals in Survey's shape.",
  },
  {
    slug: 'forage',
    label: 'Forage',
    repo: 'https://github.com/kontourai/forage',
    description:
      'Safe, replayable crawling for untrusted URLs — SSRF-guarded egress and snapshot manifests that feed pages into Traverse for review pipelines.',
  },
  {
    slug: 'lookout',
    label: 'Lookout',
    repo: 'https://github.com/kontourai/lookout',
    description:
      'Web source monitoring: a source registry plus a drift-check runner over Traverse snapshots, authoring provenance-bearing Survey inputs when watched sources change.',
  },
  {
    slug: 'ephemeris',
    label: 'Ephemeris',
    repo: 'https://github.com/kontourai/ephemeris',
    description:
      'External freshness scheduler / event-bridge for the Kontour suite. Frozen since 2026-07 — its freshness-trigger capability is being folded into Flow.',
  },
  {
    slug: 'kit-research',
    label: 'Research Kit',
    repo: 'https://github.com/kontourai/kit-research',
    description:
      'A Flow Agents kit for source-traced research — capture, compile, recall with provenance gates. Also our own test of the third-party kit-authoring path.',
  },
  {
    slug: 'ui',
    label: 'Console Kit (UI)',
    repo: 'https://github.com/kontourai/ui',
    description:
      'Shared design tokens and React/web-component primitives for Kontour consoles. You only need this if you are building a console surface.',
  },
] as const;
---

<Layout
  title="Developers — Install the Flow Agents engine, add kits, keep the receipts · Kontour AI"
  description="Start with the Flow Agents engine and its kits — Builder, Knowledge, and the agentless evidence kits — then go deeper into the disciplines it wires in: Surface trust records, Flow gates, Veritas readiness, Console projections."
>
  <Nav active="developers" />

  <Section contour size="hero" borderBottom>
    <Glow accent="gold" position="top-right" />
    <div class="container dev-hero">
      <div class="hero-badges">
        <span class="trust-badge trust-badge--proposed">developer start</span>
        <span class="install-hint">npx @kontourai/flow-agents init</span>
      </div>
      <h1 class="product-title animate-fade-up">Kontour for developers</h1>
      <p class="product-tagline animate-fade-up delay-100" data-accent="gold">install the engine, add a kit, keep the receipts</p>
      <p class="hero-copy hero-copy--wide animate-fade-up delay-200">
        Kontour is one product: an engine — <a href="/flow-agents/">Flow
        Agents</a> — that installs into the coding agent you already run and
        gates its work on evidence instead of promises. Kits are the
        workflows you install on top: Builder for delivery, Knowledge for
        durable memory, plus agentless kits that run with no agent at all.
        Everything the engine gates comes out the other side as a
        recomputable trust receipt. Under the hood, that machinery is a set
        of focused components the engine wires in for you — you don't need
        to learn them to use Kontour, and each stays independently adoptable
        when you want one alone.
      </p>
      <div class="hero-actions animate-fade-up delay-300">
        <a href="#quickstart" class="btn-primary" data-umami-event="developers-hero-quickstart">Install the engine →</a>
        <a href="https://github.com/kontourai" target="_blank" rel="noopener" class="btn-ghost" data-umami-event="developers-hero-github">Open repositories</a>
      </div>
    </div>
  </Section>

  <!-- Quickstart: real commands first, diagrams after ---------------------- -->
  <Section id="quickstart" borderBottom>
    <div class="container">
      <Eyebrow gap="sm" accent="green">Start here</Eyebrow>
      <h2 class="display-md measure-lg">Two commands, then the diagrams.</h2>
      <p class="body measure quickstart-intro">
        Install the engine into a workspace you already use, then check our
        receipts before you believe our copy — every published bundle
        recomputes under two validators, and the same commands run in this
        site's own CI on every change.
      </p>
      <Grid cols={2} gap="lg" align="start">
        <Terminal title="install the engine + kits">
          <p><span class="prompt">$ </span><span class="cmd">npx @kontourai/flow-agents init</span></p>
          <p class="muted"># hooks + adapters for Claude Code, Codex, Kiro,</p>
          <p class="muted"># opencode, and pi — blocking gates on the first</p>
          <p class="muted"># three; advisory on the rest (matrix on /trust)</p>
        </Terminal>
        <Terminal title="verify a receipt, second opinion included">
          <p class="muted"># grab the bundle from /receipts/ first</p>
          <p><span class="prompt">$ </span><span class="cmd">npx -y -p ajv@{ajvPin} -p hachure@{hachurePin} \</span></p>
          <p><span class="cmd">    hachure validate flow-agents-delivery.trust.bundle</span></p>
          <p class="pass">valid TrustBundle (schemaVersion 5)</p>
        </Terminal>
      </Grid>
      <div class="quickstart-links">
        <a href="/receipts/" class="btn-ghost" data-umami-event="developers-quickstart-receipts">Download real receipts →</a>
        <a href="/trust/" class="btn-ghost" data-umami-event="developers-quickstart-trust">Read the bypass list →</a>
        <a href="https://kontourai.github.io/flow-agents/" target="_blank" rel="noopener" class="btn-ghost" data-umami-event="developers-quickstart-docs">Engine docs →</a>
      </div>
    </div>
  </Section>

  <!-- The kits: what you actually install on the engine ------------------- -->
  <Section id="kits" tone="alt" borderTop borderBottom>
    <div class="container">
      <Eyebrow gap="sm" accent="chalk-2">The kits</Eyebrow>
      <h2 class="display-md measure-lg">Kits are the workflows. The engine treats them all the same.</h2>
      <p class="body measure kits-intro">
        A kit declares its flows, triggers, and validation requirements in a
        manifest; the engine runs it with no special privilege — first-party
        or bring-your-own.
      </p>
      <Grid min="260" gap="md">
        {kitCards.map(({ name, href, job, note, accent, external, event }) => (
          <a
            href={href}
            class="kit-card"
            data-accent={accent}
            target={external ? '_blank' : undefined}
            rel={external ? 'noopener' : undefined}
            data-umami-event={event}
          >
            <span class="kit-card__name">{name}</span>
            <span class="kit-card__job">{job}</span>
            <span class="kit-card__note">{note}</span>
            <span class="kit-card__cta">{external ? 'Engine docs →' : `Explore ${name} →`}</span>
          </a>
        ))}
      </Grid>
    </div>
  </Section>

  <!-- The one ownership artifact: the disciplines the engine wires in ------ -->
  <Section id="ownership" size="lg">
    <div class="container">
      <Eyebrow gap="sm">Under the hood</Eyebrow>
      <h2 class="display-md measure-lg">The components the engine wires in.</h2>
      <p class="fine measure ownership-note">
        None of this is required reading — <code>init</code> assembles these
        for you. This map is for auditing the proof chain, or adopting a
        single component on its own. Each one owns one layer, and
        composition is intentionally one-way: tools and workflows consume
        trust and process evidence, but the evidence substrate never depends
        on a specific agent, workflow, or application.
      </p>

      <div class="ownership-map" aria-label="Product relationship layer map">
        <div class="ownership-map__lane ownership-map__lane--tools">
          <span class="lane-label">Tools and workflows</span>
          <div class="lane-grid lane-grid--two">
            <div class="map-card" data-accent="chalk-2">
              <strong><a href="/flow-agents/" data-umami-event="developers-map-flow-agents">Flow Agents</a></strong>
              <span>runs local agent workflows, skills, sidecars, and kits</span>
            </div>
            <div class="map-card" data-accent="chalk-2">
              <strong><a href="/builder-kit/" data-umami-event="developers-map-builder-kit">Builder Kit</a></strong>
              <span>consumes Flow, Veritas, and Surface signals for build work</span>
            </div>
          </div>
        </div>

        <div class="ownership-map__lane ownership-map__lane--governance">
          <span class="lane-label">Governance and process</span>
          <div class="lane-grid lane-grid--two">
            <div class="map-card" data-accent="green">
              <strong><a href="/veritas/" data-umami-event="developers-map-veritas">Veritas</a></strong>
              <span>owns repo standards, readiness, evidence findings, and exceptions</span>
            </div>
            <div class="map-card" data-accent="cobalt-2">
              <strong><a href="/flow/" data-umami-event="developers-map-flow">Flow</a></strong>
              <span>owns paths, transitions, gates, route-backs, and next action</span>
            </div>
          </div>
        </div>

        <div class="ownership-map__lane ownership-map__lane--trust">
          <span class="lane-label">Trust substrate</span>
          <div class="lane-grid lane-grid--two">
            <div class="map-card" data-accent="gold">
              <strong><a href="/surface/" data-umami-event="developers-map-surface">Surface</a></strong>
              <span>owns portable claims, evidence, policies, status, Trust Reports, and transparency gaps</span>
            </div>
            <div class="map-card" data-accent="gold-2">
              <strong><a href="/survey/" data-umami-event="developers-map-survey">Survey</a></strong>
              <span>feeds Surface — sources, extractions, and reviews become claims with provenance</span>
            </div>
          </div>
        </div>

        <div class="ownership-map__lane ownership-map__lane--view">
          <span class="lane-label">Operating view</span>
          <div class="map-card map-card--wide" data-accent="cobalt">
            <strong><a href="/console/" data-umami-event="developers-map-console">Console</a></strong>
            <span>aggregates product-owned projections and routes attention back to the owner</span>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section tone="alt" borderTop>
    <div class="container">
      <Eyebrow gap="sm">Use-case families</Eyebrow>
      <h2 class="display-md measure-lg">Useful anywhere claims, process, readiness, and evidence need to stay connected.</h2>
      <Grid min="260" gap="md" class="use-grid">
        {useCases.map(({ title, detail }) => (
          <div class="use-case">
            <h3>{title}</h3>
            <p>{detail}</p>
          </div>
        ))}
      </Grid>
    </div>
  </Section>

  <Section borderTop>
    <div class="container state-section">
      <div>
        <Eyebrow gap="sm">Maturity framing</Eyebrow>
        <h2 class="display-md measure-lg">Current state, near-term direction, and future possibilities are separate.</h2>
        <p class="body measure">
          The public map should help developers decide what to inspect next,
          not imply a single finished control plane. Adopt one product, or
          compose several when the workflow needs it.
        </p>
      </div>
      <Grid cols={3} gap="lg">
        {states.map(({ label, body, accent }) => (
          <Card accent={accent} bar="top" pad="md">
            <h3 class="state-card__title">{label}</h3>
            <p class="state-card__body">{body}</p>
          </Card>
        ))}
      </Grid>
    </div>
  </Section>

  <Section tone="alt" borderTop>
    <div class="container">
      <div class="next-links">
        <Eyebrow>Where to go next</Eyebrow>
        <a href="/flow-agents/" data-umami-event="developers-next-flow-agents">Install the Flow Agents engine</a>
        <a href="/builder-kit/" data-umami-event="developers-next-builder-kit">Run delivery with Builder Kit</a>
        <a href="/knowledge-kit/" data-umami-event="developers-next-knowledge-kit">Keep durable memory with Knowledge Kit</a>
        <a href="/receipts/" data-umami-event="developers-next-receipts">Recompute a published receipt</a>
        <a href="/surface/" data-umami-event="developers-next-surface">Inspect Surface trust records</a>
        <a href="/flow/" data-umami-event="developers-next-flow">Inspect Flow gates</a>
        <a href="/veritas/" data-umami-event="developers-next-veritas">Inspect Veritas readiness</a>
        <a href="/console/" data-umami-event="developers-next-console">Inspect Console framing</a>
        <a href="/memory/" data-umami-event="developers-next-memory">How Kontour composes with your memory layer</a>
        <a href="/trust/" data-umami-event="developers-next-trust">Read the honest ceiling</a>
      </div>
    </div>
  </Section>

  <Section borderTop>
    <div class="container">
      <Eyebrow gap="sm">More from the lab</Eyebrow>
      <p class="fine measure lab-intro">
        A few smaller, early public repos in the Kontour org that the product
        line above builds on — nested building blocks, not top-level
        products, published as-is for anyone who wants to look under the
        hood.
      </p>
      <Grid min="280" gap="md">
        {labRepos.map(({ slug, label, repo, description }) => (
          <Card accent="chalk-2" pad="md">
            <h3 class="product-card__title">{label}</h3>
            <p class="product-card__body">{description}</p>
            <div class="product-card__links">
              <a href={repo} target="_blank" rel="noopener" data-umami-event={`developers-lab-${slug}-repo`}>GitHub →</a>
            </div>
          </Card>
        ))}
      </Grid>
    </div>
  </Section>

  <Footer active="developers" />
</Layout>

<style>
  .dev-hero {
    max-width: 820px;
  }

  .ownership-map {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.8rem;
  }

  .map-card,
  .use-case {
    border: 1px solid var(--color-edge);
    background: linear-gradient(135deg, rgba(18, 22, 35, 0.92), rgba(12, 15, 25, 0.86));
  }

  .ownership-note,
  .lab-intro {
    margin: 0.8rem 0 2rem;
  }

  .ownership-map__lane {
    display: grid;
    grid-template-columns: 160px minmax(0, 1fr);
    gap: 1rem;
    align-items: stretch;
  }

  .lane-label {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 86px;
    padding: 0.8rem;
    border: 1px solid var(--color-edge);
    color: var(--color-chalk-3);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    text-align: center;
    background: rgba(7, 9, 14, 0.58);
  }

  .lane-grid {
    display: grid;
    gap: 0.8rem;
  }

  .lane-grid--two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .map-card {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 86px;
    padding: 1rem;
    border-left: 3px solid var(--accent, var(--color-edge-2));
  }

  .map-card strong {
    color: var(--accent, var(--color-chalk));
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .map-card strong a {
    color: inherit;
    text-decoration: none;
  }

  .map-card strong a:hover {
    text-decoration: underline;
  }

  .map-card span {
    color: var(--color-chalk-2);
    font-size: 0.86rem;
    line-height: 1.5;
    margin-top: 0.35rem;
  }

  .product-card__title,
  .state-card__title,
  .use-case h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-chalk);
    margin-bottom: 0.8rem;
  }

  .product-card__body,
  .state-card__body,
  .use-case p {
    color: var(--color-chalk-2);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .product-card__links,
  .next-links {
    display: flex;
    gap: 0.7rem;
    flex-wrap: wrap;
    margin-top: 1.2rem;
  }

  .product-card__links a,
  .next-links a {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-gold);
    text-decoration: none;
  }

  .use-grid {
    margin-top: 2rem;
  }

  .use-case {
    min-height: 170px;
    padding: 1.25rem;
  }

  .state-section {
    display: grid;
    gap: 2rem;
  }

  .next-links {
    align-content: start;
    flex-direction: column;
    padding: 1rem 0;
  }

  /* Kits section ---------------------------------------------------------- */
  .kits-intro {
    margin-bottom: 2rem;
  }

  .kit-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    border: 1px solid var(--color-edge);
    border-left: 3px solid var(--accent, var(--color-edge-2));
    background: linear-gradient(135deg, rgba(18, 22, 35, 0.92), rgba(12, 15, 25, 0.86));
    text-decoration: none;
    transition: border-color 0.18s, background 0.18s;
  }

  .kit-card:hover {
    border-color: var(--accent, var(--color-edge-2));
  }

  .kit-card__name {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--accent, var(--color-chalk));
  }

  .kit-card__job {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-chalk);
    letter-spacing: 0;
  }

  .kit-card__note {
    color: var(--color-chalk-2);
    font-size: 0.86rem;
    line-height: 1.55;
    flex: 1;
  }

  .kit-card__cta {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--accent, var(--color-chalk-3));
    text-transform: uppercase;
    margin-top: 0.4rem;
  }

  /* Quickstart: real commands before diagrams. */
  .quickstart-intro {
    margin-bottom: 2rem;
  }
  .quickstart-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }

  @media (max-width: 720px) {
    .ownership-map__lane {
      grid-template-columns: 1fr;
    }

    .lane-label {
      min-height: auto;
      justify-content: flex-start;
      text-align: left;
    }

    .lane-grid--two {
      grid-template-columns: 1fr;
    }

    .use-case {
      min-height: auto;
    }
  }
</style>
