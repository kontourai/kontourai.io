---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import Section from '@/components/Section.astro';
import Glow from '@/components/Glow.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Card from '@/components/Card.astro';
import Grid from '@/components/Grid.astro';
import Split from '@/components/Split.astro';
import Terminal from '@/components/Terminal.astro';
import Subscribe from '@/components/Subscribe.astro';
import type { Accent } from '@/lib/theme';

const lanes: { title: string; label: string; body: string; subject: string; bodyText: string; accent: Accent }[] = [
  {
    title: 'Design partner',
    label: 'AI-assisted work',
    body: 'You have a real process — intake, review, research, delivery — where the result matters more than the effort. We build the gated version with you: your acceptance criteria encoded, every output carrying evidence you can check.',
    subject: 'Kontour design partner',
    bodyText: 'I want to talk about a design partner fit for Kontour. The trust break I see is:',
    accent: 'gold',
  },
  {
    title: 'Product builder',
    label: 'Claims and evidence',
    body: 'You are building an app that makes claims and needs to show source, freshness, uncertainty, and gaps.',
    subject: 'Kontour product builder',
    bodyText: 'I am building a product that needs inspectable claims. The product is:',
    accent: 'green',
  },
  {
    title: 'Agent workflow team',
    label: 'Gates and readiness',
    body: 'You are shipping with coding agents or internal tools and want durable plans, review, verification, and release evidence.',
    subject: 'Kontour agent workflow',
    bodyText: 'I want to explore Kontour for agent workflows. The workflow I want to make inspectable is:',
    accent: 'cobalt-2',
  },
];

const mailto = (subject: string, body: string) =>
  `mailto:hello@kontourai.io?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
---

<Layout
  title="Early Access — Design-partner and integration access · Kontour AI"
  description="Talk with Kontour AI about design partner fit, product integrations, and inspectability infrastructure for AI-assisted work."
>
  <Nav teaser />

  <Section contour size="hero" borderBottom>
    <Glow accent="gold" position="top-right" />
    <div class="container">
      <Split ratio="1-1" gap="lg" align="center">
        <div>
          <div class="hero-badges">
            <span class="trust-badge trust-badge--proposed">early access</span>
            <span class="install-hint">hello@kontourai.io</span>
          </div>

          <h1 class="product-title animate-fade-up">Tell us where trust breaks.</h1>
          <p class="product-tagline animate-fade-up delay-100" data-accent="gold">
            Design partners, product builders, and teams shipping AI-assisted workflows.
          </p>
          <p class="hero-copy animate-fade-up delay-200">
            Kontour is early infrastructure for making AI-assisted work inspectable:
            claims, evidence, required gates, readiness, uncertainty, and next
            actions. The best conversations start with a concrete place where
            polished output is moving faster than your ability to inspect it.
            Where it fits, the design-partner path is hands-on: we build the
            gated version of your workflow with you — your definition of done
            encoded as checks, every result carrying its evidence. You judge
            the engagement by outcomes you can verify, not a story you take on
            faith.
          </p>
          <div class="animate-fade-up delay-300 early-signup">
            <Subscribe source="early-access" cta="Get early access" event="early-access-subscribe" />
            <p class="early-signup__alt">
              Or <a href={mailto('Kontour early access', 'I want to talk about Kontour early access. The trust break I see is:')} class="early-signup__link" data-umami-event="early-access-hero-email">email us directly</a>
              · <a href="https://github.com/kontourai" target="_blank" rel="noopener" class="early-signup__link" data-umami-event="early-access-hero-github">follow on GitHub</a>
            </p>
          </div>
        </div>

        <Terminal class="animate-fade-in delay-300" title="good fit signals">
          <p class="pass">  ✓ claims need evidence and freshness</p>
          <p class="pass">  ✓ agent work needs required gates</p>
          <p class="pass">  ✓ reviewers need readiness state</p>
          <p class="pass">  ✓ teams need durable handoffs</p>
          <br />
          <p class="warn">  not a fit if the only goal is a chatbot UI</p>
          <p class="muted">  current mode: design partner conversations</p>
        </Terminal>
      </Split>
    </div>
  </Section>

  <Section size="lg">
    <div class="container">
      <Eyebrow gap="lg">Start with the shape of the problem</Eyebrow>
      <Grid cols={3} gap="lg">
        {lanes.map(({ title, label, body, subject, bodyText, accent }) => (
          <Card accent={accent} bar="top" pad="lg">
            <div class="lane__label" data-accent={accent}>{label}</div>
            <h2 class="lane__title">{title}</h2>
            <p class="lane__body">{body}</p>
            <a href={mailto(subject, bodyText)} class="lane__link" data-accent={accent} data-umami-event={`early-access-${title.toLowerCase().replaceAll(' ', '-')}`}>Start this thread →</a>
          </Card>
        ))}
      </Grid>
    </div>
  </Section>

  <Section tone="alt" borderTop>
    <div class="container container--readable">
      <Eyebrow accent="cobalt-2">Who should reach out</Eyebrow>
      <h2 class="display-md reach__title">If one of these reads like your desk, send the note.</h2>
      <p class="body reach__copy">
        Illustrative shapes, not case studies. The pattern is what matters:
        work where the result has a definition of done, and today the only
        proof it was met is somebody's word.
      </p>
      <ul class="reach__list">
        <li class="reach__item" data-accent="gold">
          <strong class="reach__item-title">Legal and compliance process teams</strong>
          <span class="reach__item-body">Intake, conflict checks, filings — where "reviewed" should mean evidence attached, not an initialed box.</span>
        </li>
        <li class="reach__item" data-accent="cobalt-2">
          <strong class="reach__item-title">Insurance operations</strong>
          <span class="reach__item-body">Application and claims information gathering — every gathered fact carrying its source and freshness before a decision stands on it.</span>
        </li>
        <li class="reach__item" data-accent="green">
          <strong class="reach__item-title">Customer service and support leaders</strong>
          <span class="reach__item-body">Promises made in conversation — tracked to evidenced follow-through instead of chat-log archaeology.</span>
        </li>
        <li class="reach__item" data-accent="chalk-2">
          <strong class="reach__item-title">Research teams — clinical, market, or academic</strong>
          <span class="reach__item-body">Synthesis where every assertion points at what it stood on, and the gaps are named instead of smoothed over.</span>
        </li>
        <li class="reach__item" data-accent="gold">
          <strong class="reach__item-title">Investment research and decisioning</strong>
          <span class="reach__item-body">Recommendations kept separate from their evidence, reviewer authority, and named exceptions — so the decision trail survives the decision.</span>
        </li>
        <li class="reach__item" data-accent="cobalt-2">
          <strong class="reach__item-title">Software delivery teams</strong>
          <span class="reach__item-body">The case we prove in public every day: agent-built code that earns its merge. <a href="/receipts/" data-umami-event="early-access-reach-receipts">Check the receipts →</a></span>
        </li>
      </ul>
      <p class="fine reach__note">
        The engine and kits are open and generic. The engagement is encoding
        what your process counts as done into gates the work has to pass —
        so what comes out carries receipts.
      </p>
    </div>
  </Section>

  <Section borderTop>
    <div class="container container--readable">
      <Eyebrow accent="gold">What to send</Eyebrow>
      <h2 class="display-md send__title">One concrete workflow is enough.</h2>
      <p class="body send__copy">
        A useful note says what the work is, who needs to trust it, what evidence
        exists today, and what currently gets missed, stale, skipped, or buried
        in chat. No procurement packet or polished brief required.
      </p>
      <p class="fine send__note">
        Kontour is not promising instant access to a hosted product. The current
        path starts as a focused conversation around fit, examples, and product
        direction — and, where it fits, continues into hands-on design-partner work.
      </p>
    </div>
  </Section>

  <Footer teaser />
</Layout>

<style>
  .early-signup {
    margin-top: 0.5rem;
  }
  .early-signup__alt {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-chalk-3);
    margin-top: 1.25rem;
  }
  .early-signup__link {
    color: var(--color-chalk-2);
    text-decoration: none;
  }
  .early-signup__link:hover {
    color: var(--color-chalk);
  }

  .lane__label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--accent);
    letter-spacing: 0;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .lane__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-chalk);
    margin-bottom: 0.75rem;
    letter-spacing: 0;
  }
  .lane__body {
    color: var(--color-chalk-2);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  .lane__link {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    text-decoration: none;
  }
  .reach__title {
    margin-bottom: 1rem;
  }
  .reach__copy {
    margin-bottom: 2rem;
    max-width: 62ch;
  }
  .reach__list {
    list-style: none;
    margin: 0 0 1.75rem;
    padding: 0;
    display: grid;
    gap: 1.4rem;
  }
  .reach__item {
    border-left: 2px solid var(--accent, var(--color-edge-2));
    padding-left: 1.2rem;
  }
  .reach__item-title {
    display: block;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.15rem;
    color: var(--color-chalk);
    margin-bottom: 0.35rem;
  }
  .reach__item-body {
    display: block;
    color: var(--color-chalk-2);
    font-size: 0.9rem;
    line-height: 1.65;
    max-width: 68ch;
  }
  .reach__item-body a {
    color: var(--color-gold);
    text-decoration: none;
  }
  .reach__note {
    margin: 0;
    max-width: 68ch;
    color: var(--color-chalk-2);
  }

  .send__title {
    margin-bottom: 1.25rem;
  }
  .send__copy {
    margin-bottom: 1.25rem;
  }
  .send__note {
    margin: 0;
  }
</style>
